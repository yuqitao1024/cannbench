[Unit]
Description=CANNBench service
After=network.target

[Service]
Type=simple
User=cannbench
Group=cannbench
WorkingDirectory=/opt/cannbench/cannbench-release
Environment=PYTHONPATH=/opt/cannbench/cannbench-release/src
ExecStart=/usr/bin/python3 -m cannbench serve --frontend-dir web/dist --published-dir published --host 0.0.0.0 --port 8000 --enable-gpu-upload
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
