namespace aten_softmax_v2 {
namespace {

template <typename T, typename AccumT, typename OutT>
struct SpatialSoftMaxForwardEpilogue {
  __aicore__ inline SpatialSoftMaxForwardEpilogue(
      AccumT max_input,
      AccumT sum)
      : max_input(max_input), sum(sum) {}

  __aicore__ inline OutT operator()(T input) const {
    return static_cast<OutT>(__expf(static_cast<AccumT>(input) - max_input) / sum);
  }

  const AccumT max_input;
  const AccumT sum;
};

template <typename T>
struct Add {
  __aicore__ inline T operator()(T a, T b) const {
    return a + b;
  }
};

template <typename T>
struct Max {
  __aicore__ inline T operator()(T a, T b) const {
    return a < b ? b : a;
  }
};

template <typename T, template <typename> class ReduceOp>
__aicore__ inline T spatial_block_reduce_x(
    __ubuf__ T* shared,
    int64_t shared_offset,
    T val) {
  ReduceOp<T> reduce_op;

  __syncthreads();
  shared[shared_offset + threadIdx.x] = val;

  int offset = blockDim.x / 2;
  while (offset > 0) {
    __syncthreads();
    if (threadIdx.x < offset) {
      shared[shared_offset + threadIdx.x] = reduce_op(
          shared[shared_offset + threadIdx.x],
          shared[shared_offset + threadIdx.x + offset]);
    }
    offset /= 2;
  }

  __syncthreads();
  return shared[shared_offset];
}

template <typename T, template <typename> class ReduceOp>
__aicore__ inline T row_block_reduce(
    __ubuf__ T* shared,
    T val) {
  ReduceOp<T> reduce_op;

  __syncthreads();
  shared[threadIdx.x] = val;

  int offset = blockDim.x / 2;
  while (offset > 0) {
    __syncthreads();
    if (threadIdx.x < offset) {
      shared[threadIdx.x] = reduce_op(
          shared[threadIdx.x],
          shared[threadIdx.x + offset]);
    }
    offset /= 2;
  }

  __syncthreads();
  return shared[0];
}

inline int64_t log2_ceil_int64(int64_t value) {
  int64_t log2_value = 0;
  while ((int64_t{1} << log2_value) < value) {
    ++log2_value;
  }
  return log2_value;
}

template <
    typename accscalar_t,
    int64_t kWarpBatch,
    int64_t kWarpSize,
    template <typename>
    class ReduceOp>
__aicore__ inline void persistent_warp_reduce(accscalar_t* values) {
  ReduceOp<accscalar_t> reduce_op;
#pragma unroll
  for (int64_t offset = kWarpSize / 2; offset > 0; offset /= 2) {
#pragma unroll
    for (int64_t i = 0; i < kWarpBatch; ++i) {
      const accscalar_t peer =
          asc_shfl_xor(values[i], static_cast<int32_t>(offset), kWarpSize);
      values[i] = reduce_op(values[i], peer);
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__global__ void row_softmax_forward_kernel(
    outscalar_t* output,
    const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  extern __ubuf__ uint32_t dynamicStartUB[];
  auto shared = (__ubuf__ accscalar_t*)dynamicStartUB;

  for (int64_t row = blockIdx.x; row < outer_size; row += gridDim.x) {
    const int64_t row_offset = row * dim_size;

    accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      const accscalar_t value =
          static_cast<accscalar_t>(input[row_offset + d]);
      max_input = Max<accscalar_t>()(max_input, value);
    }
    max_input = row_block_reduce<accscalar_t, Max>(shared, max_input);

    accscalar_t sum = 0;
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      sum += __expf(
          static_cast<accscalar_t>(input[row_offset + d]) - max_input);
    }
    sum = row_block_reduce<accscalar_t, Add>(shared, sum);

    Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      output[row_offset + d] = epilogue(input[row_offset + d]);
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kLog2Elements,
    template <typename, typename, typename>
    class Epilogue>
__global__ void row_softmax_persistent_forward_kernel(
    outscalar_t* output,
    const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  constexpr int64_t kNextPowerOfTwo = int64_t{1} << kLog2Elements;
  constexpr int64_t kWarpSize =
      kNextPowerOfTwo < 32 ? kNextPowerOfTwo : 32;
  constexpr int64_t kWarpIterations = kNextPowerOfTwo / kWarpSize;
  constexpr int64_t kWarpBatch = kNextPowerOfTwo <= 128 ? 2 : 1;

  for (int64_t row_base = (blockDim.y * blockIdx.x + threadIdx.y) * kWarpBatch;
       row_base < outer_size;
       row_base += gridDim.x * blockDim.y * kWarpBatch) {
    const int64_t local_idx = threadIdx.x;
    accscalar_t elements[kWarpBatch][kWarpIterations];

#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
      const int64_t row_offset = row * dim_size;
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (row < outer_size && element_index < dim_size) {
          elements[batch][iter] =
              static_cast<accscalar_t>(input[row_offset + element_index]);
        } else {
          elements[batch][iter] =
              std::numeric_limits<accscalar_t>::lowest();
        }
      }
    }

    accscalar_t max_values[kWarpBatch];
#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      max_values[batch] = elements[batch][0];
#pragma unroll
      for (int64_t iter = 1; iter < kWarpIterations; ++iter) {
        max_values[batch] =
            Max<accscalar_t>()(max_values[batch], elements[batch][iter]);
      }
    }
    persistent_warp_reduce<accscalar_t, kWarpBatch, kWarpSize, Max>(
        max_values);

    accscalar_t sums[kWarpBatch] = {0};
#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (row < outer_size && element_index < dim_size) {
          elements[batch][iter] =
              __expf(elements[batch][iter] - max_values[batch]);
          sums[batch] += elements[batch][iter];
        } else {
          elements[batch][iter] = 0;
        }
      }
    }
    persistent_warp_reduce<accscalar_t, kWarpBatch, kWarpSize, Add>(sums);

#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
      const int64_t row_offset = row * dim_size;
      if (row >= outer_size) {
        continue;
      }
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (element_index < dim_size) {
          output[row_offset + element_index] =
              static_cast<outscalar_t>(elements[batch][iter] / sums[batch]);
        }
      }
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__global__ void row_softmax_fast_forward_kernel(
    outscalar_t* output,
    const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  extern __ubuf__ uint32_t dynamicStartUB[];
  auto shared = (__ubuf__ accscalar_t*)dynamicStartUB;

  for (int64_t row = blockIdx.x * blockDim.y + threadIdx.y;
       row < outer_size;
       row += gridDim.x * blockDim.y) {
    const int64_t row_offset = row * dim_size;
    const int64_t shared_offset =
        static_cast<int64_t>(threadIdx.y) * blockDim.x;

    accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      const accscalar_t value =
          static_cast<accscalar_t>(input[row_offset + d]);
      max_input = Max<accscalar_t>()(max_input, value);
    }
    max_input = spatial_block_reduce_x<accscalar_t, Max>(
        shared,
        shared_offset,
        max_input);

    accscalar_t sum = 0;
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      sum += __expf(
          static_cast<accscalar_t>(input[row_offset + d]) - max_input);
    }
    sum = spatial_block_reduce_x<accscalar_t, Add>(
        shared,
        shared_offset,
        sum);

    Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      output[row_offset + d] = epilogue(input[row_offset + d]);
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__global__ void row_softmax_generic_forward_kernel(
    outscalar_t* output,
    const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  extern __ubuf__ uint32_t dynamicStartUB[];
  auto shared = (__ubuf__ accscalar_t*)dynamicStartUB;

  for (int64_t row = blockIdx.x * blockDim.y + threadIdx.y;
       row < outer_size;
       row += gridDim.x * blockDim.y) {
    const int64_t row_offset = row * dim_size;
    const int64_t shared_offset =
        static_cast<int64_t>(threadIdx.y) * blockDim.x;

    accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      const accscalar_t value =
          static_cast<accscalar_t>(input[row_offset + d]);
      max_input = Max<accscalar_t>()(max_input, value);
    }
    max_input = spatial_block_reduce_x<accscalar_t, Max>(
        shared,
        shared_offset,
        max_input);

    accscalar_t sum = 0;
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      sum += __expf(
          static_cast<accscalar_t>(input[row_offset + d]) - max_input);
    }
    sum = spatial_block_reduce_x<accscalar_t, Add>(
        shared,
        shared_offset,
        sum);

    Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      output[row_offset + d] = epilogue(input[row_offset + d]);
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__global__ void cunn_spatial_softmax_forward_kernel(
    outscalar_t* output,
    const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size) {
  const int64_t outer_stride = inner_size * dim_size;
  const int64_t dim_stride = inner_size;
  extern __ubuf__ uint32_t dynamicStartUB[];

  for (int64_t outer_index = blockIdx.x; outer_index < outer_size;
       outer_index += gridDim.x) {
    const int64_t outer_offset = outer_index * outer_stride;
    for (int64_t inner_index = blockIdx.y * blockDim.y + threadIdx.y;
         inner_index < inner_size;
         inner_index += blockDim.y * gridDim.y) {
      const int64_t data_offset = outer_offset + inner_index;

      if (blockDim.x > 1) {
        const int64_t shared_offset =
            static_cast<int64_t>(threadIdx.y) * blockDim.x;
        accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          const accscalar_t value = static_cast<accscalar_t>(
              input[data_offset + d * dim_stride]);
          max_input = Max<accscalar_t>()(max_input, value);
        }
        max_input = spatial_block_reduce_x<accscalar_t, Max>(
            (__ubuf__ accscalar_t*)dynamicStartUB,
            shared_offset,
            max_input);

        accscalar_t sum = 0;
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          sum += __expf(
              static_cast<accscalar_t>(input[data_offset + d * dim_stride]) -
              max_input);
        }
        sum = spatial_block_reduce_x<accscalar_t, Add>(
            (__ubuf__ accscalar_t*)dynamicStartUB,
            shared_offset,
            sum);

        Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          output[data_offset + d * dim_stride] =
              epilogue(input[data_offset + d * dim_stride]);
        }
      } else {
        accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
        for (int64_t d = 0; d < dim_size; ++d) {
          const accscalar_t value = static_cast<accscalar_t>(
              input[data_offset + d * dim_stride]);
          max_input = Max<accscalar_t>()(max_input, value);
        }

        accscalar_t sum = 0;
        for (int64_t d = 0; d < dim_size; ++d) {
          sum += __expf(
              static_cast<accscalar_t>(input[data_offset + d * dim_stride]) -
              max_input);
        }

        Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
        for (int64_t d = 0; d < dim_size; ++d) {
          output[data_offset + d * dim_stride] =
              epilogue(input[data_offset + d * dim_stride]);
        }
      }
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
void launch_spatial_forward_impl(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int device) {
  const auto launch = simt::spatial_launch_config_impl(
      outer_size,
      dim_size,
      inner_size,
      static_cast<int64_t>(sizeof(accscalar_t)),
      device);

  const auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);
  auto acl_call = [=]() -> int {
    cunn_spatial_softmax_forward_kernel<scalar_t, accscalar_t, outscalar_t, Epilogue>
        <<<dim3(launch.grid_x, launch.grid_y),
           dim3(launch.block_x, launch.block_y),
           launch.dynamic_ubuf_bytes,
           acl_stream>>>(
            output_ptr,
            input_ptr,
            outer_size,
            dim_size,
            inner_size);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(
      "aten_softmax_v2::spatial_softmax_forward",
      acl_call);
}

enum class RowSoftmaxPath {
  PersistentLike,
  FastLike,
  GenericLike,
};

inline bool use_persistent_like_row_softmax(
    int64_t dim_size,
    int64_t scalar_size) {
  return dim_size <= 2048 && dim_size * scalar_size <= 8192;
}

inline bool use_fast_like_row_softmax(int64_t dim_size) {
  return dim_size > 2048;
}

inline RowSoftmaxPath row_softmax_path(
    int64_t dim_size,
    int64_t scalar_size) {
  if (use_persistent_like_row_softmax(dim_size, scalar_size)) {
    return RowSoftmaxPath::PersistentLike;
  }
  if (use_fast_like_row_softmax(dim_size)) {
    return RowSoftmaxPath::FastLike;
  }
  return RowSoftmaxPath::GenericLike;
}

inline int64_t row_softmax_persistent_block_x(int64_t dim_size) {
  // Match PyTorch CUDA's persistent softmax x-lane shape. This remains the V1
  // correctness-oriented policy while V2 introduces separate row-wise paths.
  constexpr int64_t kCudaWarpLaneLimit = 32;
  int64_t block_x = 1;
  const int64_t target = std::min(dim_size, kCudaWarpLaneLimit);
  while (block_x < target) {
    block_x *= 2;
  }
  return block_x;
}

inline int64_t row_softmax_persistent_block_y(int64_t block_x) {
  constexpr int64_t kCudaPersistentThreadsPerBlock = 128;
  return std::max<int64_t>(1, kCudaPersistentThreadsPerBlock / block_x);
}

inline int64_t row_softmax_fast_block_x() {
  constexpr int64_t kCudaWarpLaneLimit = 32;
  return kCudaWarpLaneLimit;
}

inline int64_t row_softmax_fast_block_y() {
  constexpr int64_t kCudaFastPathThreads = 512;
  constexpr int64_t kCudaWarpLaneLimit = 32;
  return kCudaFastPathThreads / kCudaWarpLaneLimit;
}

inline int64_t row_softmax_generic_block_x(int64_t dim_size) {
  constexpr int64_t kCudaWarpLaneLimit = 32;
  return std::min<int64_t>(row_softmax_persistent_block_x(dim_size), kCudaWarpLaneLimit);
}

inline int64_t row_softmax_generic_block_y() {
  constexpr int64_t kCudaGenericMaxThreads = 1024;
  constexpr int64_t kCudaWarpLaneLimit = 32;
  return kCudaGenericMaxThreads / kCudaWarpLaneLimit;
}

inline int64_t row_softmax_block_x(
    int64_t dim_size,
    RowSoftmaxPath path) {
  switch (path) {
    case RowSoftmaxPath::PersistentLike:
      return row_softmax_persistent_block_x(dim_size);
    case RowSoftmaxPath::FastLike:
      return row_softmax_fast_block_x();
    case RowSoftmaxPath::GenericLike:
      return row_softmax_generic_block_x(dim_size);
  }
  return row_softmax_persistent_block_x(dim_size);
}

inline int64_t row_softmax_grid_x(int64_t outer_size) {
  // Ascend SIMT row-wise kernels showed incorrect all-zero outputs when
  // launching one block per row for large outer_size. The kernel already
  // strides by gridDim.x, so capping grid.x preserves coverage while avoiding
  // oversized row-wise launches.
  constexpr int64_t kRowSoftmaxGridXLimit = 32768;
  return std::min<int64_t>(outer_size, kRowSoftmaxGridXLimit);
}

inline int64_t row_softmax_persistent_grid_x(
    int64_t outer_size,
    int64_t block_y) {
  constexpr int64_t kRowSoftmaxGridXLimit = 32768;
  const int64_t row_blocks = (outer_size + block_y - 1) / block_y;
  return std::min<int64_t>(row_blocks, kRowSoftmaxGridXLimit);
}

inline int64_t row_softmax_persistent_grid_x(
    int64_t outer_size,
    int64_t block_y,
    int64_t warp_batch) {
  constexpr int64_t kRowSoftmaxGridXLimit = 32768;
  const int64_t rows_per_block = block_y * warp_batch;
  const int64_t row_blocks = (outer_size + rows_per_block - 1) / rows_per_block;
  return std::min<int64_t>(row_blocks, kRowSoftmaxGridXLimit);
}

inline const char* row_softmax_api_name(RowSoftmaxPath path) {
  switch (path) {
    case RowSoftmaxPath::PersistentLike:
      return "aten_softmax_v2::row_softmax_persistent_forward";
    case RowSoftmaxPath::FastLike:
      return "aten_softmax_v2::row_softmax_fast_forward";
    case RowSoftmaxPath::GenericLike:
      return "aten_softmax_v2::row_softmax_generic_forward";
  }
  return "aten_softmax_v2::row_softmax_persistent_forward";
}

inline int64_t row_softmax_persistent_warp_batch(int64_t dim_size) {
  const int64_t log2_elements = log2_ceil_int64(dim_size);
  const int64_t next_power_of_two = int64_t{1} << log2_elements;
  return next_power_of_two <= 128 ? 2 : 1;
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue,
    int64_t kLog2Elements>
void launch_row_persistent_forward_kernel(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  row_softmax_persistent_forward_kernel<
      scalar_t,
      accscalar_t,
      outscalar_t,
      kLog2Elements,
      Epilogue>
      <<<dim3(grid_x),
         dim3(block_x, block_y),
         0,
         acl_stream>>>(
          output_ptr,
          input_ptr,
          outer_size,
          dim_size);
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
void dispatch_row_persistent_forward_kernel(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  switch (log2_ceil_int64(dim_size)) {
    case 0:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 0>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 1:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 1>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 2:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 2>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 3:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 3>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 4:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 4>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 5:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 5>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 6:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 6>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 7:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 7>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 8:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 8>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 9:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 9>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 10:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 10>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 11:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, Epilogue, 11>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    default:
      TORCH_CHECK(false, "persistent softmax supports dim_size <= 2048");
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
void launch_row_forward_impl(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size) {
  const RowSoftmaxPath path = row_softmax_path(
      dim_size,
      static_cast<int64_t>(sizeof(scalar_t)));
  const int64_t block_x = row_softmax_block_x(dim_size, path);
  const int64_t block_y = path == RowSoftmaxPath::PersistentLike
      ? row_softmax_persistent_block_y(block_x)
      : path == RowSoftmaxPath::FastLike
      ? row_softmax_fast_block_y()
      : path == RowSoftmaxPath::GenericLike ? row_softmax_generic_block_y() : 1;
  const int64_t warp_batch = path == RowSoftmaxPath::PersistentLike
      ? row_softmax_persistent_warp_batch(dim_size)
      : 1;
  const int64_t grid_x = path == RowSoftmaxPath::PersistentLike
      ? row_softmax_persistent_grid_x(outer_size, block_y, warp_batch)
      : path == RowSoftmaxPath::FastLike || path == RowSoftmaxPath::GenericLike
      ? row_softmax_persistent_grid_x(outer_size, block_y)
      : row_softmax_grid_x(outer_size);
  const int64_t dynamic_ubuf_bytes = path == RowSoftmaxPath::PersistentLike
      ? 0
      : block_x * block_y * sizeof(accscalar_t);
  const char* api_name = row_softmax_api_name(path);
  const auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);
  auto acl_call = [=]() -> int {
    if (path == RowSoftmaxPath::PersistentLike) {
      dispatch_row_persistent_forward_kernel<
          scalar_t,
          accscalar_t,
          outscalar_t,
          Epilogue>(
          input_ptr,
          output_ptr,
          outer_size,
          dim_size,
          block_x,
          block_y,
          grid_x,
          acl_stream);
    } else if (path == RowSoftmaxPath::FastLike) {
      row_softmax_fast_forward_kernel<
          scalar_t,
          accscalar_t,
          outscalar_t,
          Epilogue>
          <<<dim3(grid_x),
             dim3(block_x, block_y),
             dynamic_ubuf_bytes,
             acl_stream>>>(
              output_ptr,
              input_ptr,
              outer_size,
              dim_size);
    } else if (path == RowSoftmaxPath::GenericLike) {
      row_softmax_generic_forward_kernel<
          scalar_t,
          accscalar_t,
          outscalar_t,
          Epilogue>
          <<<dim3(grid_x),
             dim3(block_x, block_y),
             dynamic_ubuf_bytes,
             acl_stream>>>(
              output_ptr,
              input_ptr,
              outer_size,
              dim_size);
    } else {
      row_softmax_forward_kernel<scalar_t, accscalar_t, outscalar_t, Epilogue>
          <<<dim3(grid_x),
             dim3(block_x),
             dynamic_ubuf_bytes,
             acl_stream>>>(
              output_ptr,
              input_ptr,
              outer_size,
              dim_size);
    }
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(api_name, acl_call);
}

template <template <typename, typename, typename> class Epilogue>
at::Tensor spatial_forward_common(
    const at::Tensor& input,
    int64_t dim,
    bool half_to_float) {
  TORCH_CHECK(
      input.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU tensor");
  TORCH_CHECK(input.dim() > 0, "softmax input must have at least one dimension");

  const auto wrapped_dim = at::maybe_wrap_dim(dim, input.dim());
  auto in_tensor = input.contiguous();

  int64_t outer_size = 1;
  for (int64_t d = 0; d < wrapped_dim; ++d) {
    outer_size *= in_tensor.size(d);
  }

  const int64_t dim_size = in_tensor.size(wrapped_dim);
  int64_t inner_size = 1;
  for (int64_t d = wrapped_dim + 1; d < in_tensor.dim(); ++d) {
    inner_size *= in_tensor.size(d);
  }

  TORCH_CHECK(
      inner_size >= 1,
      "spatial softmax path requires inner_size >= 1, got ",
      inner_size);

  if (in_tensor.numel() == 0) {
    if (half_to_float) {
      TORCH_CHECK(
          in_tensor.scalar_type() == at::ScalarType::Half,
          "half_to_float is supported for Half type only");
      return at::empty(
          in_tensor.sizes(), in_tensor.options().dtype(at::kFloat));
    }
    return at::empty_like(in_tensor);
  }

  if (half_to_float) {
    TORCH_CHECK(
        in_tensor.scalar_type() == at::ScalarType::Half,
        "half_to_float is supported for Half type only");
    auto compute_input = in_tensor.to(at::kFloat);
    auto output = at::empty(
        compute_input.sizes(), compute_input.options().dtype(at::kFloat));
    if (inner_size == 1) {
      launch_row_forward_impl<float, float, float, Epilogue>(
          compute_input.const_data_ptr<float>(),
          output.mutable_data_ptr<float>(),
          outer_size,
          dim_size);
    } else {
      launch_spatial_forward_impl<float, float, float, Epilogue>(
          compute_input.const_data_ptr<float>(),
          output.mutable_data_ptr<float>(),
          outer_size,
          dim_size,
          inner_size,
          compute_input.get_device());
    }
    return output;
  }

  TORCH_CHECK(
      in_tensor.scalar_type() != at::ScalarType::Double,
      "double device path is not supported in the current SIMT spatial prototype");
  auto output = at::empty_like(in_tensor);
  if (in_tensor.scalar_type() == at::ScalarType::Half) {
    if (inner_size == 1) {
      launch_row_forward_impl<__fp16, float, __fp16, Epilogue>(
          reinterpret_cast<const __fp16*>(in_tensor.const_data_ptr<at::Half>()),
          reinterpret_cast<__fp16*>(output.mutable_data_ptr<at::Half>()),
          outer_size,
          dim_size);
    } else {
      launch_spatial_forward_impl<__fp16, float, __fp16, Epilogue>(
          reinterpret_cast<const __fp16*>(in_tensor.const_data_ptr<at::Half>()),
          reinterpret_cast<__fp16*>(output.mutable_data_ptr<at::Half>()),
          outer_size,
          dim_size,
          inner_size,
          in_tensor.get_device());
    }
  } else if (in_tensor.scalar_type() == at::ScalarType::Float) {
    if (inner_size == 1) {
      launch_row_forward_impl<float, float, float, Epilogue>(
          in_tensor.const_data_ptr<float>(),
          output.mutable_data_ptr<float>(),
          outer_size,
          dim_size);
    } else {
      launch_spatial_forward_impl<float, float, float, Epilogue>(
          in_tensor.const_data_ptr<float>(),
          output.mutable_data_ptr<float>(),
          outer_size,
          dim_size,
          inner_size,
          in_tensor.get_device());
    }
  } else {
    TORCH_CHECK(
        false,
        "SIMT spatial softmax supports float16 and float32 in the no-cast path, got ",
        in_tensor.scalar_type());
  }
  return output;
}

bool should_use_spatial_softmax_path(const at::Tensor& tensor, int64_t dim) {
  if (tensor.dim() <= 0) {
    return false;
  }

  const auto wrapped_dim = at::maybe_wrap_dim(dim, tensor.dim());
  int64_t inner_size = 1;
  for (int64_t d = wrapped_dim + 1; d < tensor.dim(); ++d) {
    inner_size *= tensor.size(d);
  }
  return inner_size >= 1;
}

at::Tensor spatial_softmax_forward_privateuse1(
    const at::Tensor& input,
    int64_t dim,
    bool half_to_float) {
  return spatial_forward_common<SpatialSoftMaxForwardEpilogue>(
      input,
      dim,
      half_to_float);
}

at::Tensor softmax_int_privateuse1(
    const at::Tensor& self,
    int64_t dim,
    std::optional<c10::ScalarType> dtype) {
  const bool half_to_float =
      self.scalar_type() == at::ScalarType::Half &&
      dtype == at::ScalarType::Float;
  auto converted = dtype.has_value() && !half_to_float
      ? self.toType(dtype.value())
      : self;

  if (should_use_spatial_softmax_path(converted, dim)) {
    return spatial_softmax_forward_privateuse1(converted, dim, half_to_float);
  }
  return at::_softmax(converted, dim, half_to_float);
}

} // namespace

TORCH_LIBRARY_FRAGMENT(aten_softmax_v2, m) {
  m.def(
      "spatial_softmax_forward(Tensor input, int dim, bool half_to_float=False) -> Tensor");
}

TORCH_LIBRARY_IMPL(aten_softmax_v2, PrivateUse1, m) {
  m.impl("spatial_softmax_forward", &spatial_softmax_forward_privateuse1);
}

TORCH_LIBRARY_IMPL(aten, PrivateUse1, m) {
  m.impl(
      TORCH_SELECTIVE_NAME("aten::softmax.int"),
      TORCH_FN(softmax_int_privateuse1));
}

} // namespace aten_softmax_v2
