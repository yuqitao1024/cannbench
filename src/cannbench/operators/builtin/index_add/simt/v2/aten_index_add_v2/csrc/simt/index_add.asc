#include <cstdint>

#include "acl/acl.h"
#include "simt_api/asc_fp16.h"
#include "simt_api/asc_simt.h"

namespace {

__SIMT_DEVICE_FUNCTIONS_DECL__ inline float scale_index_add_value(
    float source,
    float alpha) {
  return source * alpha;
}

__SIMT_DEVICE_FUNCTIONS_DECL__ inline half scale_index_add_value(
    half source,
    uint16_t alpha) {
  return __hmul(source, __ushort_as_half(alpha));
}

template <typename scalar_t, typename alpha_t>
__global__ __launch_bounds__(1024) void index_add_generic_kernel(
    const int32_t* index,
    const scalar_t* source,
    scalar_t* output,
    alpha_t alpha,
    int32_t index_size,
    int32_t inner_stride,
    int32_t self_dim_size,
    int32_t total_length) {
  for (int32_t thread_id = blockIdx.x * blockDim.x + threadIdx.x;
       thread_id < total_length;
       thread_id += gridDim.x * blockDim.x) {
    const int32_t k = thread_id % inner_stride;
    const int32_t j = (thread_id / inner_stride) % index_size;
    const int32_t i = thread_id / (inner_stride * index_size);

    const int32_t dst_index =
        i * self_dim_size * inner_stride + index[j] * inner_stride + k;
    const scalar_t val = scale_index_add_value(source[thread_id], alpha);
    asc_atomic_add(&output[dst_index], val);
  }
}

template <typename scalar_t, typename alpha_t>
__global__ __launch_bounds__(1024) void index_add_1d_dim0_kernel(
    const int32_t* index,
    const scalar_t* source,
    scalar_t* output,
    alpha_t alpha,
    int32_t total_length) {
  for (int32_t j = blockIdx.x * blockDim.x + threadIdx.x;
       j < total_length;
       j += gridDim.x * blockDim.x) {
    const scalar_t val = scale_index_add_value(source[j], alpha);
    asc_atomic_add(&output[index[j]], val);
  }
}

template <typename scalar_t, typename alpha_t>
__global__ __launch_bounds__(1024) void index_add_2d_dim0_kernel(
    const int32_t* index,
    const scalar_t* source,
    scalar_t* output,
    alpha_t alpha,
    int32_t cols,
    int32_t total_length) {
  for (int32_t thread_id = blockIdx.x * blockDim.x + threadIdx.x;
       thread_id < total_length;
       thread_id += gridDim.x * blockDim.x) {
    const int32_t j = thread_id / cols;
    const int32_t col = thread_id - j * cols;
    const int32_t dst_index = index[j] * cols + col;
    const scalar_t val = scale_index_add_value(source[thread_id], alpha);
    asc_atomic_add(&output[dst_index], val);
  }
}

template <typename scalar_t, typename alpha_t>
__global__ __launch_bounds__(1024) void index_add_3d_dim0_kernel(
    const int32_t* index,
    const scalar_t* source,
    scalar_t* output,
    alpha_t alpha,
    int32_t slice_size,
    int32_t total_length) {
  for (int32_t thread_id = blockIdx.x * blockDim.x + threadIdx.x;
       thread_id < total_length;
       thread_id += gridDim.x * blockDim.x) {
    const int32_t j = thread_id / slice_size;
    const int32_t offset = thread_id - j * slice_size;
    const int32_t dst_index = index[j] * slice_size + offset;
    const scalar_t val = scale_index_add_value(source[thread_id], alpha);
    asc_atomic_add(&output[dst_index], val);
  }
}

template <typename scalar_t, typename alpha_t>
__global__ __launch_bounds__(1024) void index_add_4d_dim3_kernel(
    const int32_t* index,
    const scalar_t* source,
    scalar_t* output,
    alpha_t alpha,
    int32_t self_dim_size,
    int32_t index_size,
    int32_t total_length) {
  for (int32_t thread_id = blockIdx.x * blockDim.x + threadIdx.x;
       thread_id < total_length;
       thread_id += gridDim.x * blockDim.x) {
    const int32_t outer = thread_id / index_size;
    const int32_t j = thread_id - outer * index_size;
    const int32_t dst_index = outer * self_dim_size + index[j];
    const scalar_t val = scale_index_add_value(source[thread_id], alpha);
    asc_atomic_add(&output[dst_index], val);
  }
}

uint32_t blocks_for_length(int64_t total_length) {
  constexpr uint32_t threads_per_block = 1024;
  constexpr uint32_t max_blocks = 64;
  uint32_t blocks_per_grid =
      static_cast<uint32_t>((total_length + threads_per_block - 1) / threads_per_block);
  if (blocks_per_grid > max_blocks) {
    blocks_per_grid = max_blocks;
  }
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }
  return blocks_per_grid;
}

template <typename scalar_t, typename alpha_t>
void launch_index_add_generic(
    const int32_t* index,
    const scalar_t* source,
    scalar_t* output,
    alpha_t alpha,
    int64_t index_size,
    int64_t inner_stride,
    int64_t self_dim_size,
    int64_t total_length,
    aclrtStream stream) {
  constexpr uint32_t threads_per_block = 1024;
  index_add_generic_kernel<scalar_t, alpha_t>
      <<<blocks_for_length(total_length), threads_per_block, 0, stream>>>(
          index,
          source,
          output,
          alpha,
          static_cast<int32_t>(index_size),
          static_cast<int32_t>(inner_stride),
          static_cast<int32_t>(self_dim_size),
          static_cast<int32_t>(total_length));
}

} // namespace

extern "C" void launch_index_add_generic_float(
    const int32_t* index,
    const float* source,
    float* output,
    float alpha,
    int64_t index_size,
    int64_t inner_stride,
    int64_t self_dim_size,
    int64_t total_length,
    aclrtStream stream) {
  launch_index_add_generic<float, float>(
      index, source, output, alpha, index_size, inner_stride, self_dim_size, total_length, stream);
}

extern "C" void launch_index_add_generic_half(
    const int32_t* index,
    const half* source,
    half* output,
    uint16_t alpha,
    int64_t index_size,
    int64_t inner_stride,
    int64_t self_dim_size,
    int64_t total_length,
    aclrtStream stream) {
  launch_index_add_generic<half, uint16_t>(
      index, source, output, alpha, index_size, inner_stride, self_dim_size, total_length, stream);
}

extern "C" void launch_index_add_1d_dim0_float(
    const int32_t* index,
    const float* source,
    float* output,
    float alpha,
    int64_t total_length,
    aclrtStream stream) {
  constexpr uint32_t threads_per_block = 1024;
  index_add_1d_dim0_kernel<float, float>
      <<<blocks_for_length(total_length), threads_per_block, 0, stream>>>(
          index, source, output, alpha, static_cast<int32_t>(total_length));
}

