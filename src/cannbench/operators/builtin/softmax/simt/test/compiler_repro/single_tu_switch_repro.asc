#include <algorithm>
#include <cstdint>
#include <cstdlib>
#include <iostream>
#include <vector>

#include "acl/acl.h"
#include "c_api/asc_simd.h"
#include "simt_api/asc_fp16.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kDeviceId = 0;
constexpr uint32_t kOuterSize = 32;
constexpr uint32_t kDimSize = 1024;
constexpr uint32_t kBlockX = 32;
constexpr uint32_t kBlockY = 8;

#define CHECK_ACL(expr)                                                                                 \
    do {                                                                                                \
        aclError ret = (expr);                                                                          \
        if (ret != ACL_SUCCESS) {                                                                       \
            std::cerr << "ACL call failed: " #expr ", ret=" << static_cast<int32_t>(ret) << std::endl; \
            std::exit(1);                                                                               \
        }                                                                                               \
    } while (0)

template <typename T>
__simt_callee__ inline T device_zero();

template <>
__simt_callee__ inline float device_zero<float>()
{
    return 0.0f;
}

template <>
__simt_callee__ inline __fp16 device_zero<__fp16>()
{
    return (__fp16)0;
}

template <typename scalar_t, typename outscalar_t, int64_t kThreadsPerBlock>
__simt_vf__ inline void debug_persistent_store_vf(
    __gm__ outscalar_t* output, __gm__ const scalar_t* input, int64_t outer_size, int64_t dim_size)
{
    output[0] = device_zero<outscalar_t>();
    (void)input;
    (void)outer_size;
    (void)dim_size;
}

template <typename scalar_t, typename outscalar_t, int64_t kThreadsPerBlock>
__global__ __vector__ void debug_persistent_store_kernel(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y)
{
    asc_vf_call<debug_persistent_store_vf<scalar_t, outscalar_t, kThreadsPerBlock>>(
        dim3(block_x, block_y), output, input, outer_size, dim_size);
}

template <typename scalar_t, typename outscalar_t, int64_t kThreadsPerBlock>
void launch_debug_persistent_store_kernel(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    aclrtStream stream)
{
    debug_persistent_store_kernel<scalar_t, outscalar_t, kThreadsPerBlock>
        <<<grid_x, 0, stream>>>(output_ptr, input_ptr, outer_size, dim_size, block_x, block_y);
}

inline int64_t persistent_threads_per_block(int64_t dim_size)
{
    if (dim_size == 1024) {
        return 256;
    }
    return -1;
}

void instantiate_1024_kernel_but_do_not_run(
    __fp16* input_device, __fp16* output_device, int64_t outer_size, int64_t dim_size, aclrtStream stream)
{
    const int64_t block_x = kBlockX;
    const int64_t block_y = kBlockY;
    const int64_t grid_x = (outer_size + block_y - 1) / block_y;
    if (outer_size == -1) {
        launch_debug_persistent_store_kernel<__fp16, __fp16, 1024>(
            input_device, output_device, outer_size, dim_size, block_x, block_y, grid_x, stream);
    }
}

void run_single_tu_switch_repro(
    __fp16* input_device, __fp16* output_device, int64_t outer_size, int64_t dim_size, aclrtStream stream)
{
    const int64_t block_x = kBlockX;
    const int64_t block_y = kBlockY;
    const int64_t grid_x = (outer_size + block_y - 1) / block_y;

    switch (persistent_threads_per_block(dim_size)) {
        case 256:
            launch_debug_persistent_store_kernel<__fp16, __fp16, 256>(
                input_device, output_device, outer_size, dim_size, block_x, block_y, grid_x, stream);
            break;
        default:
            std::cerr << "Unsupported threads-per-block branch" << std::endl;
            std::exit(1);
    }
}

} // namespace

int main()
{
    const size_t element_count = static_cast<size_t>(kOuterSize) * kDimSize;
    const size_t bytes = element_count * sizeof(__fp16);

    std::vector<__fp16> input_host(element_count, (__fp16)0);
    std::vector<__fp16> output_host(element_count, (__fp16)0);

    __fp16* input_device = nullptr;
    __fp16* output_device = nullptr;
    aclrtStream stream = nullptr;

    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(kDeviceId));
    CHECK_ACL(aclrtCreateStream(&stream));
    CHECK_ACL(aclrtMalloc(reinterpret_cast<void**>(&input_device), bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc(reinterpret_cast<void**>(&output_device), bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(input_device, bytes, input_host.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(output_device, bytes, output_host.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));

    std::cout << "[INFO] mode = single-tu-switch" << std::endl;
    std::cout << "[INFO] shape = (" << kOuterSize << ", " << kDimSize << "), dtype = float16" << std::endl;
    std::cout << "[INFO] threads_per_block branch = " << persistent_threads_per_block(kDimSize) << std::endl;

    instantiate_1024_kernel_but_do_not_run(input_device, output_device, kOuterSize, kDimSize, stream);
    run_single_tu_switch_repro(input_device, output_device, kOuterSize, kDimSize, stream);

    aclError sync_ret = aclrtSynchronizeStream(stream);
    std::cout << "[INFO] aclrtSynchronizeStream ret = " << static_cast<int32_t>(sync_ret) << std::endl;

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        std::cerr << "[INFO] aclGetRecentErrMsg: " << err << std::endl;
    }

    if (output_device != nullptr) {
        CHECK_ACL(aclrtFree(output_device));
    }
    if (input_device != nullptr) {
        CHECK_ACL(aclrtFree(input_device));
    }
    if (stream != nullptr) {
        CHECK_ACL(aclrtDestroyStream(stream));
    }
    CHECK_ACL(aclrtResetDevice(kDeviceId));
    CHECK_ACL(aclFinalize());

    return (sync_ret == ACL_SUCCESS) ? 0 : 1;
}
