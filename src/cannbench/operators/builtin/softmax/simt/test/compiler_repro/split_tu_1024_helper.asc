#include "split_tu_common.h"

namespace softmax_compiler_repro {

void instantiate_1024_kernel_but_do_not_run(
    __fp16* input_device, __fp16* output_device, int64_t outer_size, int64_t dim_size, aclrtStream stream)
{
    const int64_t block_x = kBlockX;
    const int64_t block_y = kBlockY;
    const int64_t grid_x = (outer_size + block_y - 1) / block_y;
    if (outer_size == -1) {
        launch_debug_persistent_store_kernel<__fp16, __fp16, 1024>(
            input_device, output_device, outer_size, dim_size, block_x, block_y, grid_x, stream);
    }
}

} // namespace softmax_compiler_repro
