#include <cstdint>
#include <cstdlib>
#include <limits>

#include "c_api/asc_simd.h"
#include "simt_api/asc_fp16.h"
#include "simt_api/asc_simt.h"

namespace aten_softmax_v3 {
namespace persistent_512_detail {

template <typename T>
struct Add {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a + b;
  }
};

template <typename T>
struct Max {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a < b ? b : a;
  }
};

template <typename T, template <typename> class ReduceOp>
__simt_callee__ inline T warp_reduce(T value, int64_t width) {
  ReduceOp<T> reduce_op;
#pragma unroll
  for (int64_t offset = width / 2; offset > 0; offset /= 2) {
    const T peer = asc_shfl_xor(value, static_cast<int32_t>(offset), width);
    value = reduce_op(value, peer);
  }
  return value;
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kElements>
__simt_vf__ __launch_bounds__(512) inline void row_softmax_persistent_hybrid_vf(
    __ubuf__ outscalar_t* output_ub,
    __ubuf__ const scalar_t* input_ub,
    int64_t row_count,
    int64_t dim_size) {
  constexpr int64_t kBlockX = 32;
  constexpr int64_t kWarpSize = kElements < 32 ? kElements : 32;
  constexpr int64_t kWarpIterations = kElements / kWarpSize;
  const int64_t row_in_tile = threadIdx.x / kBlockX;
  const int64_t lane = threadIdx.x % kBlockX;
  if (row_in_tile >= row_count) {
    return;
  }

  const int64_t row_offset = row_in_tile * kElements;
  accscalar_t elements[kWarpIterations];

#pragma unroll
  for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
    const int64_t element_index = lane + iter * kWarpSize;
    if (element_index < dim_size) {
      elements[iter] = static_cast<accscalar_t>(input_ub[row_offset + element_index]);
    } else {
      elements[iter] = std::numeric_limits<accscalar_t>::lowest();
    }
  }

  accscalar_t max_value = elements[0];
#pragma unroll
  for (int64_t iter = 1; iter < kWarpIterations; ++iter) {
    max_value = Max<accscalar_t>()(max_value, elements[iter]);
  }
  max_value = warp_reduce<accscalar_t, Max>(max_value, kWarpSize);

  accscalar_t sum_value = 0;
#pragma unroll
  for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
    const int64_t element_index = lane + iter * kWarpSize;
    if (element_index < dim_size) {
      elements[iter] = __expf(elements[iter] - max_value);
      sum_value += elements[iter];
    } else {
      elements[iter] = 0;
    }
  }
  sum_value = warp_reduce<accscalar_t, Add>(sum_value, kWarpSize);

#pragma unroll
  for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
    const int64_t element_index = lane + iter * kWarpSize;
    if (element_index < dim_size) {
      output_ub[row_offset + element_index] =
          static_cast<outscalar_t>(elements[iter] / sum_value);
    }
  }
}

template <typename scalar_t>
__aicore__ inline __gm__ scalar_t* mutable_gm_ptr(__gm__ const scalar_t* ptr) {
  return const_cast<__gm__ scalar_t*>(ptr);
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kElements>
__aicore__ inline void row_softmax_persistent_hybrid_pipeline_impl(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  asc_init();
  constexpr int64_t kThreadsPerBlock = 512;
  constexpr int64_t kRowsPerTile = kThreadsPerBlock / 32;

  if (dim_size != kElements) {
    return;
  }

  __ubuf__ scalar_t input_tile_ub[2][kRowsPerTile * kElements];
  __ubuf__ outscalar_t output_tile_ub[2][kRowsPerTile * kElements];
  const int64_t tile_stride = gridDim.x * kRowsPerTile;
  const int64_t first_row_base = blockIdx.x * kRowsPerTile;
  const int64_t tile_count =
      first_row_base < outer_size
      ? ((outer_size - first_row_base) + tile_stride - 1) / tile_stride
      : 0;

  asc_sync_notify(PIPE_V, PIPE_MTE2, EVENT_ID0);
  asc_sync_notify(PIPE_V, PIPE_MTE2, EVENT_ID1);
  asc_sync_notify(PIPE_MTE3, PIPE_V, EVENT_ID0);
  asc_sync_notify(PIPE_MTE3, PIPE_V, EVENT_ID1);

  for (int64_t tile_idx = 0; tile_idx < tile_count; ++tile_idx) {
    const int32_t event_id = (tile_idx & 1) == 0 ? EVENT_ID0 : EVENT_ID1;
    const int64_t slot = tile_idx & 1;
    const int64_t row_base = first_row_base + tile_idx * tile_stride;
    const int64_t rows_remaining = outer_size - row_base;
    const int64_t row_count =
        rows_remaining >= kRowsPerTile ? kRowsPerTile : rows_remaining;
    const uint32_t tile_bytes =
        static_cast<uint32_t>(row_count * dim_size * sizeof(scalar_t));
    const uint32_t output_bytes =
        static_cast<uint32_t>(row_count * dim_size * sizeof(outscalar_t));

    asc_sync_wait(PIPE_V, PIPE_MTE2, event_id);
    asc_copy_gm2ub_align(
        input_tile_ub[slot],
        mutable_gm_ptr(input + row_base * dim_size),
        tile_bytes);
    asc_sync_notify(PIPE_MTE2, PIPE_V, event_id);
    asc_sync_wait(PIPE_MTE2, PIPE_V, event_id);

    asc_sync_wait(PIPE_MTE3, PIPE_V, event_id);
    asc_vf_call<row_softmax_persistent_hybrid_vf<
        scalar_t,
        accscalar_t,
        outscalar_t,
        kElements>>(
        dim3(kThreadsPerBlock),
        output_tile_ub[slot],
        input_tile_ub[slot],
        row_count,
        dim_size);
    asc_sync_notify(PIPE_V, PIPE_MTE2, event_id);

    asc_sync_notify(PIPE_V, PIPE_MTE3, event_id);
    asc_sync_wait(PIPE_V, PIPE_MTE3, event_id);
    asc_copy_ub2gm_align(
        output + row_base * dim_size,
        output_tile_ub[slot],
        output_bytes);
    asc_sync_notify(PIPE_MTE3, PIPE_V, event_id);
  }

  asc_sync_wait(PIPE_V, PIPE_MTE2, EVENT_ID0);
  asc_sync_wait(PIPE_V, PIPE_MTE2, EVENT_ID1);
  asc_sync_wait(PIPE_MTE3, PIPE_V, EVENT_ID0);
  asc_sync_wait(PIPE_MTE3, PIPE_V, EVENT_ID1);
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kElements>
__global__ __vector__ void row_softmax_persistent_hybrid_pipeline_kernel(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  row_softmax_persistent_hybrid_pipeline_impl<
      scalar_t,
      accscalar_t,
      outscalar_t,
      kElements>(output, input, outer_size, dim_size);
}

template <typename scalar_t, typename accscalar_t, typename outscalar_t>
void dispatch_row_persistent_forward_kernel_with_512_threads(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  switch (dim_size) {
    case 512:
      row_softmax_persistent_hybrid_pipeline_kernel<
          scalar_t,
          accscalar_t,
          outscalar_t,
          512>
          <<<grid_x,
             0,
             acl_stream>>>(
              output_ptr,
              input_ptr,
              outer_size,
              dim_size);
      break;
    default:
      std::abort();
  }
  (void)block_x;
  (void)block_y;
}

} // namespace persistent_512_detail

void dispatch_row_persistent_forward_kernel_512_fp16(
    const __fp16* input_ptr,
    __fp16* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  persistent_512_detail::dispatch_row_persistent_forward_kernel_with_512_threads<
      __fp16,
      float,
      __fp16>(
      input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
}

void dispatch_row_persistent_forward_kernel_512_fp32(
    const float* input_ptr,
    float* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  persistent_512_detail::dispatch_row_persistent_forward_kernel_with_512_threads<
      float,
      float,
      float>(
      input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
}

} // namespace aten_softmax_v3
