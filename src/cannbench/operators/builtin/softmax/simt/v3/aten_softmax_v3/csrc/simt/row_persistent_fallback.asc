#include <cstdint>
#include <limits>
#include <type_traits>

#include "simt_api/asc_fp16.h"
#include "simt_api/asc_simt.h"

namespace aten_softmax_v3 {

void dispatch_row_persistent_forward_kernel_1024_fp16(
    const __fp16* input_ptr,
    __fp16* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream);

void dispatch_row_persistent_forward_kernel_512_fp16(
    const __fp16* input_ptr,
    __fp16* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream);

void dispatch_row_persistent_forward_kernel_512_fp32(
    const float* input_ptr,
    float* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream);

void dispatch_row_persistent_forward_kernel_1024_fp32(
    const float* input_ptr,
    float* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream);

namespace {

template <typename T>
struct Add {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a + b;
  }
};

template <typename T>
struct Max {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a < b ? b : a;
  }
};

inline int64_t log2_ceil_int64(int64_t value) {
  int64_t log2_value = 0;
  while ((int64_t{1} << log2_value) < value) {
    ++log2_value;
  }
  return log2_value;
}

template <
    typename accscalar_t,
    int64_t kWarpBatch,
    int64_t kWarpSize,
    template <typename>
    class ReduceOp>
__simt_callee__ inline void persistent_warp_reduce(accscalar_t* values) {
  ReduceOp<accscalar_t> reduce_op;
#pragma unroll
  for (int64_t offset = kWarpSize / 2; offset > 0; offset /= 2) {
#pragma unroll
    for (int64_t i = 0; i < kWarpBatch; ++i) {
      const accscalar_t peer =
          asc_shfl_xor(values[i], static_cast<int32_t>(offset), kWarpSize);
      values[i] = reduce_op(values[i], peer);
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kLog2Elements,
    int64_t kThreadsPerBlock>
__simt_vf__ __launch_bounds__(kThreadsPerBlock) inline void
row_softmax_persistent_forward_vf(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  constexpr int64_t kNextPowerOfTwo = int64_t{1} << kLog2Elements;
  constexpr int64_t kWarpSize = kNextPowerOfTwo < 32 ? kNextPowerOfTwo : 32;
  constexpr int64_t kWarpIterations = kNextPowerOfTwo / kWarpSize;
  constexpr int64_t kWarpBatch = kNextPowerOfTwo <= 128 ? 2 : 1;

  for (int64_t row_base = (blockDim.y * blockIdx.x + threadIdx.y) * kWarpBatch;
       row_base < outer_size;
       row_base += gridDim.x * blockDim.y * kWarpBatch) {
    const int64_t local_idx = threadIdx.x;
    accscalar_t elements[kWarpBatch][kWarpIterations];

#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
      const int64_t row_offset = row * dim_size;
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (row < outer_size && element_index < dim_size) {
          elements[batch][iter] =
              static_cast<accscalar_t>(input[row_offset + element_index]);
        } else {
          elements[batch][iter] = std::numeric_limits<accscalar_t>::lowest();
        }
      }
    }

    accscalar_t max_values[kWarpBatch];
#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      max_values[batch] = elements[batch][0];
#pragma unroll
      for (int64_t iter = 1; iter < kWarpIterations; ++iter) {
        max_values[batch] =
            Max<accscalar_t>()(max_values[batch], elements[batch][iter]);
      }
    }
    persistent_warp_reduce<accscalar_t, kWarpBatch, kWarpSize, Max>(
        max_values);

    accscalar_t sums[kWarpBatch] = {0};
#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (row < outer_size && element_index < dim_size) {
          elements[batch][iter] =
              __expf(elements[batch][iter] - max_values[batch]);
          sums[batch] += elements[batch][iter];
        } else {
          elements[batch][iter] = 0;
        }
      }
    }
    persistent_warp_reduce<accscalar_t, kWarpBatch, kWarpSize, Add>(sums);

#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
      const int64_t row_offset = row * dim_size;
      if (row >= outer_size) {
        continue;
      }
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (element_index < dim_size) {
          output[row_offset + element_index] =
              static_cast<outscalar_t>(elements[batch][iter] / sums[batch]);
        }
      }
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kLog2Elements,
    int64_t kThreadsPerBlock>
__global__ __vector__ void row_softmax_persistent_forward_kernel(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y) {
  asc_vf_call<row_softmax_persistent_forward_vf<
      scalar_t,
      accscalar_t,
      outscalar_t,
      kLog2Elements,
      kThreadsPerBlock>>(
      dim3(block_x, block_y),
      output,
      input,
      outer_size,
      dim_size);
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kLog2Elements,
    int64_t kThreadsPerBlock>
void launch_row_persistent_forward_kernel(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  row_softmax_persistent_forward_kernel<
      scalar_t,
      accscalar_t,
      outscalar_t,
      kLog2Elements,
      kThreadsPerBlock>
      <<<grid_x, 0, acl_stream>>>(
          output_ptr,
          input_ptr,
          outer_size,
          dim_size,
          block_x,
          block_y);
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kThreadsPerBlock>
void dispatch_row_persistent_forward_kernel_with_threads(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  switch (log2_ceil_int64(dim_size)) {
    case 0:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 0, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 1:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 1, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 2:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 2, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 3:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 3, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 4:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 4, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 5:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 5, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 6:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 6, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 7:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 7, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 8:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 8, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 9:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 9, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 10:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 10, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    case 11:
      launch_row_persistent_forward_kernel<
          scalar_t, accscalar_t, outscalar_t, 11, kThreadsPerBlock>(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
      break;
    default:
      TORCH_CHECK(false, "persistent softmax supports dim_size <= 2048");
  }
}

template <typename scalar_t, typename accscalar_t, typename outscalar_t>
void dispatch_row_persistent_fallback_forward_kernel(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  if (dim_size == 1024) {
    if constexpr (
        std::is_same_v<scalar_t, __fp16> &&
        std::is_same_v<accscalar_t, float> &&
        std::is_same_v<outscalar_t, __fp16>) {
      dispatch_row_persistent_forward_kernel_1024_fp16(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
    } else if constexpr (
        std::is_same_v<scalar_t, float> &&
        std::is_same_v<accscalar_t, float> &&
        std::is_same_v<outscalar_t, float>) {
      dispatch_row_persistent_forward_kernel_1024_fp32(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
    } else {
      TORCH_CHECK(false, "unsupported 1024-thread persistent dtype combination");
    }
    return;
  }

  if (dim_size == 512) {
    if constexpr (
        std::is_same_v<scalar_t, __fp16> &&
        std::is_same_v<accscalar_t, float> &&
        std::is_same_v<outscalar_t, __fp16>) {
      dispatch_row_persistent_forward_kernel_512_fp16(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
    } else if constexpr (
        std::is_same_v<scalar_t, float> &&
        std::is_same_v<accscalar_t, float> &&
        std::is_same_v<outscalar_t, float>) {
      dispatch_row_persistent_forward_kernel_512_fp32(
          input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
    } else {
      TORCH_CHECK(false, "unsupported 512-thread persistent dtype combination");
    }
    return;
  }

  dispatch_row_persistent_forward_kernel_with_threads<
      scalar_t,
      accscalar_t,
      outscalar_t,
      1024>(
      input_ptr, output_ptr, outer_size, dim_size, block_x, block_y, grid_x, acl_stream);
}

} // namespace

void dispatch_row_persistent_forward_kernel(
    const __fp16* input_ptr,
    __fp16* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  dispatch_row_persistent_fallback_forward_kernel<__fp16, float, __fp16>(
      input_ptr,
      output_ptr,
      outer_size,
      dim_size,
      block_x,
      block_y,
      grid_x,
      acl_stream);
}

void dispatch_row_persistent_forward_kernel(
    const float* input_ptr,
    float* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream) {
  dispatch_row_persistent_fallback_forward_kernel<float, float, float>(
      input_ptr,
      output_ptr,
      outer_size,
      dim_size,
      block_x,
      block_y,
      grid_x,
      acl_stream);
}

} // namespace aten_softmax_v3
