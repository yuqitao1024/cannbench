#include <torch/all.h>

#include <cstdint>
#include <limits>

#include "acl/acl.h"
#include "simt_api/asc_fp16.h"
#include "simt_api/asc_simt.h"
#include "torch_npu/csrc/core/npu/NPUStream.h"
#include "torch_npu/csrc/framework/OpCommand.h"

#include "occupancy_common.h"

namespace aten_softmax_v3 {
namespace {

template <typename T>
struct Add {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a + b;
  }
};

template <typename T>
struct Max {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a < b ? b : a;
  }
};

template <typename T, template <typename> class ReduceOp>
__simt_callee__ inline T spatial_block_reduce_x(
    __ubuf__ T* shared,
    T val) {
  ReduceOp<T> reduce_op;
  shared += threadIdx.y * blockDim.x;

  __syncthreads();
  shared[threadIdx.x] = val;

  int offset = blockDim.x / 2;
  while (offset > 0) {
    __syncthreads();
    if (threadIdx.x < offset) {
      shared[threadIdx.x] = reduce_op(
          shared[threadIdx.x],
          shared[threadIdx.x + offset]);
    }
    offset /= 2;
  }

  __syncthreads();
  return shared[0];
}

template <typename scalar_t, typename accscalar_t, typename outscalar_t>
__simt_vf__ inline void cunn_spatial_softmax_forward_vf(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int64_t grid_x,
    int64_t grid_y,
    __ubuf__ uint32_t* dynamicStartUB) {
  const int64_t outer_stride = inner_size * dim_size;
  const int64_t dim_stride = inner_size;
  const int64_t block_index_x = blockIdx.x % grid_x;
  const int64_t block_index_y = blockIdx.x / grid_x;

  for (int64_t outer_index = block_index_x; outer_index < outer_size;
       outer_index += grid_x) {
    const int64_t outer_offset = outer_index * outer_stride;
    for (int64_t inner_index = block_index_y * blockDim.y + threadIdx.y;
         inner_index < inner_size;
         inner_index += blockDim.y * grid_y) {
      const int64_t data_offset = outer_offset + inner_index;

      if (blockDim.x > 1) {
        accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          const accscalar_t value = static_cast<accscalar_t>(
              input[data_offset + d * dim_stride]);
          max_input = Max<accscalar_t>()(max_input, value);
        }
        max_input = spatial_block_reduce_x<accscalar_t, Max>(
            (__ubuf__ accscalar_t*)dynamicStartUB,
            max_input);

        accscalar_t sum = 0;
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          sum += __expf(
              static_cast<accscalar_t>(input[data_offset + d * dim_stride]) -
              max_input);
        }
        sum = spatial_block_reduce_x<accscalar_t, Add>(
            (__ubuf__ accscalar_t*)dynamicStartUB,
            sum);

        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          output[data_offset + d * dim_stride] = static_cast<outscalar_t>(
              __expf(
                  static_cast<accscalar_t>(input[data_offset + d * dim_stride]) -
                  max_input) /
              sum);
        }
      } else {
        accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          const accscalar_t value = static_cast<accscalar_t>(
              input[data_offset + d * dim_stride]);
          max_input = Max<accscalar_t>()(max_input, value);
        }

        accscalar_t sum = 0;
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          sum += __expf(
              static_cast<accscalar_t>(input[data_offset + d * dim_stride]) -
              max_input);
        }

        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          output[data_offset + d * dim_stride] = static_cast<outscalar_t>(
              __expf(
                  static_cast<accscalar_t>(input[data_offset + d * dim_stride]) -
                  max_input) /
              sum);
        }
      }
    }
  }
}

template <typename scalar_t, typename accscalar_t, typename outscalar_t>
__global__ __vector__ void cunn_spatial_softmax_forward_kernel(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int64_t grid_x,
    int64_t grid_y,
    int64_t block_x,
    int64_t block_y) {
  extern __ubuf__ uint32_t dynamicStartUB[];
  asc_vf_call<cunn_spatial_softmax_forward_vf<scalar_t, accscalar_t, outscalar_t>>(
      dim3(block_x, block_y),
      output,
      input,
      outer_size,
      dim_size,
      inner_size,
      grid_x,
      grid_y,
      dynamicStartUB);
}

template <typename scalar_t, typename accscalar_t, typename outscalar_t>
void launch_spatial_forward_impl_typed(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int device) {
  const auto launch = simt::spatial_launch_config_impl(
      outer_size,
      dim_size,
      inner_size,
      static_cast<int64_t>(sizeof(accscalar_t)),
      device);

  const auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);
  auto acl_call = [=]() -> int {
    cunn_spatial_softmax_forward_kernel<scalar_t, accscalar_t, outscalar_t>
        <<<launch.grid_x * launch.grid_y,
           launch.dynamic_ubuf_bytes,
           acl_stream>>>(
            output_ptr,
            input_ptr,
            outer_size,
            dim_size,
            inner_size,
            launch.grid_x,
            launch.grid_y,
            launch.block_x,
            launch.block_y);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(
      "aten_softmax_v3::spatial_softmax_forward",
      acl_call);
}

} // namespace

void launch_spatial_forward_impl(
    const __fp16* input_ptr,
    __fp16* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int device) {
  launch_spatial_forward_impl_typed<__fp16, float, __fp16>(
      input_ptr,
      output_ptr,
      outer_size,
      dim_size,
      inner_size,
      device);
}

void launch_spatial_forward_impl(
    const float* input_ptr,
    float* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int device) {
  launch_spatial_forward_impl_typed<float, float, float>(
      input_ptr,
      output_ptr,
      outer_size,
      dim_size,
      inner_size,
      device);
}

} // namespace aten_softmax_v3
