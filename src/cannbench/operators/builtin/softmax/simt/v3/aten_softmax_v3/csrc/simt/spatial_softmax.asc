template <typename T, typename AccumT, typename OutT>
struct SpatialSoftMaxForwardEpilogue {
  __simt_callee__ inline SpatialSoftMaxForwardEpilogue(
      AccumT max_input,
      AccumT sum)
      : max_input(max_input), sum(sum) {}

  __simt_callee__ inline OutT operator()(T input) const {
    return static_cast<OutT>(__expf(static_cast<AccumT>(input) - max_input) / sum);
  }

  const AccumT max_input;
  const AccumT sum;
};

template <typename T>
struct Add {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a + b;
  }
};

template <typename T>
struct Max {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a < b ? b : a;
  }
};

template <typename T, template <typename> class ReduceOp>
__simt_callee__ inline T spatial_block_reduce_x(
    __ubuf__ T* shared,
    T val) {
  ReduceOp<T> reduce_op;
  shared += threadIdx.y * blockDim.x;

  __syncthreads();
  shared[threadIdx.x] = val;

  int offset = blockDim.x / 2;
  while (offset > 0) {
    __syncthreads();
    if (threadIdx.x < offset) {
      shared[threadIdx.x] = reduce_op(
          shared[threadIdx.x],
          shared[threadIdx.x + offset]);
    }
    offset /= 2;
  }

  __syncthreads();
  return shared[0];
}

template <typename T, template <typename> class ReduceOp>
__simt_callee__ inline T row_block_reduce(
    __ubuf__ T* shared,
    T val) {
  ReduceOp<T> reduce_op;

  __syncthreads();
  shared[threadIdx.x] = val;

  int offset = blockDim.x / 2;
  while (offset > 0) {
    __syncthreads();
    if (threadIdx.x < offset) {
      shared[threadIdx.x] = reduce_op(
          shared[threadIdx.x],
          shared[threadIdx.x + offset]);
    }
    offset /= 2;
  }

  __syncthreads();
  return shared[0];
}

inline int64_t log2_ceil_int64(int64_t value) {
  int64_t log2_value = 0;
  while ((int64_t{1} << log2_value) < value) {
    ++log2_value;
  }
  return log2_value;
}

template <
    typename accscalar_t,
    int64_t kWarpBatch,
    int64_t kWarpSize,
    template <typename>
    class ReduceOp>
__simt_callee__ inline void persistent_warp_reduce(accscalar_t* values) {
  ReduceOp<accscalar_t> reduce_op;
#pragma unroll
  for (int64_t offset = kWarpSize / 2; offset > 0; offset /= 2) {
#pragma unroll
    for (int64_t i = 0; i < kWarpBatch; ++i) {
      const accscalar_t peer =
          asc_shfl_xor(values[i], static_cast<int32_t>(offset), kWarpSize);
      values[i] = reduce_op(values[i], peer);
    }
  }
}

template <typename T>
__simt_callee__ inline T fast_warp_reduce_sum(T val) {
#pragma unroll
  for (int offset = 16; offset > 0; offset >>= 1) {
    val += asc_shfl_down(val, static_cast<uint32_t>(offset), 32);
  }
  return val;
}

template <typename T>
__simt_callee__ inline T fast_warp_reduce_max(T val) {
#pragma unroll
  for (int offset = 16; offset > 0; offset >>= 1) {
    val = Max<T>()(val, asc_shfl_down(val, static_cast<uint32_t>(offset), 32));
  }
  return val;
}

template <typename T, template <typename> class ReduceOp>
__simt_callee__ inline T fast_block_reduce_warp(
    __ubuf__ T* shared,
    T val,
    T identity) {
  const int64_t lane = threadIdx.x % 32;
  const int64_t warp = threadIdx.x / 32;
  if constexpr (std::is_same_v<ReduceOp<T>, Add<T>>) {
    val = fast_warp_reduce_sum(val);
  } else {
    val = fast_warp_reduce_max(val);
  }

  __syncthreads();
  if (lane == 0) {
    shared[warp] = val;
  }
  __syncthreads();

  T block_val = identity;
  if (warp == 0) {
    const int64_t warps_per_block = blockDim.x / 32;
    block_val = lane < warps_per_block ? shared[lane] : identity;
    if constexpr (std::is_same_v<ReduceOp<T>, Add<T>>) {
      block_val = fast_warp_reduce_sum(block_val);
    } else {
      block_val = fast_warp_reduce_max(block_val);
    }
    if (lane == 0) {
      shared[0] = block_val;
    }
  }
  __syncthreads();
  return shared[0];
}

template <typename T, template <typename> class ReduceOp>
__simt_callee__ inline T fast_block_reduce_warp_inverse(
    __ubuf__ T* shared,
    T val,
    T identity) {
  const T sum = fast_block_reduce_warp<T, ReduceOp>(shared, val, identity);
  if (threadIdx.x == 0) {
    shared[0] = static_cast<T>(1) / sum;
  }
  __syncthreads();
  return shared[0];
}

template <
    template <typename, typename>
    class Reduction,
    int64_t kILP,
    typename scalar_t,
    typename accscalar_t>
__simt_callee__ inline accscalar_t fast_ilp_reduce(
    __gm__ const scalar_t* data,
    int64_t size,
    const Reduction<scalar_t, accscalar_t>& reduction,
    accscalar_t identity) {
  accscalar_t thread_value = identity;
  for (int64_t offset = threadIdx.x * kILP; offset < size;
       offset += blockDim.x * kILP) {
#pragma unroll
    for (int64_t i = 0; i < kILP; ++i) {
      const int64_t element_offset = offset + i;
      if (element_offset < size) {
        thread_value = reduction(thread_value, data[element_offset]);
      }
    }
  }
  return thread_value;
}

template <
    int64_t kILP,
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t>
__simt_callee__ inline void fast_ilp_softmax_write(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t size,
    accscalar_t max_input,
    accscalar_t inv_sum) {
  for (int64_t offset = threadIdx.x * kILP; offset < size;
       offset += blockDim.x * kILP) {
#pragma unroll
    for (int64_t i = 0; i < kILP; ++i) {
      const int64_t element_offset = offset + i;
      if (element_offset < size) {
        output[element_offset] = static_cast<outscalar_t>(
            __expf(static_cast<accscalar_t>(input[element_offset]) - max_input) *
            inv_sum);
      }
    }
  }
}

template <
    template <typename, typename>
    class Reduction,
    typename accscalar_t>
__simt_callee__ inline accscalar_t fast_fp16x2_reduce(
    __gm__ const __fp16* data,
    int64_t size,
    int64_t shift,
    const Reduction<__fp16, accscalar_t>& reduction,
    accscalar_t identity) {
  accscalar_t thread_value = identity;
  if (shift != 0 && threadIdx.x == 0) {
    thread_value = reduction(thread_value, data[0]);
  }

  __gm__ const __fp16* aligned_data = data + shift;
  const int64_t aligned_size = size - shift;
  __gm__ const half2* vector_data = (__gm__ const half2*)aligned_data;
  const int64_t half2_size = aligned_size / 2;
  for (int64_t pair_offset = threadIdx.x; pair_offset < half2_size;
       pair_offset += blockDim.x) {
    const half2 pair = vector_data[pair_offset];
    thread_value = reduction(
        thread_value,
        static_cast<__fp16>(__low2float(pair)));
    thread_value = reduction(
        thread_value,
        static_cast<__fp16>(__high2float(pair)));
  }
  if ((aligned_size % 2) != 0 && threadIdx.x == 0) {
    thread_value = reduction(thread_value, data[size - 1]);
  }
  return thread_value;
}

template <
    template <typename, typename>
    class Reduction,
    typename accscalar_t>
__simt_callee__ inline accscalar_t fast_fp16x4_reduce(
    __gm__ const __fp16* data,
    int64_t size,
    const Reduction<__fp16, accscalar_t>& reduction,
    accscalar_t identity) {
  __gm__ const half2* vector_data = (__gm__ const half2*)data;
  const int64_t half2_size = size / 2;
  accscalar_t thread_value = identity;
  for (int64_t pair_offset = threadIdx.x * 2; pair_offset < half2_size;
       pair_offset += blockDim.x * 2) {
    const half2 first_pair = vector_data[pair_offset];
    thread_value = reduction(
        thread_value,
        static_cast<__fp16>(__low2float(first_pair)));
    thread_value = reduction(
        thread_value,
        static_cast<__fp16>(__high2float(first_pair)));

    const half2 second_pair = vector_data[pair_offset + 1];
    thread_value = reduction(
        thread_value,
        static_cast<__fp16>(__low2float(second_pair)));
    thread_value = reduction(
        thread_value,
        static_cast<__fp16>(__high2float(second_pair)));
  }
  return thread_value;
}

__simt_callee__ inline void fast_fp16x4_write(
    __gm__ __fp16* output,
    __gm__ const __fp16* input,
    int64_t size,
    float max_input,
    float inv_sum) {
  __gm__ const half2* vector_input = (__gm__ const half2*)input;
  __gm__ half2* vector_output = (__gm__ half2*)output;
  const int64_t half2_size = size / 2;
  for (int64_t pair_offset = threadIdx.x * 2; pair_offset < half2_size;
       pair_offset += blockDim.x * 2) {
    const half2 first_pair = vector_input[pair_offset];
    const float first_low =
        __expf(__low2float(first_pair) - max_input) * inv_sum;
    const float first_high =
        __expf(__high2float(first_pair) - max_input) * inv_sum;
    vector_output[pair_offset] =
        __floats2half2_rn(first_low, first_high);

    const half2 second_pair = vector_input[pair_offset + 1];
    const float second_low =
        __expf(__low2float(second_pair) - max_input) * inv_sum;
    const float second_high =
        __expf(__high2float(second_pair) - max_input) * inv_sum;
    vector_output[pair_offset + 1] =
        __floats2half2_rn(second_low, second_high);
  }
}

__simt_callee__ inline void fast_fp16x2_write(
    __gm__ __fp16* output,
    __gm__ const __fp16* input,
    int64_t size,
    int64_t shift,
    float max_input,
    float inv_sum) {
  if (shift != 0 && threadIdx.x == 0) {
    output[0] = static_cast<__fp16>(
        __expf(static_cast<float>(input[0]) - max_input) * inv_sum);
  }

  __gm__ const __fp16* aligned_input = input + shift;
  __gm__ __fp16* aligned_output = output + shift;
  const int64_t aligned_size = size - shift;
  __gm__ const half2* vector_input = (__gm__ const half2*)aligned_input;
  __gm__ half2* vector_output = (__gm__ half2*)aligned_output;
  const int64_t half2_size = aligned_size / 2;
  for (int64_t pair_offset = threadIdx.x; pair_offset < half2_size;
       pair_offset += blockDim.x) {
    const half2 pair = vector_input[pair_offset];
    const float low = __expf(__low2float(pair) - max_input) * inv_sum;
    const float high = __expf(__high2float(pair) - max_input) * inv_sum;
    vector_output[pair_offset] = __floats2half2_rn(low, high);
  }
  if ((aligned_size % 2) != 0 && threadIdx.x == 0) {
    output[size - 1] = static_cast<__fp16>(
        __expf(static_cast<float>(input[size - 1]) - max_input) * inv_sum);
  }
}

template<typename T, typename AccumT>
struct MaxFloat {
  __simt_callee__ inline AccumT operator()(AccumT current, T value) const {
    return Max<AccumT>()(current, static_cast<AccumT>(value));
  }
};

template<typename T, typename AccumT>
struct SumExpfFloat {
  __simt_callee__ inline SumExpfFloat(AccumT max_value) : max_value(max_value) {}

  __simt_callee__ inline AccumT operator()(AccumT current, T value) const {
    return current + __expf(static_cast<AccumT>(value) - max_value);
  }

  const AccumT max_value;
};

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__simt_vf__ inline void row_softmax_forward_vf(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    __ubuf__ uint32_t* dynamicStartUB) {
  auto shared = (__ubuf__ accscalar_t*)dynamicStartUB;

  for (int64_t row = blockIdx.x; row < outer_size; row += gridDim.x) {
    const int64_t row_offset = row * dim_size;

    accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      const accscalar_t value =
          static_cast<accscalar_t>(input[row_offset + d]);
      max_input = Max<accscalar_t>()(max_input, value);
    }
    max_input = row_block_reduce<accscalar_t, Max>(shared, max_input);

    accscalar_t sum = 0;
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      sum += __expf(
          static_cast<accscalar_t>(input[row_offset + d]) - max_input);
    }
    sum = row_block_reduce<accscalar_t, Add>(shared, sum);

    Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
    for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
      output[row_offset + d] = epilogue(input[row_offset + d]);
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kLog2Elements,
    int64_t kThreadsPerBlock,
    template <typename, typename, typename>
    class Epilogue>
__simt_vf__ __launch_bounds__(kThreadsPerBlock) inline void row_softmax_persistent_forward_vf(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  constexpr int64_t kNextPowerOfTwo = int64_t{1} << kLog2Elements;
  constexpr int64_t kWarpSize =
      kNextPowerOfTwo < 32 ? kNextPowerOfTwo : 32;
  constexpr int64_t kWarpIterations = kNextPowerOfTwo / kWarpSize;
  constexpr int64_t kWarpBatch = kNextPowerOfTwo <= 128 ? 2 : 1;

  for (int64_t row_base = (blockDim.y * blockIdx.x + threadIdx.y) * kWarpBatch;
       row_base < outer_size;
       row_base += gridDim.x * blockDim.y * kWarpBatch) {
    const int64_t local_idx = threadIdx.x;
    accscalar_t elements[kWarpBatch][kWarpIterations];

#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
      const int64_t row_offset = row * dim_size;
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (row < outer_size && element_index < dim_size) {
          elements[batch][iter] =
              static_cast<accscalar_t>(input[row_offset + element_index]);
        } else {
          elements[batch][iter] =
              std::numeric_limits<accscalar_t>::lowest();
        }
      }
    }

    accscalar_t max_values[kWarpBatch];
#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      max_values[batch] = elements[batch][0];
#pragma unroll
      for (int64_t iter = 1; iter < kWarpIterations; ++iter) {
        max_values[batch] =
            Max<accscalar_t>()(max_values[batch], elements[batch][iter]);
      }
    }
    persistent_warp_reduce<accscalar_t, kWarpBatch, kWarpSize, Max>(
        max_values);

    accscalar_t sums[kWarpBatch] = {0};
#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (row < outer_size && element_index < dim_size) {
          elements[batch][iter] =
              __expf(elements[batch][iter] - max_values[batch]);
          sums[batch] += elements[batch][iter];
        } else {
          elements[batch][iter] = 0;
        }
      }
    }
    persistent_warp_reduce<accscalar_t, kWarpBatch, kWarpSize, Add>(sums);

#pragma unroll
    for (int64_t batch = 0; batch < kWarpBatch; ++batch) {
      const int64_t row = row_base + batch;
      const int64_t row_offset = row * dim_size;
      if (row >= outer_size) {
        continue;
      }
#pragma unroll
      for (int64_t iter = 0; iter < kWarpIterations; ++iter) {
        const int64_t element_index = local_idx + iter * kWarpSize;
        if (element_index < dim_size) {
          output[row_offset + element_index] =
              static_cast<outscalar_t>(elements[batch][iter] / sums[batch]);
        }
      }
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__simt_vf__ __launch_bounds__(1024) inline void row_softmax_fast_forward_vf(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    __ubuf__ uint32_t* dynamicStartUB) {
  auto shared = (__ubuf__ accscalar_t*)dynamicStartUB;

  for (int64_t row = blockIdx.x; row < outer_size; row += gridDim.x) {
    __gm__ const scalar_t* row_input = input + row * dim_size;
    __gm__ outscalar_t* row_output = output + row * dim_size;
    constexpr int64_t kFastILP = 4;
    const bool use_fp16x4 =
        std::is_same_v<scalar_t, __fp16> &&
        std::is_same_v<outscalar_t, __fp16> &&
        dim_size % 4 == 0;
    const bool use_fp16x2 =
        std::is_same_v<scalar_t, __fp16> &&
        std::is_same_v<outscalar_t, __fp16> &&
        dim_size >= 2;
    const int64_t fp16x2_shift = (row * dim_size) % 2;

    accscalar_t thread_max = std::numeric_limits<accscalar_t>::lowest();
    if constexpr (
        std::is_same_v<scalar_t, __fp16> &&
        std::is_same_v<outscalar_t, __fp16>) {
      if (use_fp16x4) {
        thread_max = fast_fp16x4_reduce<MaxFloat, accscalar_t>(
            row_input,
            dim_size,
            MaxFloat<__fp16, accscalar_t>(),
            std::numeric_limits<accscalar_t>::lowest());
      } else if (use_fp16x2) {
        thread_max = fast_fp16x2_reduce<MaxFloat, accscalar_t>(
            row_input,
            dim_size,
            fp16x2_shift,
            MaxFloat<__fp16, accscalar_t>(),
            std::numeric_limits<accscalar_t>::lowest());
      } else {
        thread_max = fast_ilp_reduce<
            MaxFloat,
            kFastILP,
            scalar_t,
            accscalar_t>(
            row_input,
            dim_size,
            MaxFloat<scalar_t, accscalar_t>(),
            std::numeric_limits<accscalar_t>::lowest());
      }
    } else {
      thread_max = fast_ilp_reduce<
          MaxFloat,
          kFastILP,
          scalar_t,
          accscalar_t>(
          row_input,
          dim_size,
          MaxFloat<scalar_t, accscalar_t>(),
          std::numeric_limits<accscalar_t>::lowest());
    }
    const accscalar_t max_input = fast_block_reduce_warp<accscalar_t, Max>(
        shared,
        thread_max,
        std::numeric_limits<accscalar_t>::lowest());

    accscalar_t thread_exp = static_cast<accscalar_t>(0);
    if constexpr (
        std::is_same_v<scalar_t, __fp16> &&
        std::is_same_v<outscalar_t, __fp16>) {
      if (use_fp16x4) {
        thread_exp = fast_fp16x4_reduce<SumExpfFloat, accscalar_t>(
            row_input,
            dim_size,
            SumExpfFloat<__fp16, accscalar_t>(max_input),
            static_cast<accscalar_t>(0));
      } else if (use_fp16x2) {
        thread_exp = fast_fp16x2_reduce<SumExpfFloat, accscalar_t>(
            row_input,
            dim_size,
            fp16x2_shift,
            SumExpfFloat<__fp16, accscalar_t>(max_input),
            static_cast<accscalar_t>(0));
      } else {
        thread_exp = fast_ilp_reduce<
            SumExpfFloat,
            kFastILP,
            scalar_t,
            accscalar_t>(
            row_input,
            dim_size,
            SumExpfFloat<scalar_t, accscalar_t>(max_input),
            static_cast<accscalar_t>(0));
      }
    } else {
      thread_exp = fast_ilp_reduce<
          SumExpfFloat,
          kFastILP,
          scalar_t,
          accscalar_t>(
          row_input,
          dim_size,
          SumExpfFloat<scalar_t, accscalar_t>(max_input),
          static_cast<accscalar_t>(0));
    }
    const accscalar_t inv_sum = fast_block_reduce_warp_inverse<accscalar_t, Add>(
        shared,
        thread_exp,
        static_cast<accscalar_t>(0));

    if constexpr (
        std::is_same_v<scalar_t, __fp16> &&
        std::is_same_v<outscalar_t, __fp16>) {
      if (use_fp16x4) {
        fast_fp16x4_write(
            row_output,
            row_input,
            dim_size,
            max_input,
            inv_sum);
      } else if (use_fp16x2) {
        fast_fp16x2_write(
            row_output,
            row_input,
            dim_size,
            fp16x2_shift,
            max_input,
            inv_sum);
      } else {
        fast_ilp_softmax_write<
            kFastILP,
            scalar_t,
            accscalar_t,
            outscalar_t>(
            row_output,
            row_input,
            dim_size,
            max_input,
            inv_sum);
      }
    } else {
      fast_ilp_softmax_write<
          kFastILP,
          scalar_t,
          accscalar_t,
          outscalar_t>(
          row_output,
          row_input,
          dim_size,
          max_input,
          inv_sum);
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kRegCount,
    template <typename, typename, typename>
    class Epilogue>
__simt_vf__ __launch_bounds__(1024) inline void row_softmax_fast_reg_forward_vf(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    __ubuf__ uint32_t* dynamicStartUB) {
  auto shared = (__ubuf__ accscalar_t*)dynamicStartUB;

  for (int64_t row = blockIdx.x; row < outer_size; row += gridDim.x) {
    __gm__ const scalar_t* row_input = input + row * dim_size;
    __gm__ outscalar_t* row_output = output + row * dim_size;
    scalar_t elements[kRegCount];

    accscalar_t thread_max = std::numeric_limits<accscalar_t>::lowest();
#pragma unroll
    for (int64_t reg_idx = 0; reg_idx < kRegCount; ++reg_idx) {
      const int64_t offset = threadIdx.x + reg_idx * blockDim.x;
      if (offset < dim_size) {
        elements[reg_idx] = row_input[offset];
        thread_max = Max<accscalar_t>()(
            thread_max,
            static_cast<accscalar_t>(elements[reg_idx]));
      }
    }
    const accscalar_t max_input = fast_block_reduce_warp<accscalar_t, Max>(
        shared,
        thread_max,
        std::numeric_limits<accscalar_t>::lowest());

    accscalar_t thread_exp = static_cast<accscalar_t>(0);
#pragma unroll
    for (int64_t reg_idx = 0; reg_idx < kRegCount; ++reg_idx) {
      const int64_t offset = threadIdx.x + reg_idx * blockDim.x;
      if (offset < dim_size) {
        thread_exp += __expf(
            static_cast<accscalar_t>(elements[reg_idx]) - max_input);
      }
    }
    const accscalar_t sum = fast_block_reduce_warp<accscalar_t, Add>(
        shared,
        thread_exp,
        static_cast<accscalar_t>(0));

    Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
#pragma unroll
    for (int64_t reg_idx = 0; reg_idx < kRegCount; ++reg_idx) {
      const int64_t offset = threadIdx.x + reg_idx * blockDim.x;
      if (offset < dim_size) {
        row_output[offset] = epilogue(elements[reg_idx]);
      }
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__simt_vf__ inline void row_softmax_generic_forward_vf(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size) {
  // Generic row-wise softmax is intentionally left unimplemented. Current
  // realistic fp16/fp32 shapes are covered by persistent, fast, or spatial
  // paths, and this fallback has not been accuracy-verified on Ascend SIMT.
  (void)output;
  (void)input;
  (void)outer_size;
  (void)dim_size;
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__simt_vf__ inline void cunn_spatial_softmax_forward_vf(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int64_t grid_x,
    int64_t grid_y,
    __ubuf__ uint32_t* dynamicStartUB) {
  const int64_t outer_stride = inner_size * dim_size;
  const int64_t dim_stride = inner_size;
  const int64_t block_index_x = blockIdx.x % grid_x;
  const int64_t block_index_y = blockIdx.x / grid_x;

  for (int64_t outer_index = block_index_x; outer_index < outer_size;
       outer_index += grid_x) {
    const int64_t outer_offset = outer_index * outer_stride;
    for (int64_t inner_index = block_index_y * blockDim.y + threadIdx.y;
         inner_index < inner_size;
         inner_index += blockDim.y * grid_y) {
      const int64_t data_offset = outer_offset + inner_index;

      if (blockDim.x > 1) {
        accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          const accscalar_t value = static_cast<accscalar_t>(
              input[data_offset + d * dim_stride]);
          max_input = Max<accscalar_t>()(max_input, value);
        }
        max_input = spatial_block_reduce_x<accscalar_t, Max>(
            (__ubuf__ accscalar_t*)dynamicStartUB,
            max_input);

        accscalar_t sum = 0;
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          sum += __expf(
              static_cast<accscalar_t>(input[data_offset + d * dim_stride]) -
              max_input);
        }
        sum = spatial_block_reduce_x<accscalar_t, Add>(
            (__ubuf__ accscalar_t*)dynamicStartUB,
            sum);

        Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          output[data_offset + d * dim_stride] =
              epilogue(input[data_offset + d * dim_stride]);
        }
      } else {
        accscalar_t max_input = std::numeric_limits<accscalar_t>::lowest();
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          const accscalar_t value = static_cast<accscalar_t>(
              input[data_offset + d * dim_stride]);
          max_input = Max<accscalar_t>()(max_input, value);
        }

        accscalar_t sum = 0;
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          sum += __expf(
              static_cast<accscalar_t>(input[data_offset + d * dim_stride]) -
              max_input);
        }

        Epilogue<scalar_t, accscalar_t, outscalar_t> epilogue(max_input, sum);
        for (int64_t d = threadIdx.x; d < dim_size; d += blockDim.x) {
          output[data_offset + d * dim_stride] =
              epilogue(input[data_offset + d * dim_stride]);
        }
      }
    }
  }
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    template <typename, typename, typename>
    class Epilogue>
__global__ __vector__ void row_softmax_forward_kernel(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y) {
  extern __ubuf__ uint32_t dynamicStartUB[];
  asc_vf_call<row_softmax_forward_vf<scalar_t, accscalar_t, outscalar_t, Epilogue>>(
      dim3(block_x, block_y),
      output,
      input,
      outer_size,
      dim_size,
      dynamicStartUB);
}

template <
    typename scalar_t,
    typename accscalar_t,
    typename outscalar_t,
    int64_t kLog2Elements,
    int64_t kThreadsPerBlock,
    template <typename, typename, typename>
    class Epilogue>
__global__ __vector__ void row_softmax_persistent_forward_kernel(
    __gm__ outscalar_t* output,
    __gm__ const scalar_t* input,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y) {
  asc_vf_call<row_softmax_persistent_forward_vf<
      scalar_t,
      accscalar_t,
      outscalar_t,
      kLog2Elements,
      kThreadsPerBlock,
      Epilogue>>(
      dim3(block_x, block_y),
      output,
      input,
      outer_size,
      dim_size);
}

