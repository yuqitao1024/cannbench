namespace aten_softmax_v3 {

void dispatch_row_persistent_forward_kernel(
    const __fp16* input_ptr,
    __fp16* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream);

void dispatch_row_persistent_forward_kernel(
    const float* input_ptr,
    float* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    void* acl_stream);

void dispatch_row_fast_forward_kernel(
    const __fp16* input_ptr,
    __fp16* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    int64_t dynamic_ubuf_bytes,
    void* acl_stream);

void dispatch_row_fast_forward_kernel(
    const float* input_ptr,
    float* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t block_x,
    int64_t block_y,
    int64_t grid_x,
    int64_t dynamic_ubuf_bytes,
    void* acl_stream);

void launch_spatial_forward_impl(
    const __fp16* input_ptr,
    __fp16* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int device);

void launch_spatial_forward_impl(
    const float* input_ptr,
    float* output_ptr,
    int64_t outer_size,
    int64_t dim_size,
    int64_t inner_size,
    int device);

namespace {

inline int64_t log2_ceil_int64(int64_t value) {
  int64_t log2_value = 0;
  while ((int64_t{1} << log2_value) < value) {
    ++log2_value;
  }
  return log2_value;
}

enum class RowSoftmaxPath {
  PersistentLike,
  FastLike,
  GenericLike,
};

inline bool use_persistent_like_row_softmax(
    int64_t dim_size,
    int64_t scalar_size) {
  return dim_size <= 2048 && dim_size * scalar_size <= 8192;
}

inline bool use_fast_like_row_softmax(int64_t dim_size) {
  return dim_size > 2048;
}

inline RowSoftmaxPath row_softmax_path(
    int64_t dim_size,
    int64_t scalar_size) {
  if (use_persistent_like_row_softmax(dim_size, scalar_size)) {
    return RowSoftmaxPath::PersistentLike;
  }
  if (use_fast_like_row_softmax(dim_size)) {
    return RowSoftmaxPath::FastLike;
  }
  return RowSoftmaxPath::GenericLike;
}

inline int64_t row_softmax_persistent_block_x(int64_t dim_size) {
  constexpr int64_t kCudaWarpLaneLimit = 32;
  int64_t block_x = 1;
  const int64_t target = std::min(dim_size, kCudaWarpLaneLimit);
  while (block_x < target) {
    block_x *= 2;
  }
  return block_x;
}

inline int64_t row_softmax_persistent_threads_per_block(int64_t dim_size) {
  if (dim_size == 512) {
    return 512;
  }
  if (dim_size == 1024) {
    return 256;
  }
  return 1024;
}

inline int64_t row_softmax_persistent_block_y(
    int64_t block_x,
    int64_t dim_size) {
  const int64_t threads_per_block =
      row_softmax_persistent_threads_per_block(dim_size);
  return std::max<int64_t>(1, threads_per_block / block_x);
}

inline int64_t row_softmax_fast_block_x() {
  constexpr int64_t kCudaFastPathThreads = 1024;
  return kCudaFastPathThreads;
}

inline int64_t row_softmax_fast_ubuf_bytes(int64_t accscalar_size) {
  constexpr int64_t kCudaWarpLaneLimit = 32;
  return (row_softmax_fast_block_x() / kCudaWarpLaneLimit) * accscalar_size;
}

inline int64_t row_softmax_generic_block_x(int64_t dim_size) {
  constexpr int64_t kCudaWarpLaneLimit = 32;
  return std::min<int64_t>(row_softmax_persistent_block_x(dim_size), kCudaWarpLaneLimit);
}

inline int64_t row_softmax_generic_block_y() {
  constexpr int64_t kCudaGenericMaxThreads = 1024;
  constexpr int64_t kCudaWarpLaneLimit = 32;
  return kCudaGenericMaxThreads / kCudaWarpLaneLimit;
}

inline int64_t row_softmax_block_x(
    int64_t dim_size,
    RowSoftmaxPath path) {
  switch (path) {
    case RowSoftmaxPath::PersistentLike:
      return row_softmax_persistent_block_x(dim_size);
    case RowSoftmaxPath::FastLike:
      return row_softmax_fast_block_x();
    case RowSoftmaxPath::GenericLike:
      return row_softmax_generic_block_x(dim_size);
  }
  return row_softmax_persistent_block_x(dim_size);
}

inline int64_t row_softmax_grid_x(int64_t outer_size) {
  constexpr int64_t kRowSoftmaxGridXLimit = 32768;
  return std::min<int64_t>(outer_size, kRowSoftmaxGridXLimit);
}

inline int64_t row_softmax_persistent_grid_x(
    int64_t outer_size,
    int64_t block_y,
    int64_t warp_batch,
    int64_t dim_size) {
  constexpr int64_t kRowSoftmaxPhysicalGridXLimit = 64;
  constexpr int64_t kRowSoftmaxGridXLimit = 32768;
  const int64_t rows_per_block = block_y * warp_batch;
  const int64_t row_blocks = (outer_size + rows_per_block - 1) / rows_per_block;
  const int64_t grid_limit =
      dim_size <= 256 || dim_size == 512 || dim_size == 1024
      ? kRowSoftmaxPhysicalGridXLimit
      : kRowSoftmaxGridXLimit;
  return std::min<int64_t>(row_blocks, grid_limit);
}

inline const char* row_softmax_api_name(RowSoftmaxPath path) {
  switch (path) {
    case RowSoftmaxPath::PersistentLike:
      return "aten_softmax_v3::row_softmax_persistent_forward";
    case RowSoftmaxPath::FastLike:
      return "aten_softmax_v3::row_softmax_fast_forward";
    case RowSoftmaxPath::GenericLike:
      return "aten_softmax_v3::row_softmax_generic_forward";
  }
  return "aten_softmax_v3::row_softmax_persistent_forward";
}

inline int64_t row_softmax_persistent_warp_batch(int64_t dim_size) {
  const int64_t log2_elements = log2_ceil_int64(dim_size);
  const int64_t next_power_of_two = int64_t{1} << log2_elements;
  return next_power_of_two <= 128 ? 2 : 1;
}

template <typename scalar_t, typename accscalar_t, typename outscalar_t>
void launch_row_forward_impl(
    const scalar_t* input_ptr,
    outscalar_t* output_ptr,
    int64_t outer_size,
    int64_t dim_size) {
  const RowSoftmaxPath path = row_softmax_path(
      dim_size,
      static_cast<int64_t>(sizeof(scalar_t)));
  const int64_t block_x = row_softmax_block_x(dim_size, path);
  const int64_t block_y = path == RowSoftmaxPath::PersistentLike
      ? row_softmax_persistent_block_y(block_x, dim_size)
      : path == RowSoftmaxPath::FastLike
      ? 1
      : path == RowSoftmaxPath::GenericLike ? row_softmax_generic_block_y() : 1;
  const int64_t warp_batch = path == RowSoftmaxPath::PersistentLike
      ? row_softmax_persistent_warp_batch(dim_size)
      : 1;
  const int64_t grid_x = path == RowSoftmaxPath::PersistentLike
      ? row_softmax_persistent_grid_x(outer_size, block_y, warp_batch, dim_size)
      : path == RowSoftmaxPath::FastLike || path == RowSoftmaxPath::GenericLike
      ? row_softmax_grid_x(outer_size)
      : row_softmax_grid_x(outer_size);
  const int64_t dynamic_ubuf_bytes = path == RowSoftmaxPath::PersistentLike
      ? 0
      : path == RowSoftmaxPath::FastLike
      ? row_softmax_fast_ubuf_bytes(static_cast<int64_t>(sizeof(accscalar_t)))
      : block_x * block_y * sizeof(accscalar_t);
  const char* api_name = row_softmax_api_name(path);

  if (path == RowSoftmaxPath::GenericLike) {
    TORCH_CHECK(
        false,
        "generic row-wise softmax is not implemented or accuracy-verified");
  }

  const auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);
  auto acl_call = [=]() -> int {
    if (path == RowSoftmaxPath::PersistentLike) {
      dispatch_row_persistent_forward_kernel(
          input_ptr,
          output_ptr,
          outer_size,
          dim_size,
          block_x,
          block_y,
          grid_x,
          acl_stream);
    } else {
      dispatch_row_fast_forward_kernel(
          input_ptr,
          output_ptr,
          outer_size,
          dim_size,
          block_x,
          block_y,
          grid_x,
          dynamic_ubuf_bytes,
          acl_stream);
    }
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(api_name, acl_call);
}

at::Tensor spatial_forward_common(
    const at::Tensor& input,
    int64_t dim,
    bool half_to_float) {
  TORCH_CHECK(
      input.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU tensor");
  TORCH_CHECK(input.dim() > 0, "softmax input must have at least one dimension");

  const auto wrapped_dim = at::maybe_wrap_dim(dim, input.dim());
  auto in_tensor = input.contiguous();

  int64_t outer_size = 1;
  for (int64_t d = 0; d < wrapped_dim; ++d) {
    outer_size *= in_tensor.size(d);
  }

  const int64_t dim_size = in_tensor.size(wrapped_dim);
  int64_t inner_size = 1;
  for (int64_t d = wrapped_dim + 1; d < in_tensor.dim(); ++d) {
    inner_size *= in_tensor.size(d);
  }

  TORCH_CHECK(
      inner_size >= 1,
      "spatial softmax path requires inner_size >= 1, got ",
      inner_size);

  if (in_tensor.numel() == 0) {
    if (half_to_float) {
      TORCH_CHECK(
          in_tensor.scalar_type() == at::ScalarType::Half,
          "half_to_float is supported for Half type only");
      return at::empty(
          in_tensor.sizes(), in_tensor.options().dtype(at::kFloat));
    }
    return at::empty_like(in_tensor);
  }

  if (half_to_float) {
    TORCH_CHECK(
        in_tensor.scalar_type() == at::ScalarType::Half,
        "half_to_float is supported for Half type only");
    auto compute_input = in_tensor.to(at::kFloat);
    auto output = at::empty(
        compute_input.sizes(), compute_input.options().dtype(at::kFloat));
    if (inner_size == 1) {
      launch_row_forward_impl<float, float, float>(
          compute_input.const_data_ptr<float>(),
          output.mutable_data_ptr<float>(),
          outer_size,
          dim_size);
    } else {
      launch_spatial_forward_impl(
          compute_input.const_data_ptr<float>(),
          output.mutable_data_ptr<float>(),
          outer_size,
          dim_size,
          inner_size,
          compute_input.get_device());
    }
    return output;
  }

  TORCH_CHECK(
      in_tensor.scalar_type() != at::ScalarType::Double,
      "double device path is not supported in the current SIMT spatial prototype");
  auto output = at::empty_like(in_tensor);
  if (in_tensor.scalar_type() == at::ScalarType::Half) {
    if (inner_size == 1) {
      launch_row_forward_impl<__fp16, float, __fp16>(
          reinterpret_cast<const __fp16*>(in_tensor.const_data_ptr<at::Half>()),
          reinterpret_cast<__fp16*>(output.mutable_data_ptr<at::Half>()),
          outer_size,
          dim_size);
    } else {
      launch_spatial_forward_impl(
          reinterpret_cast<const __fp16*>(in_tensor.const_data_ptr<at::Half>()),
          reinterpret_cast<__fp16*>(output.mutable_data_ptr<at::Half>()),
          outer_size,
          dim_size,
          inner_size,
          in_tensor.get_device());
    }
  } else if (in_tensor.scalar_type() == at::ScalarType::Float) {
    if (inner_size == 1) {
      launch_row_forward_impl<float, float, float>(
          in_tensor.const_data_ptr<float>(),
          output.mutable_data_ptr<float>(),
          outer_size,
          dim_size);
    } else {
      launch_spatial_forward_impl(
          in_tensor.const_data_ptr<float>(),
          output.mutable_data_ptr<float>(),
          outer_size,
          dim_size,
          inner_size,
          in_tensor.get_device());
    }
  } else {
    TORCH_CHECK(
        false,
        "SIMT spatial softmax supports float16 and float32 in the no-cast path, got ",
        in_tensor.scalar_type());
  }
  return output;
}

bool should_use_spatial_softmax_path(const at::Tensor& tensor, int64_t dim) {
  if (tensor.dim() <= 0) {
    return false;
  }

  const auto wrapped_dim = at::maybe_wrap_dim(dim, tensor.dim());
  int64_t inner_size = 1;
  for (int64_t d = wrapped_dim + 1; d < tensor.dim(); ++d) {
    inner_size *= tensor.size(d);
  }
  return inner_size >= 1;
}

at::Tensor spatial_softmax_forward_privateuse1(
    const at::Tensor& input,
    int64_t dim,
    bool half_to_float) {
  return spatial_forward_common(
      input,
      dim,
      half_to_float);
}

at::Tensor softmax_int_privateuse1(
    const at::Tensor& self,
    int64_t dim,
    std::optional<c10::ScalarType> dtype) {
  const bool half_to_float =
      self.scalar_type() == at::ScalarType::Half &&
      dtype == at::ScalarType::Float;
  auto converted = dtype.has_value() && !half_to_float
      ? self.toType(dtype.value())
      : self;

  if (should_use_spatial_softmax_path(converted, dim)) {
    return spatial_softmax_forward_privateuse1(converted, dim, half_to_float);
  }
  return at::_softmax(converted, dim, half_to_float);
}

} // namespace

TORCH_LIBRARY_FRAGMENT(aten_softmax_v3, m) {
  m.def(
      "spatial_softmax_forward(Tensor input, int dim, bool half_to_float=False) -> Tensor");
}

TORCH_LIBRARY_IMPL(aten_softmax_v3, PrivateUse1, m) {
  m.impl("spatial_softmax_forward", &spatial_softmax_forward_privateuse1);
}

TORCH_LIBRARY_IMPL(aten, PrivateUse1, m) {
  m.impl(
      TORCH_SELECTIVE_NAME("aten::softmax.int"),
      TORCH_FN(softmax_int_privateuse1));
}

} // namespace aten_softmax_v3
