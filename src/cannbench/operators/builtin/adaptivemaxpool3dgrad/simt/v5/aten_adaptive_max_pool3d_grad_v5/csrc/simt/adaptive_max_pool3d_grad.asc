extern "C" void launch_adaptive_max_pool3d_grad_v5_bfloat16(
    const bfloat16_t* grad_output,
    const int32_t* indices,
    bfloat16_t* grad_input,
    int64_t n_dim,
    int64_t c_dim,
    int64_t in_d,
    int64_t in_h,
    int64_t in_w,
    int64_t out_d,
    int64_t out_h,
    int64_t out_w,
    bool is_overlap,
    bool deterministic,
    int64_t zero_block_num,
    int64_t grad_block_num,
    aclrtStream stream) {
  launch_adaptive_max_pool3d_grad_v5<bfloat16_t>(
      grad_output,
      indices,
      grad_input,
      n_dim,
      c_dim,
      in_d,
      in_h,
      in_w,
      out_d,
      out_h,
      out_w,
      is_overlap,
      deterministic,
      zero_block_num,
      grad_block_num,
      stream);
}
