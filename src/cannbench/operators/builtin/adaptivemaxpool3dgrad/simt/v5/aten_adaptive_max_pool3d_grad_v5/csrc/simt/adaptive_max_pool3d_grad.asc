#include <cstdint>

#include "acl/acl.h"
#include "simt_api/asc_bf16.h"
#include "simt_api/asc_fp16.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr uint32_t THREAD_DIM = 512;

uint32_t grid_for_blocks(int64_t block_num) {
  if (block_num < 1) {
    return 1;
  }
  return static_cast<uint32_t>(block_num);
}

template <typename scalar_t, bool deterministic>
__global__ __launch_bounds__(THREAD_DIM) void adaptive_max_pool3d_grad_v5_scatter_kernel(
    const scalar_t* grad_output,
    const int32_t* indices,
    scalar_t* grad_input,
    int64_t n_dim,
    int64_t c_dim,
    int64_t in_d,
    int64_t in_h,
    int64_t in_w,
    int64_t out_d,
    int64_t out_h,
    int64_t out_w,
    bool is_overlap) {
  const uint64_t total_nc = static_cast<uint64_t>(n_dim) * static_cast<uint64_t>(c_dim);
  const uint64_t input_spatial =
      static_cast<uint64_t>(in_d) * static_cast<uint64_t>(in_h) * static_cast<uint64_t>(in_w);
  const uint64_t output_spatial =
      static_cast<uint64_t>(out_d) * static_cast<uint64_t>(out_h) * static_cast<uint64_t>(out_w);
  const uint64_t output_numel = total_nc * output_spatial;
  const uint64_t thread_start =
      static_cast<uint64_t>(blockIdx.x) * blockDim.x + static_cast<uint64_t>(threadIdx.x);
  const uint64_t thread_stride =
      static_cast<uint64_t>(gridDim.x) * static_cast<uint64_t>(blockDim.x);

  if constexpr (deterministic) {
    for (uint64_t nc_index = thread_start; nc_index < total_nc; nc_index += thread_stride) {
      const uint64_t input_base = nc_index * input_spatial;
      const uint64_t output_base = nc_index * output_spatial;
      for (uint64_t spatial_out = 0; spatial_out < output_spatial; ++spatial_out) {
        const int32_t max_index = indices[output_base + spatial_out];
        if (max_index < 0 || static_cast<uint64_t>(max_index) >= input_spatial) {
          continue;
        }
        const uint64_t input_offset = input_base + static_cast<uint64_t>(max_index);
        grad_input[input_offset] += grad_output[output_base + spatial_out];
      }
    }
  } else {
    for (uint64_t output_index = thread_start; output_index < output_numel; output_index += thread_stride) {
      const uint64_t nc_index = output_index / output_spatial;
      const int32_t max_index = indices[output_index];
      if (max_index < 0 || static_cast<uint64_t>(max_index) >= input_spatial) {
        continue;
      }
      const uint64_t input_offset = nc_index * input_spatial + static_cast<uint64_t>(max_index);
      const scalar_t grad_value = grad_output[output_index];
      if (is_overlap) {
        asc_atomic_add(&grad_input[input_offset], grad_value);
      } else {
        grad_input[input_offset] += grad_value;
      }
    }
  }
}

template <typename scalar_t>
__global__ __launch_bounds__(THREAD_DIM) void adaptive_max_pool3d_grad_v5_zero_kernel(
    scalar_t* grad_input,
    int64_t input_numel) {
  for (uint64_t index = static_cast<uint64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
       index < static_cast<uint64_t>(input_numel);
       index += static_cast<uint64_t>(gridDim.x) * blockDim.x) {
    grad_input[index] = static_cast<scalar_t>(0);
  }
}

template <typename scalar_t>
void launch_adaptive_max_pool3d_grad_v5(
    const scalar_t* grad_output,
    const int32_t* indices,
    scalar_t* grad_input,
    int64_t n_dim,
    int64_t c_dim,
    int64_t in_d,
    int64_t in_h,
    int64_t in_w,
    int64_t out_d,
    int64_t out_h,
    int64_t out_w,
    bool is_overlap,
    bool deterministic,
    int64_t zero_block_num,
    int64_t grad_block_num,
    aclrtStream stream) {
  const int64_t input_numel = n_dim * c_dim * in_d * in_h * in_w;
  adaptive_max_pool3d_grad_v5_zero_kernel<scalar_t>
      <<<grid_for_blocks(zero_block_num), THREAD_DIM, 0, stream>>>(
          grad_input, input_numel);

  if (deterministic) {
    adaptive_max_pool3d_grad_v5_scatter_kernel<scalar_t, true>
        <<<grid_for_blocks(grad_block_num), THREAD_DIM, 0, stream>>>(
            grad_output,
            indices,
            grad_input,
            n_dim,
            c_dim,
            in_d,
            in_h,
            in_w,
            out_d,
            out_h,
            out_w,
            is_overlap);
  } else {
    adaptive_max_pool3d_grad_v5_scatter_kernel<scalar_t, false>
        <<<grid_for_blocks(grad_block_num), THREAD_DIM, 0, stream>>>(
            grad_output,
            indices,
            grad_input,
            n_dim,
            c_dim,
            in_d,
            in_h,
            in_w,
            out_d,
            out_h,
            out_w,
            is_overlap);
  }
}

} // namespace

extern "C" void launch_adaptive_max_pool3d_grad_v5_float(
    const float* grad_output,
    const int32_t* indices,
    float* grad_input,
    int64_t n_dim,
    int64_t c_dim,
    int64_t in_d,
    int64_t in_h,
    int64_t in_w,
    int64_t out_d,
    int64_t out_h,
    int64_t out_w,
    bool is_overlap,
    bool deterministic,
    int64_t zero_block_num,
    int64_t grad_block_num,
    aclrtStream stream) {
  launch_adaptive_max_pool3d_grad_v5<float>(
      grad_output,
      indices,
      grad_input,
      n_dim,
      c_dim,
      in_d,
      in_h,
      in_w,
      out_d,
      out_h,
      out_w,
      is_overlap,
      deterministic,
      zero_block_num,
      grad_block_num,
      stream);
}

