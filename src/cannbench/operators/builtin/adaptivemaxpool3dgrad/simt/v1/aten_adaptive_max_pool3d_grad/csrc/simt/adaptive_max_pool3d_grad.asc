#include <cstdint>

#include "acl/acl.h"
#include "simt_api/asc_fp16.h"
#include "simt_api/asc_simt.h"

namespace {

template <typename scalar_t>
__global__ __launch_bounds__(1024) void adaptive_max_pool3d_grad_kernel(
    const scalar_t* grad_output,
    const int32_t* indices,
    scalar_t* grad_input,
    int32_t output_numel,
    int32_t output_spatial,
    int32_t input_spatial) {
  for (int32_t out_offset = blockIdx.x * blockDim.x + threadIdx.x;
       out_offset < output_numel;
       out_offset += gridDim.x * blockDim.x) {
    const int32_t slice_index = out_offset / output_spatial;
    const int32_t spatial_index = indices[out_offset];
    if (spatial_index < 0 || spatial_index >= input_spatial) {
      continue;
    }
    const int32_t input_offset = slice_index * input_spatial + spatial_index;
    asc_atomic_add(&grad_input[input_offset], grad_output[out_offset]);
  }
}

uint32_t grid_for_numel(int64_t numel) {
  constexpr uint32_t threads_per_block = 1024;
  constexpr uint32_t max_blocks = 64;
  uint32_t blocks =
      static_cast<uint32_t>((numel + threads_per_block - 1) / threads_per_block);
  if (blocks > max_blocks) {
    blocks = max_blocks;
  }
  if (blocks < 1) {
    blocks = 1;
  }
  return blocks;
}

} // namespace

extern "C" void launch_adaptive_max_pool3d_grad_float(
    const float* grad_output,
    const int32_t* indices,
    float* grad_input,
    int64_t output_numel,
    int64_t output_spatial,
    int64_t input_spatial,
    aclrtStream stream) {
  constexpr uint32_t threads_per_block = 1024;
  adaptive_max_pool3d_grad_kernel<float>
      <<<grid_for_numel(output_numel), threads_per_block, 0, stream>>>(
          grad_output,
          indices,
          grad_input,
          static_cast<int32_t>(output_numel),
          static_cast<int32_t>(output_spatial),
          static_cast<int32_t>(input_spatial));
}

extern "C" void launch_adaptive_max_pool3d_grad_half(
    const half* grad_output,
    const int32_t* indices,
    half* grad_input,
    int64_t output_numel,
    int64_t output_spatial,
    int64_t input_spatial,
    aclrtStream stream) {
  constexpr uint32_t threads_per_block = 1024;
  adaptive_max_pool3d_grad_kernel<half>
      <<<grid_for_numel(output_numel), threads_per_block, 0, stream>>>(
          grad_output,
          indices,
          grad_input,
          static_cast<int32_t>(output_numel),
          static_cast<int32_t>(output_spatial),
          static_cast<int32_t>(input_spatial));
}
