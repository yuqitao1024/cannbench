#include <cstdint>
#include <cstdlib>
#include <iomanip>
#include <iostream>
#include <vector>

#include "acl/acl.h"
#include "simt_api/asc_bf16.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kDeviceId = 0;
constexpr uint32_t kElementCount = 1;
constexpr uint32_t kGridX = 1;
constexpr uint32_t kBlockX = 1;
constexpr uint32_t kBlockY = 1;
constexpr uint16_t kBfloatOneBits = 0x3F80U;

#define CHECK_ACL(expr)                                                                                 \
    do {                                                                                                \
        aclError ret = (expr);                                                                          \
        if (ret != ACL_SUCCESS) {                                                                       \
            std::cerr << "ACL call failed: " #expr ", ret=" << static_cast<int32_t>(ret) << std::endl; \
            std::exit(1);                                                                               \
        }                                                                                               \
    } while (0)

__simt_vf__ inline void copy_bfloat16_vf(
    __gm__ const bfloat16_t* input, __gm__ bfloat16_t* output, int64_t element_count)
{
    if (threadIdx.x != 0 || blockIdx.x != 0 || element_count < 1) {
        return;
    }
    output[0] = input[0];
}

__global__ __vector__ void copy_bfloat16_kernel(
    __gm__ const bfloat16_t* input,
    __gm__ bfloat16_t* output,
    int64_t element_count,
    int64_t block_x,
    int64_t block_y)
{
    asc_vf_call<copy_bfloat16_vf>(dim3(block_x, block_y), input, output, element_count);
}

void launch_copy_bfloat16(
    const bfloat16_t* input, bfloat16_t* output, int64_t element_count, aclrtStream stream)
{
    copy_bfloat16_kernel<<<kGridX, 0, stream>>>(input, output, element_count, kBlockX, kBlockY);
}

} // namespace

int main()
{
    const size_t bytes = kElementCount * sizeof(uint16_t);
    std::vector<uint16_t> input_host(kElementCount, kBfloatOneBits);
    std::vector<uint16_t> output_host(kElementCount, 0);

    bfloat16_t* input_device = nullptr;
    bfloat16_t* output_device = nullptr;
    aclrtStream stream = nullptr;

    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(kDeviceId));
    CHECK_ACL(aclrtCreateStream(&stream));
    CHECK_ACL(aclrtMalloc(reinterpret_cast<void**>(&input_device), bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc(reinterpret_cast<void**>(&output_device), bytes, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(input_device, bytes, input_host.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(output_device, bytes, output_host.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE));

    launch_copy_bfloat16(input_device, output_device, static_cast<int64_t>(kElementCount), stream);

    aclError sync_ret = aclrtSynchronizeStream(stream);
    CHECK_ACL(aclrtMemcpy(output_host.data(), bytes, output_device, bytes, ACL_MEMCPY_DEVICE_TO_HOST));

    std::cout << "[INFO] mode=bf16_vf_repro" << std::endl;
    std::cout << "[INFO] aclrtSynchronizeStream ret=" << static_cast<int32_t>(sync_ret) << std::endl;
    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        std::cout << "[INFO] aclGetRecentErrMsg=" << err << std::endl;
    }
    std::cout << "[INFO] output_bits=0x" << std::hex << std::setw(4) << std::setfill('0')
              << output_host[0] << std::dec << std::endl;

    if (output_device != nullptr) {
        CHECK_ACL(aclrtFree(output_device));
    }
    if (input_device != nullptr) {
        CHECK_ACL(aclrtFree(input_device));
    }
    if (stream != nullptr) {
        CHECK_ACL(aclrtDestroyStream(stream));
    }
    CHECK_ACL(aclrtResetDevice(kDeviceId));
    CHECK_ACL(aclFinalize());

    return (sync_ret == ACL_SUCCESS && output_host[0] == kBfloatOneBits) ? 0 : 1;
}
