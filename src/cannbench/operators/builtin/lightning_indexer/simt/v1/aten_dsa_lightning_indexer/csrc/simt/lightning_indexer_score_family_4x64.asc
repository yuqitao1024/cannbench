#include <cstdint>

#include "acl/acl.h"
#include "basic_api/kernel_basic_intf.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "tensor_api/tensor.h"

namespace {

using namespace AscendC::Te;

constexpr int32_t kHeadCount = 4;
constexpr int32_t kHeadDim = 64;
constexpr int32_t kBaseN = 128;

struct LightningIndexerScore4x64Shape {
  int32_t used_core_num;
  int32_t m;
  int32_t n;
  int32_t k;
};

struct LightningIndexerScore4x64MmadTrait {
  using TraitType = MmadTrait;
  static constexpr const TraitType value =
      MmadTrait(0, false, false, false, MmadType::NORMAL);
};

__aicore__ inline void copy_shape(
    LightningIndexerScore4x64Shape* shape,
    __gm__ uint8_t* tiling_gm) {
  auto dst = reinterpret_cast<uint32_t*>(shape);
  auto src = reinterpret_cast<__gm__ uint32_t*>(tiling_gm);
  for (uint32_t i = 0; i < sizeof(LightningIndexerScore4x64Shape) / sizeof(uint32_t); ++i) {
    dst[i] = src[i];
  }
}

__global__ __cube__ void lightning_indexer_score_family_4x64_kernel(
    __gm__ half* query,
    __gm__ half* keys,
    __gm__ float* scores,
    __gm__ uint8_t* tiling_gm) {
  AscendC::InitSocState();

  LightningIndexerScore4x64Shape shape;
  copy_shape(&shape, tiling_gm);
  if (AscendC::GetBlockIdx() >= static_cast<uint32_t>(shape.used_core_num)) {
    return;
  }

  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);

  auto gm_query = MakeTensor(
      MakeMemPtr(query), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.k));
  auto gm_keys = MakeTensor(
      MakeMemPtr(keys), MakeFrameLayout<DNExtLayoutPtn>(shape.k, shape.n));
  auto gm_scores = MakeTensor(
      MakeMemPtr(scores), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.n));

  __cbuf__ half l1_query_buf[kHeadCount * kHeadDim];
  __cbuf__ half l1_keys_buf[kHeadDim * kBaseN];
  __ca__ half l0_query_buf[kHeadCount * kHeadDim];
  __cb__ half l0_keys_buf[kHeadDim * kBaseN];
  __cc__ float l0_scores_buf[16 * kBaseN];

  auto copy_gm_to_l1 = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
  auto copy_l1_to_l0a = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
  auto copy_l1_to_l0b = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
  auto copy_l0c_to_gm = MakeCopy(CopyL0C2GM{}, CopyL0C2GMTraitDefault{});
  auto mmad = MakeMmad(MmadOperation{}, LightningIndexerScore4x64MmadTrait{});

  auto l1_query_nd = MakeTensor(
      MakeMemPtr(l1_query_buf), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.k));
  auto l1_query_nz = MakeTensor(
      l1_query_nd.Data(),
      MakeFrameLayout<NZLayoutPtn, half>(
          shape.k / C0_ELEMENT<half>,
          shape.m,
          C0_ELEMENT<half>));
  auto l0_query = MakeTensor(
      MakeMemPtr(l0_query_buf),
      MakeFrameLayout<NZLayoutPtn, half>(
          shape.k / C0_ELEMENT<half>,
          shape.m,
          C0_ELEMENT<half>));

  Copy(copy_gm_to_l1, l1_query_nd, gm_query);
  AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
  AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
  Copy(copy_l1_to_l0a, l0_query, l1_query_nz);
  AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

  for (uint32_t n_index = 0; n_index < n_loop; ++n_index) {
    const uint16_t cur_n = static_cast<uint16_t>(
        n_index + 1 == n_loop ? shape.n - static_cast<int32_t>(n_index) * kBaseN : kBaseN);

    auto l1_keys = MakeTensor(
        MakeMemPtr(l1_keys_buf), MakeFrameLayout<ZNLayoutPtn, half>(shape.k, cur_n));
    auto l0_keys = MakeTensor(
        MakeMemPtr(l0_keys_buf), MakeFrameLayout<ZNLayoutPtn, half>(shape.k, cur_n));
    auto l0_scores = MakeTensor(
        MakeMemPtr(l0_scores_buf), MakeFrameLayout<NZLayoutPtn>(shape.m, cur_n));
    auto gm_key_tile = gm_keys.Slice(
        MakeCoord(0, static_cast<int32_t>(n_index) * kBaseN),
        MakeShape(shape.k, cur_n));
    auto gm_score_tile = gm_scores.Slice(
        MakeCoord(0, static_cast<int32_t>(n_index) * kBaseN),
        MakeShape(shape.m, cur_n));

    AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
    Copy(copy_gm_to_l1, l1_keys, gm_key_tile);
    AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
    Copy(copy_l1_to_l0b, l0_keys, l1_keys);
    AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

    MmadParams params{
        static_cast<uint16_t>(shape.m),
        cur_n,
        static_cast<uint16_t>(shape.k),
        0,
        true,
    };
    Mmad(mmad.with(params), l0_scores, l0_query, l0_keys);

    AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
    Copy(copy_l0c_to_gm, gm_score_tile, l0_scores);
    AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  }

  AscendC::PipeBarrier<PIPE_ALL>();
}

} // namespace

extern "C" void launch_lightning_indexer_score_4x64_float(
    const half* query,
    const half* keys,
    float* scores,
    uint8_t* tiling,
    int64_t batch_size,
    int64_t query_count,
    int64_t context_count,
    aclrtStream stream) {
  const int64_t total_rows = batch_size * query_count;
  const int64_t query_stride = kHeadCount * kHeadDim;
  const int64_t key_batch_stride = context_count * kHeadDim;
  const int64_t scores_stride = kHeadCount * context_count;
  LightningIndexerScore4x64Shape shape = {
      1,
      1,
      static_cast<int32_t>(context_count),
      kHeadDim,
  };
  aclrtMemcpyAsync(
      tiling,
      sizeof(shape),
      &shape,
      sizeof(shape),
      ACL_MEMCPY_HOST_TO_DEVICE,
      stream);
  for (int64_t row_index = 0; row_index < total_rows; ++row_index) {
    const int64_t batch_index = row_index / query_count;
    for (int64_t head_index = 0; head_index < kHeadCount; ++head_index) {
      // TODO: Restore the original m=4 score launch after fixing the multi-row
      // score layout path. The current per-head launch is a correctness-first
      // fallback aligned with the 64x128 host strategy.
      lightning_indexer_score_family_4x64_kernel<<<shape.used_core_num, 0, stream>>>(
          const_cast<half*>(query) + row_index * query_stride + head_index * kHeadDim,
          const_cast<half*>(keys) + batch_index * key_batch_stride,
          scores + row_index * scores_stride + head_index * context_count,
          tiling);
    }
  }
}
