#include <cstdint>
#include <limits>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kFamily64x128HeadCount = 64;
constexpr int32_t kTopKUpperBound = 1024;

__SIMT_DEVICE_FUNCTIONS_DECL__ inline float relu_float(float value) {
  return value > 0.0F ? value : 0.0F;
}

__global__ void lightning_indexer_postprocess_family_64x128_kernel(
    const float* scores,
    const float* weights,
    float* topk_scores,
    int32_t* topk_indices,
    int32_t batch_size,
    int32_t query_count,
    int32_t context_count,
    int32_t top_k,
    int32_t context_start) {
  if (threadIdx.x != 0) {
    return;
  }

  for (int32_t linear_index = blockIdx.x; linear_index < batch_size * query_count;
       linear_index += gridDim.x) {
    const int32_t batch_index = linear_index / query_count;
    const int32_t query_index = linear_index % query_count;

    const int64_t weight_base =
        (static_cast<int64_t>(batch_index) * query_count + query_index) *
        kFamily64x128HeadCount;
    const int64_t topk_base =
        (static_cast<int64_t>(batch_index) * query_count + query_index) * top_k;
    const int64_t score_base =
        ((static_cast<int64_t>(batch_index) * query_count + query_index) *
         kFamily64x128HeadCount) *
        context_count;

    for (int32_t context_index = 0; context_index < context_count; ++context_index) {
      float reduced_score = 0.0F;
      for (int32_t head_index = 0; head_index < kFamily64x128HeadCount; ++head_index) {
        const int64_t score_offset =
            score_base +
            static_cast<int64_t>(head_index) * context_count + context_index;
        reduced_score +=
            relu_float(scores[score_offset]) * weights[weight_base + head_index];
      }

      int32_t insert_at = top_k;
      for (int32_t rank = 0; rank < top_k; ++rank) {
        if (reduced_score > topk_scores[topk_base + rank]) {
          insert_at = rank;
          break;
        }
      }

      if (insert_at < top_k) {
        for (int32_t rank = top_k - 1; rank > insert_at; --rank) {
          topk_scores[topk_base + rank] = topk_scores[topk_base + rank - 1];
          topk_indices[topk_base + rank] = topk_indices[topk_base + rank - 1];
        }
        topk_scores[topk_base + insert_at] = reduced_score;
        topk_indices[topk_base + insert_at] = context_start + context_index;
      }
    }
  }
}

} // namespace

extern "C" void launch_lightning_indexer_prefill_family_64x128_postprocess_float(
    const float* scores,
    const float* weights,
    float* topk_scores,
    int32_t* topk_indices,
    int64_t batch_size,
    int64_t query_count,
    int64_t context_count,
    int64_t top_k,
    int64_t context_start,
    aclrtStream stream) {
  constexpr uint32_t kThreadsPerBlock = 1;
  constexpr uint32_t kMaxBlocks = 256;

  uint32_t blocks_per_grid = static_cast<uint32_t>(batch_size * query_count);
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }

  lightning_indexer_postprocess_family_64x128_kernel
      <<<blocks_per_grid, kThreadsPerBlock, 0, stream>>>(
          scores,
          weights,
          topk_scores,
          topk_indices,
          static_cast<int32_t>(batch_size),
          static_cast<int32_t>(query_count),
          static_cast<int32_t>(context_count),
          static_cast<int32_t>(top_k),
          static_cast<int32_t>(context_start));
}
