#include <c10/core/ScalarType.h>
#include <torch/library.h>

#include <algorithm>
#include <limits>
#include <string_view>
#include <vector>

#include "acl/acl.h"
#include "torch_npu/csrc/core/npu/NPUCachingAllocator.h"
#include "torch_npu/csrc/core/npu/NPUStream.h"

namespace aten_dsa_lightning_indexer {
namespace {

constexpr int64_t kFamily4x64QueryTile = 32;
constexpr int64_t kFamily4x64ContextTile = 128;
constexpr int64_t kFamily64x128QueryTile = 4;
constexpr int64_t kFamily64x128ContextTile = 128;

extern "C" void launch_lightning_indexer_fused_family_4x64_float(
    const at::BFloat16* query,
    const at::BFloat16* keys,
    const at::BFloat16* weights,
    float* topk_scores,
    int32_t* output,
    int64_t batch_size,
    int64_t query_count,
    int64_t context_count,
    int64_t top_k,
    int64_t context_start,
    aclrtStream stream);

extern "C" void launch_lightning_indexer_fused_family_64x128_float(
    const at::BFloat16* query,
    const at::BFloat16* keys,
    const at::BFloat16* weights,
    float* topk_scores,
    int32_t* output,
    int64_t batch_size,
    int64_t query_count,
    int64_t context_count,
    int64_t top_k,
    int64_t context_start,
    aclrtStream stream);

inline void record_tensor_on_stream(
    const at::Tensor& tensor,
    c10_npu::NPUStream stream) {
  if (!tensor.defined()) {
    return;
  }
  const auto& data_ptr = tensor.storage().data_ptr();
  if (data_ptr.get() == nullptr) {
    return;
  }
  c10_npu::NPUCachingAllocator::recordStream(data_ptr, stream);
}

void run_lightning_indexer_family_4x64_tile(
    const at::Tensor& query_tile,
    const at::Tensor& key_tile,
    const at::Tensor& weights_tile,
    at::Tensor& best_scores_tile,
    at::Tensor& best_indices_tile,
    int64_t batch_size,
    int64_t current_query,
    int64_t current_context,
    int64_t top_k,
    int64_t context_start) {
  const auto npu_stream = c10_npu::getCurrentNPUStream();
  // Submit queued tensor initialization/copies before the raw ACL launch.
  const auto acl_stream = npu_stream.stream(true);
  launch_lightning_indexer_fused_family_4x64_float(
      query_tile.const_data_ptr<at::BFloat16>(),
      key_tile.const_data_ptr<at::BFloat16>(),
      weights_tile.const_data_ptr<at::BFloat16>(),
      best_scores_tile.mutable_data_ptr<float>(),
      best_indices_tile.mutable_data_ptr<int32_t>(),
      batch_size,
      current_query,
      current_context,
      top_k,
      context_start,
      acl_stream);
  record_tensor_on_stream(key_tile, npu_stream);
}

void run_lightning_indexer_family_64x128_tile(
    const at::Tensor& query_tile,
    const at::Tensor& key_tile,
    const at::Tensor& weights_tile,
    at::Tensor& best_scores_tile,
    at::Tensor& best_indices_tile,
    int64_t batch_size,
    int64_t current_query,
    int64_t current_context,
    int64_t top_k,
    int64_t context_start) {
  const auto npu_stream = c10_npu::getCurrentNPUStream();
  // Submit queued tensor initialization/copies before the raw ACL launch.
  const auto acl_stream = npu_stream.stream(true);
  launch_lightning_indexer_fused_family_64x128_float(
      query_tile.const_data_ptr<at::BFloat16>(),
      key_tile.const_data_ptr<at::BFloat16>(),
      weights_tile.const_data_ptr<at::BFloat16>(),
      best_scores_tile.mutable_data_ptr<float>(),
      best_indices_tile.mutable_data_ptr<int32_t>(),
      batch_size,
      current_query,
      current_context,
      top_k,
      context_start,
      acl_stream);
  record_tensor_on_stream(key_tile, npu_stream);
}

at::Tensor lightning_indexer_forward_family_4x64_score_tiled_float(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& weights,
    int64_t top_k) {
  const auto batch_size = query.size(0);
  const auto query_count = query.size(1);
  const auto context_count = keys.size(1);

  const auto npu_stream = c10_npu::getCurrentNPUStream();
  // Raw launches are async, so retain every base-storage tile until completion.
  std::vector<at::Tensor> retained_score_tiles;
  std::vector<at::Tensor> best_index_tiles;
  const auto query_tile_count =
      (query_count + kFamily4x64QueryTile - 1) / kFamily4x64QueryTile;
  retained_score_tiles.reserve(query_tile_count);
  best_index_tiles.reserve(query_tile_count);

  for (int64_t query_start = 0; query_start < query_count;
       query_start += kFamily4x64QueryTile) {
    const auto current_query =
        std::min<int64_t>(kFamily4x64QueryTile, query_count - query_start);
    auto query_tile = query.narrow(1, query_start, current_query).contiguous();
    auto weights_tile = weights.narrow(1, query_start, current_query).contiguous();
    auto best_scores_tile = at::full(
        {batch_size, current_query, top_k},
        -std::numeric_limits<float>::infinity(),
        query.options().dtype(c10::kFloat));
    auto best_indices_tile = at::zeros(
        {batch_size, current_query, top_k},
        query.options().dtype(c10::kInt));

    for (int64_t context_start = 0; context_start < context_count;
         context_start += kFamily4x64ContextTile) {
      const auto current_context = std::min<int64_t>(
          kFamily4x64ContextTile, context_count - context_start);
      auto key_tile = keys.narrow(1, context_start, current_context).contiguous();
      run_lightning_indexer_family_4x64_tile(
          query_tile,
          key_tile,
          weights_tile,
          best_scores_tile,
          best_indices_tile,
          batch_size,
          current_query,
          current_context,
          top_k,
          context_start);
    }
    record_tensor_on_stream(query_tile, npu_stream);
    record_tensor_on_stream(weights_tile, npu_stream);
    record_tensor_on_stream(best_scores_tile, npu_stream);
    record_tensor_on_stream(best_indices_tile, npu_stream);
    retained_score_tiles.push_back(best_scores_tile);
    best_index_tiles.push_back(best_indices_tile);
  }
  if (best_index_tiles.size() == 1) {
    return best_index_tiles.front();
  }
  // TODO: Remove this host sync when raw ACL launches can participate in the
  // torch_npu task queue's stream-ordered dependency tracking.
  TORCH_CHECK(
      aclrtSynchronizeStream(npu_stream.stream(true)) == ACL_SUCCESS,
      "failed to synchronize lightning_indexer family_4x64 stream");
  return at::cat(best_index_tiles, 1);
}

at::Tensor lightning_indexer_forward_prefill_family_4x64_float(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& weights,
    int64_t top_k) {
  return lightning_indexer_forward_family_4x64_score_tiled_float(
      query, keys, weights, top_k);
}

at::Tensor lightning_indexer_forward_decode_family_64x128_float(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& weights,
    int64_t top_k) {
  const auto batch_size = query.size(0);
  const auto query_count = query.size(1);
  const auto context_count = keys.size(1);

  const auto npu_stream = c10_npu::getCurrentNPUStream();
  // Raw launches are async, so retain every base-storage tile until completion.
  std::vector<at::Tensor> retained_score_tiles;
  std::vector<at::Tensor> best_index_tiles;
  const auto query_tile_count =
      (query_count + kFamily64x128QueryTile - 1) / kFamily64x128QueryTile;
  retained_score_tiles.reserve(query_tile_count);
  best_index_tiles.reserve(query_tile_count);

  for (int64_t query_start = 0; query_start < query_count;
       query_start += kFamily64x128QueryTile) {
    const auto current_query =
        std::min<int64_t>(kFamily64x128QueryTile, query_count - query_start);
    auto query_tile = query.narrow(1, query_start, current_query).contiguous();
    auto weights_tile = weights.narrow(1, query_start, current_query).contiguous();
    auto best_scores_tile = at::full(
        {batch_size, current_query, top_k},
        -std::numeric_limits<float>::infinity(),
        query.options().dtype(c10::kFloat));
    auto best_indices_tile = at::zeros(
        {batch_size, current_query, top_k},
        query.options().dtype(c10::kInt));

    for (int64_t context_start = 0; context_start < context_count;
         context_start += kFamily64x128ContextTile) {
      const auto current_context = std::min<int64_t>(
          kFamily64x128ContextTile, context_count - context_start);
      auto key_tile = keys.narrow(1, context_start, current_context).contiguous();
      run_lightning_indexer_family_64x128_tile(
          query_tile,
          key_tile,
          weights_tile,
          best_scores_tile,
          best_indices_tile,
          batch_size,
          current_query,
          current_context,
          top_k,
          context_start);
    }
    record_tensor_on_stream(query_tile, npu_stream);
    record_tensor_on_stream(weights_tile, npu_stream);
    record_tensor_on_stream(best_scores_tile, npu_stream);
    record_tensor_on_stream(best_indices_tile, npu_stream);
    retained_score_tiles.push_back(best_scores_tile);
    best_index_tiles.push_back(best_indices_tile);
  }
  if (best_index_tiles.size() == 1) {
    return best_index_tiles.front();
  }
  // TODO: Remove this host sync when raw ACL launches can participate in the
  // torch_npu task queue's stream-ordered dependency tracking.
  TORCH_CHECK(
      aclrtSynchronizeStream(npu_stream.stream(true)) == ACL_SUCCESS,
      "failed to synchronize lightning_indexer family_64x128 stream");
  return at::cat(best_index_tiles, 1);
}

at::Tensor lightning_indexer_forward_prefill_family_64x128_float(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& weights,
    int64_t top_k) {
  return lightning_indexer_forward_decode_family_64x128_float(
      query, keys, weights, top_k);
}

at::Tensor lightning_indexer_forward_decode_family_4x64_float(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& weights,
    int64_t top_k) {
  return lightning_indexer_forward_family_4x64_score_tiled_float(
      query, keys, weights, top_k);
}

at::Tensor lightning_indexer_forward_privateuse1(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& weights,
    int64_t top_k,
    std::string_view phase,
    std::string_view family) {
  TORCH_CHECK(
      query.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU query tensor");
  TORCH_CHECK(
      keys.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU keys tensor");
  TORCH_CHECK(
      weights.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU weights tensor");
  TORCH_CHECK(top_k >= 0, "top_k must be non-negative");
  TORCH_CHECK(query.dim() == 4, "query must have shape [B, Q, H, D]");
  TORCH_CHECK(keys.dim() == 3, "keys must have shape [B, C, D]");
  TORCH_CHECK(weights.dim() == 3, "weights must have shape [B, Q, H]");
  TORCH_CHECK(query.size(0) == keys.size(0), "batch sizes must match");
  TORCH_CHECK(query.size(0) == weights.size(0), "batch sizes must match");
  TORCH_CHECK(query.size(1) == weights.size(1), "query count must match");
  TORCH_CHECK(query.size(2) == weights.size(2), "head count must match");
  TORCH_CHECK(
      query.scalar_type() == at::ScalarType::Float ||
          query.scalar_type() == at::ScalarType::Half ||
          query.scalar_type() == at::ScalarType::BFloat16,
      "lightning_indexer custom op supports float32/float16/bfloat16 query");
  TORCH_CHECK(
      keys.scalar_type() == query.scalar_type() &&
          weights.scalar_type() == query.scalar_type(),
      "query, keys, and weights must use the same dtype");
  TORCH_CHECK(
      top_k <= keys.size(1),
      "top_k must not exceed context length, got top_k=",
      top_k,
      " context=",
      keys.size(1));

  if (query.numel() == 0 || keys.numel() == 0 || top_k == 0) {
    return at::empty(
        {query.size(0), query.size(1), top_k},
        query.options().dtype(c10::kInt));
  }

  auto query_bfloat = query.scalar_type() == at::ScalarType::BFloat16
      ? query.contiguous()
      : query.to(at::kBFloat16).contiguous();
  auto keys_bfloat = keys.scalar_type() == at::ScalarType::BFloat16
      ? keys.contiguous()
      : keys.to(at::kBFloat16).contiguous();
  auto weights_bfloat = weights.scalar_type() == at::ScalarType::BFloat16
      ? weights.contiguous()
      : weights.to(at::kBFloat16).contiguous();

  if (phase == "prefill" && family == "family_4x64") {
    TORCH_CHECK(query.size(2) == 4, "family_4x64 requires H == 4");
    TORCH_CHECK(query.size(3) == 64, "family_4x64 requires D == 64");
    TORCH_CHECK(keys.size(2) == 64, "family_4x64 requires keys D == 64");
    TORCH_CHECK(top_k <= 2048, "family_4x64 custom op requires top_k <= 2048");
    return lightning_indexer_forward_prefill_family_4x64_float(
        query_bfloat,
        keys_bfloat,
        weights_bfloat,
        top_k);
  }

  if (phase == "prefill" && family == "family_64x128") {
    TORCH_CHECK(query.size(2) == 64, "family_64x128 requires H == 64");
    TORCH_CHECK(query.size(3) == 128, "family_64x128 requires D == 128");
    TORCH_CHECK(keys.size(2) == 128, "family_64x128 requires keys D == 128");
    TORCH_CHECK(top_k <= 1024, "family_64x128 custom op requires top_k <= 1024");
    return lightning_indexer_forward_prefill_family_64x128_float(
        query_bfloat,
        keys_bfloat,
        weights_bfloat,
        top_k);
  }

  if (phase == "decode" && family == "family_64x128") {
    TORCH_CHECK(query.size(2) == 64, "family_64x128 requires H == 64");
    TORCH_CHECK(query.size(3) == 128, "family_64x128 requires D == 128");
    TORCH_CHECK(keys.size(2) == 128, "family_64x128 requires keys D == 128");
    TORCH_CHECK(top_k <= 1024, "family_64x128 custom op requires top_k <= 1024");
    return lightning_indexer_forward_decode_family_64x128_float(
        query_bfloat,
        keys_bfloat,
        weights_bfloat,
        top_k);
  }

  if (phase == "decode" && family == "family_4x64") {
    TORCH_CHECK(query.size(2) == 4, "family_4x64 requires H == 4");
    TORCH_CHECK(query.size(3) == 64, "family_4x64 requires D == 64");
    TORCH_CHECK(keys.size(2) == 64, "family_4x64 requires keys D == 64");
    TORCH_CHECK(top_k <= 2048, "family_4x64 custom op requires top_k <= 2048");
    return lightning_indexer_forward_decode_family_4x64_float(
        query_bfloat,
        keys_bfloat,
        weights_bfloat,
        top_k);
  }

  TORCH_CHECK(
      false,
      "lightning_indexer custom op supports prefill/family_4x64, prefill/family_64x128, decode/family_64x128, and decode/family_4x64 only");
}

TORCH_LIBRARY_FRAGMENT(aten_dsa_lightning_indexer, m) {
  m.def(
      "lightning_indexer_forward(Tensor query, Tensor keys, Tensor weights, int top_k, str phase, str family) -> Tensor");
}

TORCH_LIBRARY_IMPL(aten_dsa_lightning_indexer, PrivateUse1, m) {
  m.impl("lightning_indexer_forward", &lightning_indexer_forward_privateuse1);
}

} // namespace
} // namespace aten_dsa_lightning_indexer
