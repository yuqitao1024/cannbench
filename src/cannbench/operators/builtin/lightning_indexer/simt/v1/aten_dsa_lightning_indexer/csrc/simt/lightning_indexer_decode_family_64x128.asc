#include <cstdint>
#include <limits>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kFamily64x128HeadCount = 64;
constexpr int32_t kFamily64x128HeadDim = 128;
constexpr int32_t kTopKUpperBound = 1024;

__SIMT_DEVICE_FUNCTIONS_DECL__ inline float relu_float(float value) {
  return value > 0.0F ? value : 0.0F;
}

__global__ void lightning_indexer_decode_family_64x128_kernel(
    const float* query,
    const float* keys,
    const float* weights,
    int32_t* output,
    int32_t batch_size,
    int32_t query_count,
    int32_t context_count,
    int32_t top_k) {
  if (threadIdx.x != 0) {
    return;
  }

  for (int32_t linear_index = blockIdx.x; linear_index < batch_size * query_count;
       linear_index += gridDim.x) {
    const int32_t batch_index = linear_index / query_count;
    const int32_t query_index = linear_index % query_count;

    float best_scores[kTopKUpperBound];
    int32_t best_indices[kTopKUpperBound];

#pragma unroll
    for (int32_t i = 0; i < kTopKUpperBound; ++i) {
      best_scores[i] = -std::numeric_limits<float>::infinity();
      best_indices[i] = 0;
    }

    const int64_t query_base =
        (static_cast<int64_t>(batch_index) * query_count + query_index) *
        kFamily64x128HeadCount * kFamily64x128HeadDim;
    const int64_t weight_base =
        (static_cast<int64_t>(batch_index) * query_count + query_index) *
        kFamily64x128HeadCount;
    const int64_t key_batch_base =
        static_cast<int64_t>(batch_index) * context_count * kFamily64x128HeadDim;

    for (int32_t context_index = 0; context_index < context_count; ++context_index) {
      const int64_t key_base =
          key_batch_base + static_cast<int64_t>(context_index) * kFamily64x128HeadDim;

      float reduced_score = 0.0F;
      for (int32_t head_index = 0; head_index < kFamily64x128HeadCount; ++head_index) {
        float dot = 0.0F;
        const int64_t query_head_base =
            query_base + static_cast<int64_t>(head_index) * kFamily64x128HeadDim;
        for (int32_t dim_index = 0; dim_index < kFamily64x128HeadDim; ++dim_index) {
          dot += query[query_head_base + dim_index] * keys[key_base + dim_index];
        }
        reduced_score += relu_float(dot) * weights[weight_base + head_index];
      }

      int32_t insert_at = top_k;
      for (int32_t rank = 0; rank < top_k; ++rank) {
        if (reduced_score > best_scores[rank]) {
          insert_at = rank;
          break;
        }
      }

      if (insert_at < top_k) {
        for (int32_t rank = top_k - 1; rank > insert_at; --rank) {
          best_scores[rank] = best_scores[rank - 1];
          best_indices[rank] = best_indices[rank - 1];
        }
        best_scores[insert_at] = reduced_score;
        best_indices[insert_at] = context_index;
      }
    }

    const int64_t output_base =
        (static_cast<int64_t>(batch_index) * query_count + query_index) * top_k;
    for (int32_t rank = 0; rank < top_k; ++rank) {
      output[output_base + rank] = best_indices[rank];
    }
  }
}

} // namespace

extern "C" void launch_lightning_indexer_decode_family_64x128_float(
    const float* query,
    const float* keys,
    const float* weights,
    int32_t* output,
    int64_t batch_size,
    int64_t query_count,
    int64_t context_count,
    int64_t top_k,
    aclrtStream stream) {
  constexpr uint32_t kThreadsPerBlock = 1;
  constexpr uint32_t kMaxBlocks = 256;

  uint32_t blocks_per_grid = static_cast<uint32_t>(batch_size * query_count);
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }

  lightning_indexer_decode_family_64x128_kernel
      <<<blocks_per_grid, kThreadsPerBlock, 0, stream>>>(
          query,
          keys,
          weights,
          output,
          static_cast<int32_t>(batch_size),
          static_cast<int32_t>(query_count),
          static_cast<int32_t>(context_count),
          static_cast<int32_t>(top_k));
}
