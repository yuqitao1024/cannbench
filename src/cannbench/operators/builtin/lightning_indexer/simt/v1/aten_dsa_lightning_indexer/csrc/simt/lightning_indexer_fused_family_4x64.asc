#include <cstdint>

#include "acl/acl.h"
#include "basic_api/kernel_basic_intf.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "kernel_operator.h"
#include "simt_api/asc_bf16.h"
#include "simt_api/asc_simt.h"
#include "tensor_api/tensor.h"

#include "lightning_indexer_topk_ub.h"

namespace {

using namespace AscendC::Te;

constexpr int32_t kFamily4x64HeadCount = 4;
constexpr int32_t kFamily4x64AlignedHeadCount = 16;
constexpr int32_t kFamily4x64HeadDim = 64;
constexpr int32_t kContextTileCapacity = 128;
constexpr int32_t kThreadsPerBlock = 256;
constexpr int32_t kMaxUsedCoreNum = 11;
constexpr uint8_t kScoreReadyFlagBase = 0;
constexpr uint8_t kCrossCoreSyncMode = 4;
constexpr uint32_t kSharedScoresEntries =
    kFamily4x64HeadCount * kContextTileCapacity;
constexpr AscendC::FixpipeConfig kRowMajorUbFixpipeConfig = {
    AscendC::CO2Layout::ROW_MAJOR,
    true,
};

struct LightningIndexerFamily4x64MmadTrait {
  using TraitType = MmadTrait;
  static constexpr const TraitType value =
      MmadTrait(0, false, false, false, MmadType::NORMAL);
};

__SIMT_DEVICE_FUNCTIONS_DECL__ inline float relu_float(float value) {
  return value > 0.0F ? value : 0.0F;
}

__simt_vf__ __launch_bounds__(kThreadsPerBlock) inline void
lightning_indexer_fused_family_4x64_postprocess_vf(
    __ubuf__ const float* shared_scores,
    __gm__ const bfloat16_t* weights,
    __gm__ float* topk_scores,
    __gm__ int32_t* topk_indices,
    int32_t query_count,
    int32_t context_count,
    int32_t top_k,
    int32_t context_start,
    int32_t linear_index,
    __ubuf__ uint32_t* dynamicStartUB) {
  __ubuf__ float* candidate_scores =
      reinterpret_cast<__ubuf__ float*>(dynamicStartUB);
  __ubuf__ int32_t* candidate_indices = reinterpret_cast<__ubuf__ int32_t*>(
      candidate_scores + kFusedTopkSortCapacity);

  const int32_t batch_index = linear_index / query_count;
  const int32_t query_index = linear_index % query_count;
  const int64_t weight_base =
      (static_cast<int64_t>(batch_index) * query_count + query_index) *
      kFamily4x64HeadCount;
  const int64_t topk_base =
      (static_cast<int64_t>(batch_index) * query_count + query_index) * top_k;

  for (int32_t context_index = static_cast<int32_t>(threadIdx.x);
       context_index < context_count;
       context_index += static_cast<int32_t>(blockDim.x)) {
    float reduced_score = 0.0F;
    for (int32_t head_index = 0; head_index < kFamily4x64HeadCount; ++head_index) {
      const bfloat16_t dot_bf16 = static_cast<bfloat16_t>(
          shared_scores[head_index * kContextTileCapacity + context_index]);
      const bfloat16_t relu_bf16 =
          static_cast<bfloat16_t>(relu_float(static_cast<float>(dot_bf16)));
      const bfloat16_t weighted_bf16 = static_cast<bfloat16_t>(
          static_cast<float>(relu_bf16) *
          static_cast<float>(weights[weight_base + head_index]));
      reduced_score += static_cast<float>(weighted_bf16);
    }
    reduced_score = static_cast<float>(static_cast<bfloat16_t>(reduced_score));
    const int32_t candidate_index = top_k + context_index;
    candidate_scores[candidate_index] = reduced_score;
    candidate_indices[candidate_index] = context_start + context_index;
  }

  asc_syncthreads();
  lightning_indexer_merge_topk_ub(
      candidate_scores,
      candidate_indices,
      topk_scores,
      topk_indices,
      topk_base,
      context_count,
      top_k);
}

__aicore__ inline void lightning_indexer_fused_family_4x64_aic(
    __gm__ bfloat16_t* query,
    __gm__ bfloat16_t* keys,
    int32_t query_count,
    int32_t context_count,
    int32_t row_start,
    int32_t used_core_num) {
  AscendC::InitSocState();
  const uint32_t block_idx = AscendC::GetBlockIdx();
  if (block_idx >= static_cast<uint32_t>(used_core_num)) {
    return;
  }

  const uint16_t score_ready_flag =
      static_cast<uint16_t>(kScoreReadyFlagBase + block_idx);
  const int64_t query_batch_stride =
      static_cast<int64_t>(query_count) * kFamily4x64HeadCount * kFamily4x64HeadDim;
  const int64_t key_batch_stride =
      static_cast<int64_t>(context_count) * kFamily4x64HeadDim;

  __cbuf__ bfloat16_t
      l1_query_buf[kFamily4x64AlignedHeadCount * kFamily4x64HeadDim];
  __cbuf__ bfloat16_t l1_keys_buf[kFamily4x64HeadDim * kContextTileCapacity];
  __ca__ bfloat16_t
      l0_query_buf[kFamily4x64AlignedHeadCount * kFamily4x64HeadDim];
  __cb__ bfloat16_t l0_keys_buf[kFamily4x64HeadDim * kContextTileCapacity];
  __cc__ float
      l0_scores_buf[kFamily4x64AlignedHeadCount * kContextTileCapacity];

  AscendC::LocalTensor<float> l0_scores_tensor(
      AscendC::TPosition::CO1,
      0,
      kFamily4x64AlignedHeadCount * kContextTileCapacity);
  AscendC::LocalTensor<float> shared_scores_tensor(
      AscendC::TPosition::LCM,
      0,
      kSharedScoresEntries);

  auto copy_gm_to_l1 = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
  auto copy_l1_to_l0a = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
  auto copy_l1_to_l0b = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
  auto mm = MakeMmad(MmadOperation{}, LightningIndexerFamily4x64MmadTrait{});

  auto l1_query = MakeTensor(
      MakeMemPtr(l1_query_buf),
      MakeFrameLayout<NZLayoutPtn, bfloat16_t>(
          kFamily4x64HeadCount,
          kFamily4x64HeadDim));
  auto l0_query = MakeTensor(
      MakeMemPtr(l0_query_buf),
      MakeFrameLayout<NZLayoutPtn, bfloat16_t>(
          kFamily4x64HeadCount,
          kFamily4x64HeadDim));
  auto l1_keys = MakeTensor(
      MakeMemPtr(l1_keys_buf),
      MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(
          kFamily4x64HeadDim, context_count));
  auto l0_keys = MakeTensor(
      MakeMemPtr(l0_keys_buf),
      MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(
          kFamily4x64HeadDim, context_count));
  auto l0_scores = MakeTensor(
      MakeMemPtr(l0_scores_buf),
      MakeFrameLayout<NZLayoutPtn>(kFamily4x64HeadCount, context_count));

  const int32_t linear_index = row_start + static_cast<int32_t>(block_idx);
  const int32_t batch_index = linear_index / query_count;
  const int32_t query_index = linear_index % query_count;
  auto gm_query = MakeTensor(
      MakeMemPtr(
          query + static_cast<int64_t>(batch_index) * query_batch_stride +
          static_cast<int64_t>(query_index) * kFamily4x64HeadCount *
              kFamily4x64HeadDim),
      MakeFrameLayout<NDExtLayoutPtn>(
          kFamily4x64HeadCount, kFamily4x64HeadDim));
  auto gm_keys = MakeTensor(
      MakeMemPtr(keys + static_cast<int64_t>(batch_index) * key_batch_stride),
      MakeFrameLayout<DNExtLayoutPtn>(kFamily4x64HeadDim, context_count));

  Copy(copy_gm_to_l1, l1_query, gm_query);
  AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
  AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
  Copy(copy_l1_to_l0a, l0_query, l1_query);
  AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
  AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

  Copy(copy_gm_to_l1, l1_keys, gm_keys);
  AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
  AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
  Copy(copy_l1_to_l0b, l0_keys, l1_keys);
  AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
  AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);

  MmadParams params;
  params.m = kFamily4x64HeadCount;
  params.n = static_cast<uint16_t>(context_count);
  params.k = kFamily4x64HeadDim;
  params.unitFlag = 0;
  params.cmatrixInitVal = true;
  Mmad(mm.with(params), l0_scores, l0_query, l0_keys);
  AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
  AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);

  AscendC::CrossCoreWaitFlag<kCrossCoreSyncMode, PIPE_FIX>(score_ready_flag);
  AscendC::FixpipeParamsC310<AscendC::CO2Layout::ROW_MAJOR> fixpipe_params;
  fixpipe_params.nSize =
      ((static_cast<uint32_t>(context_count) + 7U) / 8U) * 8U;
  fixpipe_params.mSize = kFamily4x64HeadCount;
  fixpipe_params.srcStride = kFamily4x64AlignedHeadCount;
  fixpipe_params.dstStride = kContextTileCapacity;
  fixpipe_params.dualDstCtl = 0;
  fixpipe_params.subBlockId = false;
  fixpipe_params.unitFlag = 0;
  AscendC::Fixpipe<float, float, kRowMajorUbFixpipeConfig>(
      shared_scores_tensor,
      l0_scores_tensor,
      fixpipe_params);
  AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_FIX>(score_ready_flag);

  AscendC::PipeBarrier<PIPE_ALL>();
}

__aicore__ inline void lightning_indexer_fused_family_4x64_aiv(
    __gm__ const bfloat16_t* weights,
    __gm__ float* topk_scores,
    __gm__ int32_t* topk_indices,
    int32_t query_count,
    int32_t context_count,
    int32_t top_k,
    int32_t context_start,
    int32_t row_start,
    int32_t used_core_num) {
  AscendC::InitSocState();
  if (AscendC::GetSubBlockIdx() != 0) {
    return;
  }

  const uint32_t block_idx =
      static_cast<uint32_t>(AscendC::GetBlockIdx() / AscendC::GetTaskRatio());
  if (block_idx >= static_cast<uint32_t>(used_core_num)) {
    return;
  }

  const uint16_t score_ready_flag =
      static_cast<uint16_t>(kScoreReadyFlagBase + block_idx);
  AscendC::LocalTensor<float> shared_scores_tensor(
      AscendC::TPosition::LCM,
      0,
      kSharedScoresEntries);
  __ubuf__ const float* shared_scores =
      reinterpret_cast<__ubuf__ const float*>(shared_scores_tensor.GetPhyAddr());
  extern __ubuf__ uint32_t dynamicStartUB[];

  const int32_t linear_index = row_start + static_cast<int32_t>(block_idx);
  AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_V>(score_ready_flag);
  AscendC::CrossCoreWaitFlag<kCrossCoreSyncMode, PIPE_V>(score_ready_flag);
  asc_vf_call<lightning_indexer_fused_family_4x64_postprocess_vf>(
      dim3(kThreadsPerBlock, 1, 1),
      shared_scores,
      weights,
      topk_scores,
      topk_indices,
      query_count,
      context_count,
      top_k,
      context_start,
      linear_index,
      dynamicStartUB);
}

__global__ __aicore__ void lightning_indexer_fused_family_4x64_kernel(
    __gm__ const uint16_t* query,
    __gm__ const uint16_t* keys,
    __gm__ const uint16_t* weights,
    __gm__ float* topk_scores,
    __gm__ int32_t* topk_indices,
    __kfc_workspace__ __gm__ uint8_t* workspace,
    int32_t query_count,
    int32_t context_count,
    int32_t top_k,
    int32_t context_start,
    int32_t row_start,
    int32_t used_core_num) {
  (void)workspace;
  KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIC_1_2);
  if ASCEND_IS_AIC {
    lightning_indexer_fused_family_4x64_aic(
        reinterpret_cast<__gm__ bfloat16_t*>(
            const_cast<__gm__ uint16_t*>(query)),
        reinterpret_cast<__gm__ bfloat16_t*>(
            const_cast<__gm__ uint16_t*>(keys)),
        query_count,
        context_count,
        row_start,
        used_core_num);
  } else if ASCEND_IS_AIV {
    lightning_indexer_fused_family_4x64_aiv(
        reinterpret_cast<__gm__ const bfloat16_t*>(weights),
        topk_scores,
        topk_indices,
        query_count,
        context_count,
        top_k,
        context_start,
        row_start,
        used_core_num);
  }
}

} // namespace

extern "C" void launch_lightning_indexer_fused_family_4x64_float(
    const bfloat16_t* query,
    const bfloat16_t* keys,
    const bfloat16_t* weights,
    float* topk_scores,
    int32_t* topk_indices,
    int64_t batch_size,
    int64_t query_count,
    int64_t context_count,
    int64_t top_k,
    int64_t context_start,
    aclrtStream stream) {
  const int32_t total_rows = static_cast<int32_t>(batch_size * query_count);
  // asc_vf_call is asynchronous, so a core must not reuse its score UB in one launch.
  for (int32_t row_start = 0; row_start < total_rows;
       row_start += kMaxUsedCoreNum) {
    const int32_t used_core_num =
        total_rows - row_start < kMaxUsedCoreNum
        ? total_rows - row_start
        : kMaxUsedCoreNum;
    lightning_indexer_fused_family_4x64_kernel
        <<<used_core_num, kFusedTopkDynamicUbufBytes, stream>>>(
        reinterpret_cast<const uint16_t*>(query),
        reinterpret_cast<const uint16_t*>(keys),
        reinterpret_cast<const uint16_t*>(weights),
        topk_scores,
        topk_indices,
        reinterpret_cast<uint8_t*>(topk_scores),
        static_cast<int32_t>(query_count),
        static_cast<int32_t>(context_count),
        static_cast<int32_t>(top_k),
        static_cast<int32_t>(context_start),
        row_start,
        used_core_num);
  }
}
