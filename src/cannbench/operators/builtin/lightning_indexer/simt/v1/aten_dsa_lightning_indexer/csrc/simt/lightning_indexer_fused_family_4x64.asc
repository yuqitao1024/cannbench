#include <cstdint>
#include <limits>

#include "acl/acl.h"
#include "simt_api/asc_bf16.h"
#include "simt_api/asc_fp16.h"
#include "simt_api/asc_simt.h"

#include "lightning_indexer_topk_ub.h"

namespace {

constexpr int32_t kFamily4x64HeadCount = 4;
constexpr int32_t kFamily4x64HeadDim = 64;
constexpr int32_t kThreadsPerBlock = 256;
constexpr int32_t kMaxBlocks = 256;

__SIMT_DEVICE_FUNCTIONS_DECL__ inline float relu_float(float value) {
  return value > 0.0F ? value : 0.0F;
}

__simt_vf__ __launch_bounds__(kThreadsPerBlock) inline void
lightning_indexer_fused_family_4x64_vf(
    __gm__ const bfloat16_t* query,
    __gm__ const bfloat16_t* keys,
    __gm__ const bfloat16_t* weights,
    __gm__ float* topk_scores,
    __gm__ int32_t* topk_indices,
    int32_t batch_size,
    int32_t query_count,
    int32_t context_count,
    int32_t top_k,
    int32_t context_start,
    __ubuf__ uint32_t* dynamicStartUB) {
  __ubuf__ float* candidate_scores =
      reinterpret_cast<__ubuf__ float*>(dynamicStartUB);
  __ubuf__ int32_t* candidate_indices = reinterpret_cast<__ubuf__ int32_t*>(
      candidate_scores + kFusedTopkSortCapacity);

  const int64_t query_batch_stride =
      static_cast<int64_t>(query_count) * kFamily4x64HeadCount * kFamily4x64HeadDim;
  const int64_t key_batch_stride =
      static_cast<int64_t>(context_count) * kFamily4x64HeadDim;
  const int64_t weight_batch_stride =
      static_cast<int64_t>(query_count) * kFamily4x64HeadCount;
  const int64_t topk_batch_stride = static_cast<int64_t>(query_count) * top_k;

  for (int32_t linear_index = blockIdx.x; linear_index < batch_size * query_count;
       linear_index += gridDim.x) {
    const int32_t batch_index = linear_index / query_count;
    const int32_t query_index = linear_index % query_count;

    const int64_t query_base =
        static_cast<int64_t>(batch_index) * query_batch_stride +
        static_cast<int64_t>(query_index) * kFamily4x64HeadCount * kFamily4x64HeadDim;
    const int64_t key_base = static_cast<int64_t>(batch_index) * key_batch_stride;
    const int64_t weight_base =
        static_cast<int64_t>(batch_index) * weight_batch_stride +
        static_cast<int64_t>(query_index) * kFamily4x64HeadCount;
    const int64_t topk_base =
        static_cast<int64_t>(batch_index) * topk_batch_stride +
        static_cast<int64_t>(query_index) * top_k;

    for (int32_t context_index = static_cast<int32_t>(threadIdx.x);
         context_index < context_count;
         context_index += static_cast<int32_t>(blockDim.x)) {
      const int64_t key_offset =
          key_base + static_cast<int64_t>(context_index) * kFamily4x64HeadDim;
      float reduced_score = 0.0F;
      for (int32_t head_index = 0; head_index < kFamily4x64HeadCount; ++head_index) {
        const int64_t query_offset =
            query_base +
            static_cast<int64_t>(head_index) * kFamily4x64HeadDim;
        float dot = 0.0F;
        for (int32_t dim_index = 0; dim_index < kFamily4x64HeadDim; ++dim_index) {
          dot += static_cast<float>(query[query_offset + dim_index]) *
              static_cast<float>(keys[key_offset + dim_index]);
        }
        const bfloat16_t dot_bf16 = static_cast<bfloat16_t>(dot);
        const bfloat16_t relu_bf16 =
            static_cast<bfloat16_t>(relu_float(static_cast<float>(dot_bf16)));
        const bfloat16_t weighted_bf16 = static_cast<bfloat16_t>(
            static_cast<float>(relu_bf16) *
            static_cast<float>(weights[weight_base + head_index]));
        reduced_score += static_cast<float>(weighted_bf16);
      }
      reduced_score = static_cast<float>(static_cast<bfloat16_t>(reduced_score));
      const int32_t candidate_index = top_k + context_index;
      candidate_scores[candidate_index] = reduced_score;
      candidate_indices[candidate_index] = context_start + context_index;
    }

    asc_syncthreads();
    lightning_indexer_merge_topk_ub(
        candidate_scores,
        candidate_indices,
        topk_scores,
        topk_indices,
        topk_base,
        context_count,
        top_k);
  }
}

__global__ __vector__ void lightning_indexer_fused_family_4x64_kernel(
    __gm__ const uint16_t* query,
    __gm__ const uint16_t* keys,
    __gm__ const uint16_t* weights,
    __gm__ float* topk_scores,
    __gm__ int32_t* topk_indices,
    int32_t batch_size,
    int32_t query_count,
    int32_t context_count,
    int32_t top_k,
    int32_t context_start,
    int64_t block_x,
    int64_t block_y) {
  extern __ubuf__ uint32_t dynamicStartUB[];
  asc_vf_call<lightning_indexer_fused_family_4x64_vf>(
      dim3(block_x, block_y),
      reinterpret_cast<__gm__ const bfloat16_t*>(query),
      reinterpret_cast<__gm__ const bfloat16_t*>(keys),
      reinterpret_cast<__gm__ const bfloat16_t*>(weights),
      topk_scores,
      topk_indices,
      batch_size,
      query_count,
      context_count,
      top_k,
      context_start,
      dynamicStartUB);
}

} // namespace

extern "C" void launch_lightning_indexer_fused_family_4x64_float(
    const bfloat16_t* query,
    const bfloat16_t* keys,
    const bfloat16_t* weights,
    float* topk_scores,
    int32_t* topk_indices,
    int64_t batch_size,
    int64_t query_count,
    int64_t context_count,
    int64_t top_k,
    int64_t context_start,
    aclrtStream stream) {
  uint32_t blocks_per_grid = static_cast<uint32_t>(batch_size * query_count);
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }

  lightning_indexer_fused_family_4x64_kernel
      <<<blocks_per_grid, kFusedTopkDynamicUbufBytes, stream>>>(
      reinterpret_cast<const uint16_t*>(query),
      reinterpret_cast<const uint16_t*>(keys),
      reinterpret_cast<const uint16_t*>(weights),
      topk_scores,
      topk_indices,
      static_cast<int32_t>(batch_size),
      static_cast<int32_t>(query_count),
      static_cast<int32_t>(context_count),
      static_cast<int32_t>(top_k),
      static_cast<int32_t>(context_start),
      kThreadsPerBlock,
      1);
}
