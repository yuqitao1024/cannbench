#include <cstdint>
#include <limits>
#include <math.h>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kHeadDim = 512;
constexpr int32_t kSelectedTokenUpperBound = 1024;

__global__ void sparse_attention_postprocess_family_hd512_kernel(
    const float* scores,
    const float* selected_values,
    const int32_t* indices,
    float* output,
    float* lse,
    int32_t batch_size,
    int32_t query_heads,
    int32_t query_tokens,
    int32_t selected_tokens,
    int32_t query_start,
    bool causal) {
  if (threadIdx.x != 0) {
    return;
  }

  for (int64_t linear_index = blockIdx.x;
       linear_index < static_cast<int64_t>(batch_size) * query_heads * query_tokens;
       linear_index += gridDim.x) {
    const int32_t query_index = static_cast<int32_t>(linear_index % query_tokens);
    const int64_t row_index = linear_index / query_tokens;
    const int32_t head_index = static_cast<int32_t>(row_index % query_heads);
    const int32_t batch_index = static_cast<int32_t>(row_index / query_heads);

    float weighted_output[kHeadDim];
    for (int32_t dim_index = 0; dim_index < kHeadDim; ++dim_index) {
      weighted_output[dim_index] = 0.0F;
    }

    const int64_t output_base =
        ((static_cast<int64_t>(batch_index) * query_heads + head_index) * query_tokens +
         query_index) *
        kHeadDim;
    const int64_t index_base =
        (static_cast<int64_t>(batch_index) * query_tokens + query_index) *
        selected_tokens;
    const int64_t score_base =
        ((static_cast<int64_t>(batch_index) * query_heads + head_index) * query_tokens +
         query_index) *
        selected_tokens;
    const int64_t value_base =
        ((((static_cast<int64_t>(batch_index) * query_heads + head_index) * query_tokens +
           query_index) *
          selected_tokens) *
         kHeadDim);

    float max_score = -std::numeric_limits<float>::infinity();
    bool has_valid_score = false;
    for (int32_t selected_index = 0; selected_index < selected_tokens; ++selected_index) {
      const int32_t token_index = indices[index_base + selected_index];
      if (token_index < 0) {
        continue;
      }
      if (causal && token_index > (query_start + query_index)) {
        continue;
      }
      const float score = scores[score_base + selected_index];
      if (!has_valid_score || score > max_score) {
        max_score = score;
        has_valid_score = true;
      }
    }

    if (!has_valid_score) {
      for (int32_t dim_index = 0; dim_index < kHeadDim; ++dim_index) {
        output[output_base + dim_index] = 0.0F;
      }
      lse[linear_index] = -std::numeric_limits<float>::infinity();
      continue;
    }

    float sum_exp = 0.0F;
    for (int32_t selected_index = 0; selected_index < selected_tokens; ++selected_index) {
      const int32_t token_index = indices[index_base + selected_index];
      if (token_index < 0) {
        continue;
      }
      if (causal && token_index > (query_start + query_index)) {
        continue;
      }

      const float score = scores[score_base + selected_index];
      const float probability = expf(score - max_score);
      sum_exp += probability;
      for (int32_t dim_index = 0; dim_index < kHeadDim; ++dim_index) {
        weighted_output[dim_index] +=
            probability *
            selected_values[value_base +
                            static_cast<int64_t>(selected_index) * kHeadDim + dim_index];
      }
    }

    const float inv_sum = sum_exp > 0.0F ? 1.0F / sum_exp : 0.0F;
    for (int32_t dim_index = 0; dim_index < kHeadDim; ++dim_index) {
      output[output_base + dim_index] = weighted_output[dim_index] * inv_sum;
    }
    lse[linear_index] = max_score + logf(sum_exp);
  }
}

} // namespace

extern "C" void launch_sparse_attention_hd512_postprocess_float(
    const float* scores,
    const float* selected_values,
    const int32_t* indices,
    float* output,
    float* lse,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t query_start,
    bool causal,
    aclrtStream stream) {
  constexpr uint32_t kThreadsPerBlock = 1;
  constexpr uint32_t kMaxBlocks = 256;

  uint32_t blocks_per_grid =
      static_cast<uint32_t>(batch_size * query_heads * query_tokens);
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }

  sparse_attention_postprocess_family_hd512_kernel<<<blocks_per_grid, kThreadsPerBlock, 0, stream>>>(
      scores,
      selected_values,
      indices,
      output,
      lse,
      static_cast<int32_t>(batch_size),
      static_cast<int32_t>(query_heads),
      static_cast<int32_t>(query_tokens),
      static_cast<int32_t>(selected_tokens),
      static_cast<int32_t>(query_start),
      causal);
}
