#include <cstdint>

#include "acl/acl.h"
#include "basic_api/kernel_common.h"
#include "c_api/asc_simd.h"
#include "simt_api/asc_simt.h"
#include "tensor_api/tensor.h"

namespace {

using namespace AscendC::Te;

constexpr int32_t kHeadDim = 128;
constexpr int32_t kBaseN = 256;
constexpr int32_t kUsedCoreNum = 32;
constexpr uint8_t kGatherMutexId = 0;

struct SparseAttentionScoreHd128Shape {
  int32_t used_core_num;
  int32_t m;
  int32_t n;
  int32_t k;
  int32_t single_core_m;
  int32_t single_core_n;
  int32_t single_core_k;
};

struct SparseAttentionScoreHd128GemvTrait {
  using TraitType = MmadTrait;
  static constexpr const TraitType value =
      MmadTrait(0, false, false, false, MmadType::NORMAL);
};

__SIMT_DEVICE_FUNCTIONS_DECL__ inline uint32_t zn_offset_hd128(
    uint32_t dim_index,
    uint32_t selected_index) {
  constexpr uint32_t kC0 = 16;
  return (selected_index / kC0) * kHeadDim * kC0 +
      (dim_index / kC0) * kC0 * kC0 +
      (selected_index % kC0) * kC0 +
      (dim_index % kC0);
}

__aicore__ inline void copy_shape(
    SparseAttentionScoreHd128Shape* shape,
    __gm__ uint8_t* tiling_gm) {
  auto dst = reinterpret_cast<uint32_t*>(shape);
  auto src = reinterpret_cast<__gm__ uint32_t*>(tiling_gm);
  for (uint32_t i = 0; i < sizeof(SparseAttentionScoreHd128Shape) / sizeof(uint32_t); ++i) {
    dst[i] = src[i];
  }
}

__aicore__ inline void sparse_attention_score_family_hd128_aic(
    __gm__ half* query,
    __gm__ half* selected_keys,
    __gm__ float* scores,
    __gm__ uint8_t* tiling_gm,
    __cbuf__ half* shared_l1_keys_buf) {
  SparseAttentionScoreHd128Shape shape;
  copy_shape(&shape, tiling_gm);
  const uint32_t core_idx = static_cast<uint32_t>(blockIdx.x);
  if (core_idx >= static_cast<uint32_t>(shape.used_core_num)) {
    return;
  }
  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);

  auto gm_query = MakeTensor(
      MakeMemPtr(query), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.k));
  auto gm_scores = MakeTensor(
      MakeMemPtr(scores), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.n));

  __cbuf__ half l1_query_buf[kHeadDim];
  __ca__ half l0_query_buf[kHeadDim];
  __cb__ half l0_keys_buf[kHeadDim * kBaseN];
  __cc__ float l0_scores_buf[16 * kBaseN];

  auto copy_gm_to_l1 = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
  auto copy_l1_to_l0a = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
  auto copy_l1_to_l0b = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
  auto copy_l0c_to_gm = MakeCopy(CopyL0C2GM{}, CopyL0C2GMTraitDefault{});
  auto mm = MakeMmad(MmadOperation{}, SparseAttentionScoreHd128GemvTrait{});

  auto l1_query_nd = MakeTensor(
      MakeMemPtr(l1_query_buf), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.k));
  auto l1_query_nz = MakeTensor(
      l1_query_nd.Data(),
      MakeFrameLayout<NZLayoutPtn, half>(shape.k / C0_ELEMENT<half>, C0_ELEMENT<half>));
  auto l0_query = MakeTensor(
      MakeMemPtr(l0_query_buf),
      MakeFrameLayout<NZLayoutPtn, half>(shape.k / C0_ELEMENT<half>, C0_ELEMENT<half>));

  Copy(copy_gm_to_l1, l1_query_nd, gm_query);
  Copy(copy_l1_to_l0a, l0_query, l1_query_nz);

  for (uint32_t n_index = core_idx; n_index < n_loop;
       n_index += static_cast<uint32_t>(shape.used_core_num)) {
    const uint16_t cur_n = static_cast<uint16_t>(
        n_index + 1 == n_loop ? shape.n - static_cast<int32_t>(n_index) * kBaseN : kBaseN);
    auto l1_keys = MakeTensor(
        MakeMemPtr(shared_l1_keys_buf), MakeFrameLayout<ZNLayoutPtn, half>(shape.k, cur_n));
    auto l0_keys = MakeTensor(
        MakeMemPtr(l0_keys_buf), MakeFrameLayout<ZNLayoutPtn, half>(shape.k, cur_n));
    auto l0_scores = MakeTensor(
        MakeMemPtr(l0_scores_buf), MakeFrameLayout<NZLayoutPtn>(shape.m, cur_n));
    auto gm_score_tile = gm_scores.Slice(
        MakeCoord(0, static_cast<int32_t>(n_index) * kBaseN),
        MakeShape(shape.m, cur_n));

    if (selected_keys != nullptr) {
      auto gm_keys = MakeTensor(
          MakeMemPtr(selected_keys), MakeFrameLayout<DNExtLayoutPtn>(shape.k, shape.n));
      auto gm_key_tile = gm_keys.Slice(
          MakeCoord(0, static_cast<int32_t>(n_index) * kBaseN),
          MakeShape(shape.k, cur_n));
      Copy(copy_gm_to_l1, l1_keys, gm_key_tile);
    } else {
      AscendC::Mutex::Lock<PIPE_MTE1>(kGatherMutexId);
    }
    Copy(copy_l1_to_l0b, l0_keys, l1_keys);
    if (selected_keys == nullptr) {
      AscendC::Mutex::Unlock<PIPE_MTE1>(kGatherMutexId);
    }

    MmadParams params{
        static_cast<uint16_t>(shape.m),
        cur_n,
        static_cast<uint16_t>(shape.k),
        0,
        true,
    };
    Mmad(mm.with(params), l0_scores, l0_query, l0_keys);

    Copy(copy_l0c_to_gm, gm_score_tile, l0_scores);
  }
}

__simt_vf__ __launch_bounds__(256) inline void sparse_attention_gather_pack_family_hd128_vf(
    __gm__ const float* keys,
    __gm__ const int32_t* indices,
    __ubuf__ half* packed_keys,
    int64_t selected_base,
    int64_t tile_selected_tokens,
    int64_t context_tokens) {
  const int64_t total = tile_selected_tokens * kHeadDim;
  for (int64_t linear = blockIdx.x * blockDim.x + threadIdx.x;
       linear < total;
       linear += gridDim.x * blockDim.x) {
    const int64_t tile_selected_index = linear / kHeadDim;
    const int64_t selected_index = selected_base + tile_selected_index;
    const int64_t dim_index = linear - tile_selected_index * kHeadDim;
    const int32_t context_index = indices[selected_index];
    packed_keys[zn_offset_hd128(
        static_cast<uint32_t>(dim_index),
        static_cast<uint32_t>(tile_selected_index))] =
        context_index < 0 || context_index >= context_tokens
            ? static_cast<half>(0)
            : static_cast<half>(
                  keys[static_cast<int64_t>(context_index) * kHeadDim + dim_index]);
  }
}

__aicore__ inline void sparse_attention_gather_pack_family_hd128_aiv(
    __gm__ const float* keys,
    __gm__ const int32_t* indices,
    int64_t selected_tokens,
    int64_t context_tokens,
    __cbuf__ half* shared_l1_keys_buf) {
  if (keys == nullptr || indices == nullptr) {
    return;
  }

  const uint32_t core_idx = static_cast<uint32_t>(blockIdx.x);
  const uint32_t n_loop =
      static_cast<uint32_t>((selected_tokens + kBaseN - 1) / kBaseN);
  alignas(32) __ubuf__ half packed_keys_buf[kHeadDim * kBaseN];
  for (uint32_t n_index = core_idx; n_index < n_loop; n_index += kUsedCoreNum) {
    const int64_t selected_base = static_cast<int64_t>(n_index) * kBaseN;
    const int64_t cur_n = n_index + 1 == n_loop
        ? selected_tokens - selected_base
        : static_cast<int64_t>(kBaseN);
    AscendC::Mutex::Lock<PIPE_V>(kGatherMutexId);
    asc_vf_call<sparse_attention_gather_pack_family_hd128_vf>(
        dim3(256),
        keys,
        indices,
        packed_keys_buf,
        selected_base,
        cur_n,
        context_tokens);
    AscendC::Mutex::Unlock<PIPE_V>(kGatherMutexId);
    AscendC::Mutex::Lock<PIPE_MTE3>(kGatherMutexId);
    const int64_t aligned_cur_n = ((cur_n + 15) / 16) * 16;
    const auto copy_bytes = static_cast<uint32_t>(
        aligned_cur_n * static_cast<int64_t>(kHeadDim) * sizeof(half));
    asc_copy_ub2l1_sync(shared_l1_keys_buf, packed_keys_buf, copy_bytes);
    AscendC::Mutex::Unlock<PIPE_MTE3>(kGatherMutexId);
  }
}

__global__ __aicore__ void sparse_attention_score_family_hd128_kernel(
    __gm__ half* query,
    __gm__ half* selected_keys,
    __gm__ const float* keys,
    __gm__ const int32_t* indices,
    __gm__ float* scores,
    __kfc_workspace__ __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm,
    int64_t selected_tokens,
    int64_t context_tokens) {
  (void)workspace;
  KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIC_1_1);
  __cbuf__ half shared_l1_keys_buf[kHeadDim * kBaseN];
  if ASCEND_IS_AIC {
    sparse_attention_score_family_hd128_aic(
        query, selected_keys, scores, tiling_gm, shared_l1_keys_buf);
  } else if ASCEND_IS_AIV {
    sparse_attention_gather_pack_family_hd128_aiv(
        keys,
        indices,
        selected_tokens,
        context_tokens,
        shared_l1_keys_buf);
  }
}

} // namespace

extern "C" void launch_sparse_attention_score_hd128_float(
    const half* query,
    const half* selected_keys,
    float* scores,
    uint8_t* workspace,
    uint8_t* tiling,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t score_stride,
    int64_t score_offset,
    aclrtStream stream) {
  const int64_t total_rows = batch_size * query_heads * query_tokens;
  const int64_t selected_keys_stride = selected_tokens * kHeadDim;
  SparseAttentionScoreHd128Shape shape = {
      kUsedCoreNum,
      1,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
      kUsedCoreNum,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
  };
  aclrtMemcpyAsync(
      tiling,
      sizeof(shape),
      &shape,
      sizeof(shape),
      ACL_MEMCPY_HOST_TO_DEVICE,
      stream);
  for (int64_t row_index = 0; row_index < total_rows; ++row_index) {
    const int64_t head_row = row_index / query_tokens;
    const int64_t query_row = row_index % query_tokens;
    sparse_attention_score_family_hd128_kernel<<<shape.used_core_num, 0, stream>>>(
        const_cast<half*>(query) +
            (head_row * query_query_stride + query_query_offset + query_row) * kHeadDim,
        const_cast<half*>(selected_keys) + row_index * selected_keys_stride,
        nullptr,
        nullptr,
        scores + row_index * score_stride + score_offset,
        workspace,
        tiling,
        selected_tokens,
        0);
  }
}

extern "C" void launch_sparse_attention_score_gather_hd128_float(
    const half* query,
    const float* keys,
    const int32_t* indices,
    float* scores,
    uint8_t* workspace,
    uint8_t* tiling,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t context_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t score_stride,
    int64_t score_offset,
    aclrtStream stream) {
  const int64_t total_rows = batch_size * query_heads * query_tokens;
  SparseAttentionScoreHd128Shape shape = {
      kUsedCoreNum,
      1,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
      kUsedCoreNum,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
  };
  aclrtMemcpyAsync(
      tiling,
      sizeof(shape),
      &shape,
      sizeof(shape),
      ACL_MEMCPY_HOST_TO_DEVICE,
      stream);
  for (int64_t row_index = 0; row_index < total_rows; ++row_index) {
    const int64_t head_row = row_index / query_tokens;
    const int64_t query_row = row_index % query_tokens;
    const int64_t batch_index = head_row / query_heads;
    const int64_t key_offset = batch_index * context_tokens * kHeadDim;
    const int64_t indices_offset =
        (batch_index * indices_query_stride + indices_query_offset + query_row) *
            indices_selected_stride +
        indices_selected_offset;
    sparse_attention_score_family_hd128_kernel<<<shape.used_core_num, 0, stream>>>(
        const_cast<half*>(query) +
            (head_row * query_query_stride + query_query_offset + query_row) * kHeadDim,
        nullptr,
        keys + key_offset,
        indices + indices_offset,
        scores + row_index * score_stride + score_offset,
        workspace,
        tiling,
        selected_tokens,
        context_tokens);
  }
}
