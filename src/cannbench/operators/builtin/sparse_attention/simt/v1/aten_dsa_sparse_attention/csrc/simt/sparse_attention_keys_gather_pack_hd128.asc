#include <cstdint>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kHeadDim = 128;

__simt_vf__ __launch_bounds__(256) inline void sparse_attention_keys_gather_pack_hd128_vf(
    __gm__ const float* keys,
    __gm__ const int32_t* indices,
    __gm__ half* selected_keys,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t context_tokens,
    int64_t selected_tokens,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset) {
  const int64_t total_rows = batch_size * query_heads * query_tokens;
  for (int64_t linear_row = blockIdx.x; linear_row < total_rows; linear_row += gridDim.x) {
    const int64_t query_index = linear_row % query_tokens;
    const int64_t row_index = linear_row / query_tokens;
    const int64_t batch_index = row_index / query_heads;

    const int64_t key_row_base = (batch_index * context_tokens) * kHeadDim;
    const int64_t index_row_base =
        (batch_index * indices_query_stride + indices_query_offset + query_index) *
            indices_selected_stride +
        indices_selected_offset;
    const int64_t output_row_base = linear_row * selected_tokens * kHeadDim;

    const int64_t row_elements = selected_tokens * kHeadDim;
    for (int64_t packed_index = threadIdx.x; packed_index < row_elements;
         packed_index += blockDim.x) {
      const int64_t selected_index = packed_index / kHeadDim;
      const int64_t dim_index = packed_index - selected_index * kHeadDim;
      const int32_t context_index = indices[index_row_base + selected_index];
      const int64_t source_offset =
          key_row_base + static_cast<int64_t>(context_index) * kHeadDim + dim_index;
      selected_keys[output_row_base + packed_index] =
          static_cast<half>(keys[source_offset]);
    }
  }
}

__global__ __vector__ void sparse_attention_keys_gather_pack_hd128_kernel(
    __gm__ const float* keys,
    __gm__ const int32_t* indices,
    __gm__ half* selected_keys,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t context_tokens,
    int64_t selected_tokens,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t block_x,
    int64_t block_y) {
  asc_vf_call<sparse_attention_keys_gather_pack_hd128_vf>(
      dim3(block_x, block_y),
      keys,
      indices,
      selected_keys,
      batch_size,
      query_heads,
      query_tokens,
      context_tokens,
      selected_tokens,
      indices_query_stride,
      indices_query_offset,
      indices_selected_stride,
      indices_selected_offset);
}

} // namespace

extern "C" void launch_sparse_attention_keys_gather_pack_hd128_float(
    const float* keys,
    const int32_t* indices,
    half* selected_keys,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t context_tokens,
    int64_t selected_tokens,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    aclrtStream stream) {
  constexpr uint32_t kThreadsPerBlock = 256;
  constexpr uint32_t kMaxBlocks = 256;
  uint32_t blocks_per_grid =
      static_cast<uint32_t>(batch_size * query_heads * query_tokens);
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }

  sparse_attention_keys_gather_pack_hd128_kernel
      <<<blocks_per_grid, 0, stream>>>(
          keys,
          indices,
          selected_keys,
          batch_size,
          query_heads,
          query_tokens,
          context_tokens,
          selected_tokens,
          indices_query_stride,
          indices_query_offset,
          indices_selected_stride,
          indices_selected_offset,
          kThreadsPerBlock,
          1);
}
