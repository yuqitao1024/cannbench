#include <cstdint>

#include "acl/acl.h"
#include "simt_api/asc_bf16.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kHeadDim = 512;

__simt_vf__ __launch_bounds__(256) inline void sparse_attention_query_pack_hd512_vf(
    __gm__ const float* query,
    __gm__ bfloat16_t* query_tile,
    int64_t batch_size,
    int64_t query_heads,
    int64_t current_query,
    int64_t query_query_stride,
    int64_t query_query_offset) {
  const int64_t total_elements =
      batch_size * query_heads * current_query * kHeadDim;
  for (int64_t linear_index = blockIdx.x * blockDim.x + threadIdx.x;
       linear_index < total_elements;
       linear_index += gridDim.x * blockDim.x) {
    const int64_t dim_index = linear_index % kHeadDim;
    const int64_t query_index = (linear_index / kHeadDim) % current_query;
    const int64_t head_batch_index = linear_index / (current_query * kHeadDim);
    const int64_t source_offset =
        (head_batch_index * query_query_stride + query_query_offset + query_index) *
            kHeadDim +
        dim_index;
    query_tile[linear_index] = static_cast<bfloat16_t>(query[source_offset]);
  }
}

__global__ __vector__ void sparse_attention_query_pack_hd512_kernel(
    __gm__ const float* query,
    __gm__ bfloat16_t* query_tile,
    int64_t batch_size,
    int64_t query_heads,
    int64_t current_query,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t block_x,
    int64_t block_y) {
  asc_vf_call<sparse_attention_query_pack_hd512_vf>(
      dim3(block_x, block_y),
      query,
      query_tile,
      batch_size,
      query_heads,
      current_query,
      query_query_stride,
      query_query_offset);
}

} // namespace

extern "C" void launch_sparse_attention_query_pack_hd512_float(
    const float* query,
    bfloat16_t* query_tile,
    int64_t batch_size,
    int64_t query_heads,
    int64_t current_query,
    int64_t query_query_stride,
    int64_t query_query_offset,
    aclrtStream stream) {
  constexpr uint32_t kThreadsPerBlock = 256;
  constexpr uint32_t kMaxBlocks = 256;
  uint32_t blocks_per_grid =
      static_cast<uint32_t>(
          (batch_size * query_heads * current_query * kHeadDim +
           kThreadsPerBlock - 1) /
          kThreadsPerBlock);
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }

  sparse_attention_query_pack_hd512_kernel
      <<<blocks_per_grid, 0, stream>>>(
          query,
          query_tile,
          batch_size,
          query_heads,
          current_query,
          query_query_stride,
          query_query_offset,
          kThreadsPerBlock,
          1);
}
