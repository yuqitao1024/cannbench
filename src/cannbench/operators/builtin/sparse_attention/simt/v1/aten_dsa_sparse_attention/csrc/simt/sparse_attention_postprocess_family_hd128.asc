#include <cstdint>
#include <limits>
#include <math.h>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kHeadDim = 128;
constexpr int32_t kWarpSize = 32;

template <typename T>
struct Add {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a + b;
  }
};

template <typename T>
struct Max {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a < b ? b : a;
  }
};

template <typename T>
__simt_callee__ inline T fast_warp_reduce_sum(T val) {
#pragma unroll
  for (int32_t offset = kWarpSize / 2; offset > 0; offset >>= 1) {
    val += asc_shfl_down(val, static_cast<uint32_t>(offset), kWarpSize);
  }
  return val;
}

template <typename T>
__simt_callee__ inline T fast_warp_reduce_max(T val) {
#pragma unroll
  for (int32_t offset = kWarpSize / 2; offset > 0; offset >>= 1) {
    val = Max<T>()(val, asc_shfl_down(val, static_cast<uint32_t>(offset), kWarpSize));
  }
  return val;
}

template <typename T, template <typename> class ReduceOp>
__simt_callee__ inline T fast_block_reduce_warp(
    __ubuf__ T* shared,
    T val,
    T identity) {
  const int32_t lane = threadIdx.x % kWarpSize;
  const int32_t warp = threadIdx.x / kWarpSize;

  if constexpr (std::is_same_v<ReduceOp<T>, Add<T>>) {
    val = fast_warp_reduce_sum(val);
  } else {
    val = fast_warp_reduce_max(val);
  }

  __syncthreads();
  if (lane == 0) {
    shared[warp] = val;
  }
  __syncthreads();

  T block_val = identity;
  if (warp == 0) {
    const int32_t warps_per_block = blockDim.x / kWarpSize;
    block_val = lane < warps_per_block ? shared[lane] : identity;
    if constexpr (std::is_same_v<ReduceOp<T>, Add<T>>) {
      block_val = fast_warp_reduce_sum(block_val);
    } else {
      block_val = fast_warp_reduce_max(block_val);
    }
    if (lane == 0) {
      shared[0] = block_val;
    }
  }
  __syncthreads();
  return shared[0];
}

__simt_vf__ __launch_bounds__(128) inline void sparse_attention_postprocess_family_hd128_decode_direct_vf(
    __gm__ const float* scores,
    __gm__ const bfloat16_t* values,
    __gm__ const int32_t* indices,
    __gm__ float* output,
    __gm__ float* lse,
    int32_t batch_size,
    int32_t query_heads,
    int32_t query_tokens,
    int32_t context_tokens,
    int32_t selected_tokens,
    int32_t indices_query_stride,
    int32_t indices_query_offset,
    int32_t indices_selected_stride,
    int32_t indices_selected_offset,
    int32_t output_query_stride,
    int32_t output_query_offset,
    float score_scale,
    int32_t query_start,
    bool causal,
    __ubuf__ uint32_t* dynamicStartUB) {
  auto reduce_shared = (__ubuf__ float*)dynamicStartUB;

  for (int64_t linear_index = blockIdx.x;
       linear_index < static_cast<int64_t>(batch_size) * query_heads * query_tokens;
       linear_index += gridDim.x) {
    const int32_t query_index = static_cast<int32_t>(linear_index % query_tokens);
    const int64_t row_index = linear_index / query_tokens;
    const int32_t head_index = static_cast<int32_t>(row_index % query_heads);
    const int32_t batch_index = static_cast<int32_t>(row_index / query_heads);

    const int64_t output_base =
        ((static_cast<int64_t>(batch_index) * query_heads + head_index) *
             output_query_stride +
         output_query_offset + query_index) *
        kHeadDim;
    const int64_t lse_index =
        (static_cast<int64_t>(batch_index) * query_heads + head_index) *
            output_query_stride +
        output_query_offset + query_index;
    const int64_t index_base =
        (static_cast<int64_t>(batch_index) * indices_query_stride +
         indices_query_offset + query_index) *
            indices_selected_stride +
        indices_selected_offset;
    const int64_t score_base =
        ((static_cast<int64_t>(batch_index) * query_heads + head_index) * query_tokens +
         query_index) *
        selected_tokens;
    const int64_t value_batch_base =
        static_cast<int64_t>(batch_index) * context_tokens * kHeadDim;

    float local_valid = 0.0F;
    float local_max = -std::numeric_limits<float>::infinity();
    for (int32_t selected_index = threadIdx.x; selected_index < selected_tokens;
         selected_index += blockDim.x) {
      const int32_t token_index = indices[index_base + selected_index];
      if (token_index < 0) {
        continue;
      }
      if (causal && token_index > (query_start + query_index)) {
        continue;
      }
      const float score = scores[score_base + selected_index] * score_scale;
      local_valid = 1.0F;
      local_max = Max<float>()(local_max, score);
    }

    const float valid_count = fast_block_reduce_warp<float, Add>(
        reduce_shared,
        local_valid,
        0.0F);
    if (valid_count == 0.0F) {
      for (int32_t dim_index = threadIdx.x; dim_index < kHeadDim; dim_index += blockDim.x) {
        output[output_base + dim_index] = 0.0F;
      }
      if (threadIdx.x == 0) {
        lse[lse_index] = -std::numeric_limits<float>::infinity();
      }
      continue;
    }

    const float max_score = fast_block_reduce_warp<float, Max>(
        reduce_shared,
        local_max,
        -std::numeric_limits<float>::infinity());

    float local_sum_exp = 0.0F;
    for (int32_t selected_index = threadIdx.x; selected_index < selected_tokens;
         selected_index += blockDim.x) {
      const int32_t token_index = indices[index_base + selected_index];
      if (token_index < 0) {
        continue;
      }
      if (causal && token_index > (query_start + query_index)) {
        continue;
      }
      const float score = scores[score_base + selected_index] * score_scale;
      local_sum_exp += __expf(score - max_score);
    }

    const float sum_exp = fast_block_reduce_warp<float, Add>(
        reduce_shared,
        local_sum_exp,
        0.0F);
    const float inv_sum = sum_exp > 0.0F ? 1.0F / sum_exp : 0.0F;

    for (int32_t dim_index = threadIdx.x; dim_index < kHeadDim; dim_index += blockDim.x) {
      float weighted_output = 0.0F;
      for (int32_t selected_index = 0; selected_index < selected_tokens; ++selected_index) {
        const int32_t token_index = indices[index_base + selected_index];
        if (token_index < 0 || (causal && token_index > (query_start + query_index))) {
          continue;
        }
        const float score = scores[score_base + selected_index] * score_scale;
        const float probability = __expf(score - max_score) * inv_sum;
        weighted_output +=
            probability *
            static_cast<float>(
                values[value_batch_base +
                       static_cast<int64_t>(token_index) * kHeadDim + dim_index]);
      }
      output[output_base + dim_index] = weighted_output;
    }
    if (threadIdx.x == 0) {
      lse[lse_index] = max_score + logf(sum_exp);
    }
  }
}

__global__ __vector__ void sparse_attention_postprocess_family_hd128_decode_direct_kernel(
    __gm__ const float* scores,
    __gm__ const bfloat16_t* values,
    __gm__ const int32_t* indices,
    __gm__ float* output,
    __gm__ float* lse,
    int32_t batch_size,
    int32_t query_heads,
    int32_t query_tokens,
    int32_t context_tokens,
    int32_t selected_tokens,
    int32_t indices_query_stride,
    int32_t indices_query_offset,
    int32_t indices_selected_stride,
    int32_t indices_selected_offset,
    int32_t output_query_stride,
    int32_t output_query_offset,
    float score_scale,
    int32_t query_start,
    bool causal,
    int64_t block_x,
    int64_t block_y) {
  extern __ubuf__ uint32_t dynamicStartUB[];
  asc_vf_call<sparse_attention_postprocess_family_hd128_decode_direct_vf>(
      dim3(block_x, block_y),
      scores,
      values,
      indices,
      output,
      lse,
      batch_size,
      query_heads,
      query_tokens,
      context_tokens,
      selected_tokens,
      indices_query_stride,
      indices_query_offset,
      indices_selected_stride,
      indices_selected_offset,
      output_query_stride,
      output_query_offset,
      score_scale,
      query_start,
      causal,
      dynamicStartUB);
}

} // namespace

extern "C" void launch_sparse_attention_hd128_postprocess_decode_direct_float(
    const float* scores,
    const bfloat16_t* values,
    const int32_t* indices,
    float* output,
    float* lse,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t context_tokens,
    int64_t selected_tokens,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t output_query_stride,
    int64_t output_query_offset,
    float score_scale,
    int64_t query_start,
    bool causal,
    aclrtStream stream) {
  constexpr uint32_t kThreadsPerBlock = 128;
  constexpr uint32_t kMaxBlocks = 256;
  constexpr uint32_t kWarpsPerBlock = kThreadsPerBlock / kWarpSize;
  const uint32_t dynamic_ubuf_bytes = kWarpsPerBlock * sizeof(float);

  uint32_t blocks_per_grid =
      static_cast<uint32_t>(batch_size * query_heads * query_tokens);
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }

  sparse_attention_postprocess_family_hd128_decode_direct_kernel
      <<<blocks_per_grid, dynamic_ubuf_bytes, stream>>>(
          scores,
          values,
          indices,
          output,
          lse,
          static_cast<int32_t>(batch_size),
          static_cast<int32_t>(query_heads),
          static_cast<int32_t>(query_tokens),
          static_cast<int32_t>(context_tokens),
          static_cast<int32_t>(selected_tokens),
          static_cast<int32_t>(indices_query_stride),
          static_cast<int32_t>(indices_query_offset),
          static_cast<int32_t>(indices_selected_stride),
          static_cast<int32_t>(indices_selected_offset),
          static_cast<int32_t>(output_query_stride),
          static_cast<int32_t>(output_query_offset),
          score_scale,
          static_cast<int32_t>(query_start),
          causal,
          kThreadsPerBlock,
          1);
}
