#include <cstdint>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kHeadDim = 512;

__simt_vf__ __launch_bounds__(256) inline void sparse_attention_score_family_hd512_vf(
    __gm__ const float* query,
    __gm__ const float* selected_keys,
    __gm__ float* scores,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    float scale) {
  const int64_t total_rows = batch_size * query_heads * query_tokens;
  for (int64_t linear_row = blockIdx.x; linear_row < total_rows; linear_row += gridDim.x) {
    const int64_t query_base = linear_row * kHeadDim;
    const int64_t key_base = linear_row * selected_tokens * kHeadDim;
    const int64_t score_base = linear_row * selected_tokens;
    for (int64_t selected_index = threadIdx.x; selected_index < selected_tokens;
         selected_index += blockDim.x) {
      float dot = 0.0F;
      const int64_t key_offset = key_base + selected_index * kHeadDim;
      for (int64_t dim_index = 0; dim_index < kHeadDim; ++dim_index) {
        dot += query[query_base + dim_index] * selected_keys[key_offset + dim_index];
      }
      scores[score_base + selected_index] = dot * scale;
    }
  }
}

__global__ __vector__ void sparse_attention_score_family_hd512_kernel(
    __gm__ const float* query,
    __gm__ const float* selected_keys,
    __gm__ float* scores,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    float scale,
    int64_t block_x,
    int64_t block_y) {
  asc_vf_call<sparse_attention_score_family_hd512_vf>(
      dim3(block_x, block_y),
      query,
      selected_keys,
      scores,
      batch_size,
      query_heads,
      query_tokens,
      selected_tokens,
      scale);
}

} // namespace

extern "C" void launch_sparse_attention_score_hd512_float(
    const float* query,
    const float* selected_keys,
    float* scores,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    float scale,
    aclrtStream stream) {
  constexpr uint32_t kThreadsPerBlock = 256;
  constexpr uint32_t kMaxBlocks = 256;
  uint32_t blocks_per_grid =
      static_cast<uint32_t>(batch_size * query_heads * query_tokens);
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }

  sparse_attention_score_family_hd512_kernel
      <<<blocks_per_grid, 0, stream>>>(
          query,
          selected_keys,
          scores,
          batch_size,
          query_heads,
          query_tokens,
          selected_tokens,
          scale,
          kThreadsPerBlock,
          1);
}
