#include <cstdint>

#include "acl/acl.h"
#include "basic_api/kernel_basic_intf.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "c_api/asc_simd.h"
#include "kernel_operator.h"
#include "tensor_api/tensor.h"

namespace {

using namespace AscendC::Te;

constexpr int32_t kHeadDim = 512;
constexpr int32_t kBaseN = 64;
constexpr int32_t kBaseK = 64;
constexpr uint32_t kGatherKeysL1Offset = 64 * 1024;
constexpr uint8_t kGatherKeysReadyFlag = 9;

struct SparseAttentionScoreHd512Shape {
  int32_t used_core_num;
  int32_t m;
  int32_t n;
  int32_t k;
  int32_t single_core_m;
  int32_t single_core_n;
  int32_t single_core_k;
};

struct SparseAttentionScoreHd512GemvTrait {
  using TraitType = MmadTrait;
  static constexpr const TraitType value =
      MmadTrait(0, false, false, false, MmadType::NORMAL);
};

__aicore__ inline void copy_shape(
    SparseAttentionScoreHd512Shape* shape,
    __gm__ uint8_t* tiling_gm) {
  auto dst = reinterpret_cast<uint32_t*>(shape);
  auto src = reinterpret_cast<__gm__ uint32_t*>(tiling_gm);
  for (uint32_t i = 0; i < sizeof(SparseAttentionScoreHd512Shape) / sizeof(uint32_t); ++i) {
    dst[i] = src[i];
  }
}

__aicore__ inline void sparse_attention_score_family_hd512_aic(
    __gm__ half* query,
    __gm__ half* selected_keys,
    __gm__ float* scores,
    __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm) {
  (void)workspace;
  AscendC::InitSocState();

  SparseAttentionScoreHd512Shape shape;
  copy_shape(&shape, tiling_gm);
  if (AscendC::GetBlockIdx() >= static_cast<uint32_t>(shape.used_core_num)) {
    return;
  }

  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);
  const uint32_t k_loop =
      static_cast<uint32_t>((shape.k + kBaseK - 1) / kBaseK);

  auto gm_query = MakeTensor(
      MakeMemPtr(query), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.k));
  auto gm_keys = MakeTensor(
      MakeMemPtr(selected_keys), MakeFrameLayout<DNExtLayoutPtn>(shape.k, shape.n));
  auto gm_scores = MakeTensor(
      MakeMemPtr(scores), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.n));

  __cbuf__ half l1_query_buf[kBaseK];
  __cbuf__ half l1_keys_buf[kBaseK * kBaseN];
  __ca__ half l0_query_buf[kBaseK];
  __cb__ half l0_keys_buf[kBaseK * kBaseN];
  __cc__ float l0_scores_buf[16 * kBaseN];

  auto copy_gm_to_l1 = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
  auto copy_l1_to_l0a = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
  auto copy_l1_to_l0b = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
  auto copy_l0c_to_gm = MakeCopy(CopyL0C2GM{}, CopyL0C2GMTraitDefault{});
  auto mm = MakeMmad(MmadOperation{}, SparseAttentionScoreHd512GemvTrait{});

  AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
  AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
  AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);

  for (uint32_t n_index = 0; n_index < n_loop; ++n_index) {
    const uint16_t cur_n = static_cast<uint16_t>(
        n_index + 1 == n_loop ? shape.n - static_cast<int32_t>(n_index) * kBaseN : kBaseN);
    auto l0_scores = MakeTensor(
        MakeMemPtr(l0_scores_buf), MakeFrameLayout<NZLayoutPtn>(shape.m, cur_n));
    auto gm_score_tile = gm_scores.Slice(
        MakeCoord(0, static_cast<int32_t>(n_index) * kBaseN),
        MakeShape(shape.m, cur_n));

    for (uint32_t k_index = 0; k_index < k_loop; ++k_index) {
      const uint16_t cur_k = static_cast<uint16_t>(
          k_index + 1 == k_loop ? shape.k - static_cast<int32_t>(k_index) * kBaseK : kBaseK);
      auto l1_query_nd = MakeTensor(
          MakeMemPtr(l1_query_buf), MakeFrameLayout<NDExtLayoutPtn>(shape.m, cur_k));
      auto l1_query_nz = MakeTensor(
          l1_query_nd.Data(),
          MakeFrameLayout<NZLayoutPtn, half>(cur_k / C0_ELEMENT<half>, C0_ELEMENT<half>));
      auto l0_query = MakeTensor(
          MakeMemPtr(l0_query_buf),
          MakeFrameLayout<NZLayoutPtn, half>(cur_k / C0_ELEMENT<half>, C0_ELEMENT<half>));
      auto l1_keys = MakeTensor(
          MakeMemPtr(l1_keys_buf), MakeFrameLayout<ZNLayoutPtn, half>(cur_k, cur_n));
      auto l0_keys = MakeTensor(
          MakeMemPtr(l0_keys_buf), MakeFrameLayout<ZNLayoutPtn, half>(cur_k, cur_n));
      auto gm_query_tile = gm_query.Slice(
          MakeCoord(0, static_cast<int32_t>(k_index) * kBaseK),
          MakeShape(shape.m, cur_k));
      auto gm_key_tile = gm_keys.Slice(
          MakeCoord(static_cast<int32_t>(k_index) * kBaseK, static_cast<int32_t>(n_index) * kBaseN),
          MakeShape(cur_k, cur_n));

      AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
      Copy(copy_gm_to_l1, l1_query_nd, gm_query_tile);
      Copy(copy_gm_to_l1, l1_keys, gm_key_tile);
      AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
      AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

      AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
      Copy(copy_l1_to_l0a, l0_query, l1_query_nz);
      Copy(copy_l1_to_l0b, l0_keys, l1_keys);
      AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
      AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);

      if (k_index == 0) {
        AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
      }
      MmadParams params{
          static_cast<uint16_t>(shape.m),
          cur_n,
          cur_k,
          0,
          k_index == 0,
      };
      Mmad(mm.with(params), l0_scores, l0_query, l0_keys);

      if (k_index + 1 == k_loop) {
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
      }
      AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
      AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
    }

    AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
    Copy(copy_l0c_to_gm, gm_score_tile, l0_scores);
    AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  }

  AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
  AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
  AscendC::PipeBarrier<PIPE_ALL>();
}

__global__ __aicore__ void sparse_attention_score_family_hd512_kernel(
    __gm__ half* query,
    __gm__ half* selected_keys,
    __gm__ float* scores,
    __kfc_workspace__ __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm) {
  KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIC_1_2);
  if ASCEND_IS_AIC {
    sparse_attention_score_family_hd512_aic(
        query, selected_keys, scores, workspace, tiling_gm);
  }
}

__aicore__ inline uint32_t zn_offset_hd512(
    uint32_t dim_offset,
    uint32_t selected_index,
    uint32_t selected_count) {
  constexpr uint32_t kC0 = 16;
  const uint32_t aligned_selected = ((selected_count + kC0 - 1) / kC0) * kC0;
  return (dim_offset / kC0) * kC0 * aligned_selected +
      (selected_index / kC0) * kC0 * kC0 +
      (selected_index % kC0) * kC0 +
      (dim_offset % kC0);
}

__aicore__ inline void sparse_attention_score_gather_family_hd512_aic(
    __gm__ half* query,
    __gm__ const float* keys,
    __gm__ const int32_t* indices,
    __gm__ float* scores,
    __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm) {
  (void)keys;
  (void)indices;
  (void)workspace;
  AscendC::InitSocState();

  SparseAttentionScoreHd512Shape shape;
  copy_shape(&shape, tiling_gm);
  if (AscendC::GetBlockIdx() >= static_cast<uint32_t>(shape.used_core_num)) {
    return;
  }

  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);
  const uint32_t k_loop =
      static_cast<uint32_t>((shape.k + kBaseK - 1) / kBaseK);

  auto gm_query = MakeTensor(
      MakeMemPtr(query), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.k));
  auto gm_scores = MakeTensor(
      MakeMemPtr(scores), MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.n));

  __cbuf__ half l1_query_buf[kBaseK];
  __ca__ half l0_query_buf[kBaseK];
  __cb__ half l0_keys_buf[kBaseK * kBaseN];
  __cc__ float l0_scores_buf[16 * kBaseN];
  AscendC::LocalTensor<half> l1_keys_tensor(
      AscendC::TPosition::TSCM,
      kGatherKeysL1Offset,
      kBaseK * kBaseN);

  auto copy_gm_to_l1 = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
  auto copy_l1_to_l0a = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
  auto copy_l1_to_l0b = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
  auto copy_l0c_to_gm = MakeCopy(CopyL0C2GM{}, CopyL0C2GMTraitDefault{});
  auto mm = MakeMmad(MmadOperation{}, SparseAttentionScoreHd512GemvTrait{});

  AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
  AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
  AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  AscendC::CrossCoreSetFlag<2, PIPE_MTE1>(kGatherKeysReadyFlag);

  for (uint32_t n_index = 0; n_index < n_loop; ++n_index) {
    const uint16_t cur_n = static_cast<uint16_t>(
        n_index + 1 == n_loop ? shape.n - static_cast<int32_t>(n_index) * kBaseN : kBaseN);
    auto l0_scores = MakeTensor(
        MakeMemPtr(l0_scores_buf), MakeFrameLayout<NZLayoutPtn>(shape.m, cur_n));
    auto gm_score_tile = gm_scores.Slice(
        MakeCoord(0, static_cast<int32_t>(n_index) * kBaseN),
        MakeShape(shape.m, cur_n));

    for (uint32_t k_index = 0; k_index < k_loop; ++k_index) {
      const uint16_t cur_k = static_cast<uint16_t>(
          k_index + 1 == k_loop ? shape.k - static_cast<int32_t>(k_index) * kBaseK : kBaseK);
      auto l1_query_nd = MakeTensor(
          MakeMemPtr(l1_query_buf), MakeFrameLayout<NDExtLayoutPtn>(shape.m, cur_k));
      auto l1_query_nz = MakeTensor(
          l1_query_nd.Data(),
          MakeFrameLayout<NZLayoutPtn, half>(cur_k / C0_ELEMENT<half>, C0_ELEMENT<half>));
      auto l0_query = MakeTensor(
          MakeMemPtr(l0_query_buf),
          MakeFrameLayout<NZLayoutPtn, half>(cur_k / C0_ELEMENT<half>, C0_ELEMENT<half>));
      auto l1_keys = MakeTensor(
          MakeMemPtr(reinterpret_cast<__cbuf__ half*>(l1_keys_tensor.GetPhyAddr())),
          MakeFrameLayout<ZNLayoutPtn, half>(cur_k, cur_n));
      auto l0_keys = MakeTensor(
          MakeMemPtr(l0_keys_buf), MakeFrameLayout<ZNLayoutPtn, half>(cur_k, cur_n));
      auto gm_query_tile = gm_query.Slice(
          MakeCoord(0, static_cast<int32_t>(k_index) * kBaseK),
          MakeShape(shape.m, cur_k));

      AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
      Copy(copy_gm_to_l1, l1_query_nd, gm_query_tile);
      AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
      AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

      AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
      AscendC::CrossCoreWaitFlag<2, PIPE_MTE1>(kGatherKeysReadyFlag);
      Copy(copy_l1_to_l0a, l0_query, l1_query_nz);
      Copy(copy_l1_to_l0b, l0_keys, l1_keys);
      AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
      AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);

      if (k_index == 0) {
        AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
      }
      MmadParams params{
          static_cast<uint16_t>(shape.m),
          cur_n,
          cur_k,
          0,
          k_index == 0,
      };
      Mmad(mm.with(params), l0_scores, l0_query, l0_keys);

      if (k_index + 1 == k_loop) {
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
      }
      AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
      AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
      AscendC::CrossCoreSetFlag<2, PIPE_MTE1>(kGatherKeysReadyFlag);
    }

    AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
    Copy(copy_l0c_to_gm, gm_score_tile, l0_scores);
    AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  }

  AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
  AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
  AscendC::PipeBarrier<PIPE_ALL>();
}

__aicore__ inline void sparse_attention_score_gather_family_hd512_aiv(
    __gm__ half* query,
    __gm__ const float* keys,
    __gm__ const int32_t* indices,
    __gm__ float* scores,
    __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm) {
  (void)query;
  (void)scores;
  (void)workspace;

  SparseAttentionScoreHd512Shape shape;
  copy_shape(&shape, tiling_gm);
  if (AscendC::GetBlockIdx() >= static_cast<uint32_t>(shape.used_core_num * 2)) {
    return;
  }

  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);
  const uint32_t k_loop =
      static_cast<uint32_t>((shape.k + kBaseK - 1) / kBaseK);

  AscendC::LocalTensor<half> l1_keys_tensor(
      AscendC::TPosition::TSCM,
      kGatherKeysL1Offset,
      kBaseK * kBaseN);
  __ubuf__ half ub_keys_buf[kBaseK * kBaseN];
  auto copy_ub_to_l1 = MakeCopy(CopyUB2L1{}, CopyUB2L1TraitDefault{});

  for (uint32_t n_index = 0; n_index < n_loop; ++n_index) {
    const uint16_t cur_n = static_cast<uint16_t>(
        n_index + 1 == n_loop ? shape.n - static_cast<int32_t>(n_index) * kBaseN : kBaseN);
    for (uint32_t k_index = 0; k_index < k_loop; ++k_index) {
      const uint16_t cur_k = static_cast<uint16_t>(
          k_index + 1 == k_loop ? shape.k - static_cast<int32_t>(k_index) * kBaseK : kBaseK);
      AscendC::CrossCoreWaitFlag<2, PIPE_MTE3>(kGatherKeysReadyFlag);
      auto ub_keys = MakeTensor(
          MakeMemPtr(ub_keys_buf), MakeFrameLayout<ZNLayoutPtn, half>(cur_k, cur_n));
      auto l1_keys = MakeTensor(
          MakeMemPtr(reinterpret_cast<__cbuf__ half*>(l1_keys_tensor.GetPhyAddr())),
          MakeFrameLayout<ZNLayoutPtn, half>(cur_k, cur_n));
      for (uint32_t selected_index = 0; selected_index < static_cast<uint32_t>(cur_n);
           ++selected_index) {
        const int32_t context_index = indices[n_index * kBaseN + selected_index];
        for (uint32_t dim_offset = 0; dim_offset < static_cast<uint32_t>(cur_k); ++dim_offset) {
          const uint32_t dim_index = k_index * kBaseK + dim_offset;
          const uint32_t dst_offset =
              zn_offset_hd512(dim_offset, selected_index, static_cast<uint32_t>(cur_n));
          ub_keys_buf[dst_offset] =
              static_cast<half>(keys[static_cast<int64_t>(context_index) * kHeadDim + dim_index]);
        }
      }
      Copy(copy_ub_to_l1, l1_keys, ub_keys);
      AscendC::CrossCoreSetFlag<2, PIPE_MTE3>(kGatherKeysReadyFlag);
    }
  }
}

__global__ __aicore__ void sparse_attention_score_gather_family_hd512_kernel(
    __gm__ half* query,
    __gm__ const float* keys,
    __gm__ const int32_t* indices,
    __gm__ float* scores,
    __kfc_workspace__ __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm) {
  KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIC_1_2);
  if ASCEND_IS_AIC {
    sparse_attention_score_gather_family_hd512_aic(
        query, keys, indices, scores, workspace, tiling_gm);
  } else if ASCEND_IS_AIV {
    sparse_attention_score_gather_family_hd512_aiv(
        query, keys, indices, scores, workspace, tiling_gm);
  }
}

} // namespace

extern "C" void launch_sparse_attention_score_hd512_float(
    const half* query,
    const half* selected_keys,
    float* scores,
    uint8_t* workspace,
    uint8_t* tiling,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t score_stride,
    int64_t score_offset,
    aclrtStream stream) {
  const int64_t total_rows = batch_size * query_heads * query_tokens;
  const int64_t selected_keys_stride = selected_tokens * kHeadDim;
  SparseAttentionScoreHd512Shape shape = {
      1,
      1,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
      1,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
  };
  aclrtMemcpyAsync(
      tiling,
      sizeof(shape),
      &shape,
      sizeof(shape),
      ACL_MEMCPY_HOST_TO_DEVICE,
      stream);
  for (int64_t row_index = 0; row_index < total_rows; ++row_index) {
    const int64_t head_row = row_index / query_tokens;
    const int64_t query_row = row_index % query_tokens;
    sparse_attention_score_family_hd512_kernel<<<shape.used_core_num, 0, stream>>>(
        const_cast<half*>(query) +
            (head_row * query_query_stride + query_query_offset + query_row) * kHeadDim,
        const_cast<half*>(selected_keys) + row_index * selected_keys_stride,
        scores + row_index * score_stride + score_offset,
        workspace,
        tiling);
  }
}

extern "C" void launch_sparse_attention_score_gather_hd512_float(
    const half* query,
    const float* keys,
    const int32_t* indices,
    float* scores,
    uint8_t* workspace,
    uint8_t* tiling,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t context_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t score_stride,
    int64_t score_offset,
    aclrtStream stream) {
  const int64_t total_rows = batch_size * query_heads * query_tokens;
  SparseAttentionScoreHd512Shape shape = {
      1,
      1,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
      1,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
  };
  aclrtMemcpyAsync(
      tiling,
      sizeof(shape),
      &shape,
      sizeof(shape),
      ACL_MEMCPY_HOST_TO_DEVICE,
      stream);
  for (int64_t row_index = 0; row_index < total_rows; ++row_index) {
    const int64_t head_row = row_index / query_tokens;
    const int64_t query_row = row_index % query_tokens;
    const int64_t batch_index = head_row / query_heads;
    const int64_t key_offset = batch_index * context_tokens * kHeadDim;
    const int64_t indices_offset =
        (batch_index * indices_query_stride + indices_query_offset + query_row) *
            indices_selected_stride +
        indices_selected_offset;
    sparse_attention_score_gather_family_hd512_kernel<<<shape.used_core_num, 0, stream>>>(
        const_cast<half*>(query) +
            (head_row * query_query_stride + query_query_offset + query_row) * kHeadDim,
        keys + key_offset,
        indices + indices_offset,
        scores + row_index * score_stride + score_offset,
        workspace,
        tiling);
  }
}
