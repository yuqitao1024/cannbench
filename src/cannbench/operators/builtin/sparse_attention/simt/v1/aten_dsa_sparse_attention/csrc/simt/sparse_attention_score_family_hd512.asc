#include <cstdint>
#include <limits>
#include <math.h>

#include "acl/acl.h"
#include "basic_api/kernel_basic_intf.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "c_api/asc_simd.h"
#include "kernel_operator.h"
#include "simt_api/asc_bf16.h"
#include "simt_api/asc_simt.h"
#include "tensor_api/tensor.h"

namespace {

using namespace AscendC::Te;

constexpr int32_t kHeadDim = 512;
constexpr int32_t kBaseN = 64;
constexpr int32_t kBaseK = 64;
constexpr int32_t kSelectedTokenUpperBound = 2048;
constexpr int32_t kMaxUsedCoreNum = 11;
constexpr int32_t kFusedMaxUsedCoreNum = 5;
constexpr uint32_t kFusedPostprocessThreads = 256;
constexpr uint32_t kGatherKeysL1Offset = 64 * 1024;
constexpr uint32_t kSharedScoresUbOffset = 0;
constexpr uint32_t kSharedScoresUbEntries = kSelectedTokenUpperBound;
constexpr uint32_t kSharedScoresUbBytes = kSharedScoresUbEntries * sizeof(float);
constexpr uint32_t kGatherKeysUbOffset = kSharedScoresUbOffset + kSharedScoresUbBytes;
constexpr uint32_t kGatherKeysUbEntries = kBaseK * kBaseN;
constexpr uint8_t kGatherKeysReadyFlagBase = 0;
constexpr uint8_t kScoreTileReadyFlagBase = 5;
constexpr uint8_t kCrossCoreSyncMode = 4;
constexpr AscendC::FixpipeConfig kRowMajorUbFixpipeConfig = {
    AscendC::CO2Layout::ROW_MAJOR,
    true,
};

struct SparseAttentionScoreHd512Shape {
  int32_t used_core_num;
  int32_t m;
  int32_t n;
  int32_t k;
  int32_t single_core_m;
  int32_t single_core_n;
  int32_t single_core_k;
};

struct SparseAttentionScoreHd512GemvTrait {
  using TraitType = MmadTrait;
  static constexpr const TraitType value =
      MmadTrait(0, false, false, false, MmadType::NORMAL);
};

__aicore__ inline void copy_shape(
    SparseAttentionScoreHd512Shape* shape,
    __gm__ uint8_t* tiling_gm) {
  auto dst = reinterpret_cast<uint32_t*>(shape);
  auto src = reinterpret_cast<__gm__ uint32_t*>(tiling_gm);
  for (uint32_t i = 0; i < sizeof(SparseAttentionScoreHd512Shape) / sizeof(uint32_t); ++i) {
    dst[i] = src[i];
  }
}

template <typename T>
struct Max {
  __simt_callee__ inline T operator()(T a, T b) const {
    return a < b ? b : a;
  }
};

__aicore__ inline uint32_t zn_offset_hd512(
    uint32_t dim_offset,
    uint32_t selected_index,
    uint32_t selected_count) {
  constexpr uint32_t kC0 = 16;
  const uint32_t aligned_selected = ((selected_count + kC0 - 1) / kC0) * kC0;
  return (dim_offset / kC0) * kC0 * aligned_selected +
      (selected_index / kC0) * kC0 * kC0 +
      (selected_index % kC0) * kC0 +
      (dim_offset % kC0);
}

__aicore__ inline void sparse_attention_score_gather_family_hd512_aic(
    __gm__ bfloat16_t* query,
    __gm__ bfloat16_t* keys,
    __gm__ const int32_t* indices,
    __gm__ float* scores,
    __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm,
    int64_t row_start,
    int64_t total_rows,
    int64_t query_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t score_stride,
    int64_t score_offset) {
  (void)keys;
  (void)indices;
  (void)workspace;
  AscendC::InitSocState();

  SparseAttentionScoreHd512Shape shape;
  copy_shape(&shape, tiling_gm);
  const uint32_t block_idx = AscendC::GetBlockIdx();
  const uint16_t ready_flag =
      static_cast<uint16_t>(kGatherKeysReadyFlagBase + block_idx);
  if (block_idx >= static_cast<uint32_t>(shape.used_core_num)) {
    return;
  }

  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);
  const uint32_t k_loop =
      static_cast<uint32_t>((shape.k + kBaseK - 1) / kBaseK);

  const int64_t row_index = row_start + block_idx;
  if (row_index >= total_rows) {
    return;
  }
  const int64_t head_row = row_index / query_tokens;
  const int64_t query_row = row_index % query_tokens;
  auto gm_query = MakeTensor(
      MakeMemPtr(
          query +
          (head_row * query_query_stride + query_query_offset + query_row) * kHeadDim),
      MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.k));
  auto gm_scores = MakeTensor(
      MakeMemPtr(scores + row_index * score_stride + score_offset),
      MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.n));

  __cbuf__ bfloat16_t l1_query_buf[kBaseK];
  __ca__ bfloat16_t l0_query_buf[kBaseK];
  __cb__ bfloat16_t l0_keys_buf[kBaseK * kBaseN];
  __cc__ float l0_scores_buf[16 * kBaseN];
  AscendC::LocalTensor<bfloat16_t> l1_keys_tensor(
      AscendC::TPosition::TSCM,
      kGatherKeysL1Offset,
      kBaseK * kBaseN);

  auto copy_gm_to_l1 = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
  auto copy_l1_to_l0a = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
  auto copy_l1_to_l0b = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
  auto copy_l0c_to_gm = MakeCopy(CopyL0C2GM{}, CopyL0C2GMTraitDefault{});
  auto mm = MakeMmad(MmadOperation{}, SparseAttentionScoreHd512GemvTrait{});

  AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
  AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
  AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_MTE1>(ready_flag);

  for (uint32_t n_index = 0; n_index < n_loop; ++n_index) {
    const uint16_t cur_n = static_cast<uint16_t>(
        n_index + 1 == n_loop ? shape.n - static_cast<int32_t>(n_index) * kBaseN : kBaseN);
    auto l0_scores = MakeTensor(
        MakeMemPtr(l0_scores_buf), MakeFrameLayout<NZLayoutPtn>(shape.m, cur_n));
    auto gm_score_tile = gm_scores.Slice(
        MakeCoord(0, static_cast<int32_t>(n_index) * kBaseN),
        MakeShape(shape.m, cur_n));

    for (uint32_t k_index = 0; k_index < k_loop; ++k_index) {
      const uint16_t cur_k = static_cast<uint16_t>(
          k_index + 1 == k_loop ? shape.k - static_cast<int32_t>(k_index) * kBaseK : kBaseK);
      auto l1_query_nd = MakeTensor(
          MakeMemPtr(l1_query_buf), MakeFrameLayout<NDExtLayoutPtn>(shape.m, cur_k));
      auto l1_query_nz = MakeTensor(
          l1_query_nd.Data(),
          MakeFrameLayout<NZLayoutPtn, bfloat16_t>(
              cur_k / C0_ELEMENT<bfloat16_t>, C0_ELEMENT<bfloat16_t>));
      auto l0_query = MakeTensor(
          MakeMemPtr(l0_query_buf),
          MakeFrameLayout<NZLayoutPtn, bfloat16_t>(
              cur_k / C0_ELEMENT<bfloat16_t>, C0_ELEMENT<bfloat16_t>));
      auto l1_keys = MakeTensor(
          MakeMemPtr(reinterpret_cast<__cbuf__ bfloat16_t*>(l1_keys_tensor.GetPhyAddr())),
          MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(cur_k, cur_n));
      auto l0_keys = MakeTensor(
          MakeMemPtr(l0_keys_buf), MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(cur_k, cur_n));
      auto gm_query_tile = gm_query.Slice(
          MakeCoord(0, static_cast<int32_t>(k_index) * kBaseK),
          MakeShape(shape.m, cur_k));

      AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
      Copy(copy_gm_to_l1, l1_query_nd, gm_query_tile);
      AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
      AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

      AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
      AscendC::CrossCoreWaitFlag<kCrossCoreSyncMode, PIPE_MTE1>(ready_flag);
      Copy(copy_l1_to_l0a, l0_query, l1_query_nz);
      Copy(copy_l1_to_l0b, l0_keys, l1_keys);
      AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
      AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);

      if (k_index == 0) {
        AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
      }
      MmadParams params{
          static_cast<uint16_t>(shape.m),
          cur_n,
          cur_k,
          0,
          k_index == 0,
      };
      Mmad(mm.with(params), l0_scores, l0_query, l0_keys);

      if (k_index + 1 == k_loop) {
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
      }
      AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
      AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
      AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_MTE1>(ready_flag);
    }

    AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
    Copy(copy_l0c_to_gm, gm_score_tile, l0_scores);
    AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  }

  AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
  AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
  AscendC::PipeBarrier<PIPE_ALL>();
}

__aicore__ inline void sparse_attention_score_gather_family_hd512_aiv(
    __gm__ bfloat16_t* query,
    __gm__ bfloat16_t* keys,
    __gm__ const int32_t* indices,
    __gm__ float* scores,
    __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm,
    int64_t row_start,
    int64_t total_rows,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t context_tokens,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset) {
  (void)query;
  (void)scores;
  (void)workspace;
  if (AscendC::GetSubBlockIdx() != 0) {
    return;
  }

  SparseAttentionScoreHd512Shape shape;
  copy_shape(&shape, tiling_gm);
  const uint32_t block_idx =
      static_cast<uint32_t>(AscendC::GetBlockIdx() / AscendC::GetTaskRatio());
  const uint16_t ready_flag =
      static_cast<uint16_t>(kGatherKeysReadyFlagBase + block_idx);
  if (block_idx >= static_cast<uint32_t>(shape.used_core_num)) {
    return;
  }

  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);
  const uint32_t k_loop =
      static_cast<uint32_t>((shape.k + kBaseK - 1) / kBaseK);

  AscendC::LocalTensor<bfloat16_t> l1_keys_tensor(
      AscendC::TPosition::TSCM,
      kGatherKeysL1Offset,
      kBaseK * kBaseN);
  __ubuf__ bfloat16_t ub_keys_buf[kBaseK * kBaseN];
  auto copy_ub_to_l1 = MakeCopy(CopyUB2L1{}, CopyUB2L1TraitDefault{});

  const int64_t row_index = row_start + block_idx;
  if (row_index >= total_rows) {
    return;
  }
  const int64_t head_row = row_index / query_tokens;
  const int64_t query_row = row_index % query_tokens;
  const int64_t batch_index = head_row / query_heads;
  const int64_t key_offset = batch_index * context_tokens * kHeadDim;
  const int64_t indices_offset =
      (batch_index * indices_query_stride + indices_query_offset + query_row) *
          indices_selected_stride +
      indices_selected_offset;

  for (uint32_t n_index = 0; n_index < n_loop; ++n_index) {
    const uint16_t cur_n = static_cast<uint16_t>(
        n_index + 1 == n_loop ? shape.n - static_cast<int32_t>(n_index) * kBaseN : kBaseN);
    for (uint32_t k_index = 0; k_index < k_loop; ++k_index) {
      const uint16_t cur_k = static_cast<uint16_t>(
          k_index + 1 == k_loop ? shape.k - static_cast<int32_t>(k_index) * kBaseK : kBaseK);
      AscendC::CrossCoreWaitFlag<kCrossCoreSyncMode, PIPE_MTE3>(ready_flag);
      auto ub_keys = MakeTensor(
          MakeMemPtr(ub_keys_buf), MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(cur_k, cur_n));
      auto l1_keys = MakeTensor(
          MakeMemPtr(reinterpret_cast<__cbuf__ bfloat16_t*>(l1_keys_tensor.GetPhyAddr())),
          MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(cur_k, cur_n));
      for (uint32_t selected_index = 0; selected_index < static_cast<uint32_t>(cur_n);
           ++selected_index) {
        const int32_t context_index =
            indices[indices_offset + n_index * kBaseN + selected_index];
        for (uint32_t dim_offset = 0; dim_offset < static_cast<uint32_t>(cur_k); ++dim_offset) {
          const uint32_t dim_index = k_index * kBaseK + dim_offset;
          const uint32_t dst_offset =
              zn_offset_hd512(dim_offset, selected_index, static_cast<uint32_t>(cur_n));
          if (context_index < 0 || context_index >= context_tokens) {
            ub_keys_buf[dst_offset] = 0;
          } else {
            ub_keys_buf[dst_offset] =
                keys[key_offset + static_cast<int64_t>(context_index) * kHeadDim + dim_index];
          }
        }
      }
      Copy(copy_ub_to_l1, l1_keys, ub_keys);
      AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_MTE3>(ready_flag);
    }
  }
}

__global__ __aicore__ void sparse_attention_score_gather_family_hd512_kernel(
    __gm__ bfloat16_t* query,
    __gm__ bfloat16_t* keys,
    __gm__ const int32_t* indices,
    __gm__ float* scores,
    __kfc_workspace__ __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm,
    int64_t row_start,
    int64_t total_rows,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t context_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t score_stride,
    int64_t score_offset) {
  KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIC_1_2);
  if ASCEND_IS_AIC {
    sparse_attention_score_gather_family_hd512_aic(
        query,
        keys,
        indices,
        scores,
        workspace,
        tiling_gm,
        row_start,
        total_rows,
        query_tokens,
        query_query_stride,
        query_query_offset,
        score_stride,
        score_offset);
  } else if ASCEND_IS_AIV {
    sparse_attention_score_gather_family_hd512_aiv(
        query,
        keys,
        indices,
        scores,
        workspace,
        tiling_gm,
        row_start,
        total_rows,
        query_heads,
        query_tokens,
        context_tokens,
        indices_query_stride,
        indices_query_offset,
        indices_selected_stride,
        indices_selected_offset);
  }
}

__simt_vf__ __aicore__ __launch_bounds__(kFusedPostprocessThreads) inline void
sparse_attention_fused_family_hd512_postprocess_vf(
    __ubuf__ const float* scores,
    __gm__ bfloat16_t* values,
    __gm__ const int32_t* indices,
    __gm__ float* output,
    __gm__ float* lse,
    int64_t key_offset,
    int64_t indices_offset,
    int64_t output_base,
    int64_t lse_index,
    int32_t head_dim,
    int32_t selected_tokens,
    float score_scale,
    int64_t valid_query_limit,
    bool causal,
    __ubuf__ uint32_t* dynamicStartUB) {
  (void)dynamicStartUB;
  float has_valid = 0.0F;
  float max_score = -std::numeric_limits<float>::infinity();
  for (int32_t selected_index = 0; selected_index < selected_tokens; ++selected_index) {
    const int32_t token_index = indices[indices_offset + selected_index];
    if (token_index < 0) {
      continue;
    }
    if (causal && token_index > valid_query_limit) {
      continue;
    }
    const float score = scores[selected_index] * score_scale;
    has_valid = 1.0F;
    max_score = Max<float>()(max_score, score);
  }

  if (has_valid == 0.0F) {
    for (int32_t dim_index = threadIdx.x; dim_index < head_dim; dim_index += blockDim.x) {
      output[output_base + dim_index] = 0.0F;
    }
    if (threadIdx.x == 0) {
      lse[lse_index] = -std::numeric_limits<float>::infinity();
    }
    return;
  }

  float sum_exp = 0.0F;
  for (int32_t selected_index = 0; selected_index < selected_tokens; ++selected_index) {
    const int32_t token_index = indices[indices_offset + selected_index];
    if (token_index < 0) {
      continue;
    }
    if (causal && token_index > valid_query_limit) {
      continue;
    }
    const float score = scores[selected_index] * score_scale;
    sum_exp += __expf(score - max_score);
  }
  const float inv_sum = sum_exp > 0.0F ? 1.0F / sum_exp : 0.0F;

  for (int32_t dim_index = threadIdx.x; dim_index < head_dim; dim_index += blockDim.x) {
    float weighted_output = 0.0F;
    for (int32_t selected_index = 0; selected_index < selected_tokens; ++selected_index) {
      const int32_t token_index = indices[indices_offset + selected_index];
      if (token_index < 0) {
        continue;
      }
      if (causal && token_index > valid_query_limit) {
        continue;
      }
      const float score = scores[selected_index] * score_scale;
      weighted_output +=
          __expf(score - max_score) * inv_sum *
          static_cast<float>(
              values[key_offset + static_cast<int64_t>(token_index) * head_dim + dim_index]);
    }
    output[output_base + dim_index] = weighted_output;
  }
  if (threadIdx.x == 0) {
    lse[lse_index] = max_score + logf(sum_exp);
  }
}

__aicore__ inline void sparse_attention_fused_family_hd512_aic(
    __gm__ bfloat16_t *query, __gm__ uint8_t *tiling_gm, int64_t total_rows,
    int64_t query_tokens, int64_t selected_tokens, int64_t query_query_stride,
    int64_t query_query_offset) {
  AscendC::InitSocState();

  SparseAttentionScoreHd512Shape shape;
  copy_shape(&shape, tiling_gm);
  const int32_t head_dim = shape.k;
  const uint32_t block_idx = AscendC::GetBlockIdx();
  const uint16_t gather_ready_flag =
      static_cast<uint16_t>(kGatherKeysReadyFlagBase + block_idx);
  const uint16_t score_ready_flag =
      static_cast<uint16_t>(kScoreTileReadyFlagBase + block_idx);
  if (block_idx >= static_cast<uint32_t>(shape.used_core_num)) {
    return;
  }

  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);
  const uint32_t k_loop =
      static_cast<uint32_t>((shape.k + kBaseK - 1) / kBaseK);

  __cbuf__ bfloat16_t l1_query_buf[kBaseK];
  __ca__ bfloat16_t l0_query_buf[kBaseK];
  __cb__ bfloat16_t l0_keys_buf[kBaseK * kBaseN];
  __cc__ float l0_scores_buf[16 * kBaseN];
  AscendC::LocalTensor<bfloat16_t> l1_keys_tensor(
      AscendC::TPosition::TSCM, kGatherKeysL1Offset, kBaseK * kBaseN);
  AscendC::LocalTensor<float> l0_scores_tensor(AscendC::TPosition::CO1, 0,
                                               16 * kBaseN);

  auto copy_gm_to_l1 = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
  auto copy_l1_to_l0a = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
  auto copy_l1_to_l0b = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
  auto mm = MakeMmad(MmadOperation{}, SparseAttentionScoreHd512GemvTrait{});

  AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
  AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
  AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_MTE1>(gather_ready_flag);

  for (int64_t row_index = static_cast<int64_t>(block_idx);
       row_index < total_rows; row_index += shape.used_core_num) {
    const int64_t head_row = row_index / query_tokens;
    const int64_t query_row = row_index % query_tokens;
    auto gm_query =
        MakeTensor(MakeMemPtr(query + (head_row * query_query_stride +
                                       query_query_offset + query_row) *
                                          head_dim),
                   MakeFrameLayout<NDExtLayoutPtn>(shape.m, shape.k));

    for (uint32_t n_index = 0; n_index < n_loop; ++n_index) {
      const uint16_t cur_n = static_cast<uint16_t>(
          n_index + 1 == n_loop
              ? shape.n - static_cast<int32_t>(n_index) * kBaseN
              : kBaseN);
      auto l0_scores = MakeTensor(MakeMemPtr(l0_scores_buf),
                                  MakeFrameLayout<NZLayoutPtn>(shape.m, cur_n));

      for (uint32_t k_index = 0; k_index < k_loop; ++k_index) {
        const uint16_t cur_k = static_cast<uint16_t>(
            k_index + 1 == k_loop
                ? shape.k - static_cast<int32_t>(k_index) * kBaseK
                : kBaseK);
        auto l1_query_nd =
            MakeTensor(MakeMemPtr(l1_query_buf),
                       MakeFrameLayout<NDExtLayoutPtn>(shape.m, cur_k));
        auto l1_query_nz = MakeTensor(
            l1_query_nd.Data(),
            MakeFrameLayout<NZLayoutPtn, bfloat16_t>(
                cur_k / C0_ELEMENT<bfloat16_t>, C0_ELEMENT<bfloat16_t>));
        auto l0_query = MakeTensor(
            MakeMemPtr(l0_query_buf),
            MakeFrameLayout<NZLayoutPtn, bfloat16_t>(
                cur_k / C0_ELEMENT<bfloat16_t>, C0_ELEMENT<bfloat16_t>));
        auto l1_keys =
            MakeTensor(MakeMemPtr(reinterpret_cast<__cbuf__ bfloat16_t *>(
                           l1_keys_tensor.GetPhyAddr())),
                       MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(cur_k, cur_n));
        auto l0_keys =
            MakeTensor(MakeMemPtr(l0_keys_buf),
                       MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(cur_k, cur_n));
        auto gm_query_tile =
            gm_query.Slice(MakeCoord(0, static_cast<int32_t>(k_index) * kBaseK),
                           MakeShape(shape.m, cur_k));

        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        Copy(copy_gm_to_l1, l1_query_nd, gm_query_tile);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
        AscendC::CrossCoreWaitFlag<kCrossCoreSyncMode, PIPE_MTE1>(
            gather_ready_flag);
        Copy(copy_l1_to_l0a, l0_query, l1_query_nz);
        Copy(copy_l1_to_l0b, l0_keys, l1_keys);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);

        if (k_index == 0) {
          AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
        }
        MmadParams params{
            static_cast<uint16_t>(shape.m), cur_n, cur_k, 0, k_index == 0,
        };
        Mmad(mm.with(params), l0_scores, l0_query, l0_keys);

        if (k_index + 1 == k_loop) {
          AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        }
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_MTE1>(
            gather_ready_flag);
      }

      AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
      AscendC::CrossCoreWaitFlag<kCrossCoreSyncMode, PIPE_FIX>(score_ready_flag);
      AscendC::LocalTensor<float> shared_scores_tile_tensor(
          AscendC::TPosition::LCM,
          kSharedScoresUbOffset + n_index * kBaseN * sizeof(float), kBaseN);
      AscendC::FixpipeParamsC310<AscendC::CO2Layout::ROW_MAJOR> fixpipe_params;
      fixpipe_params.nSize = ((static_cast<uint32_t>(cur_n) + 7U) / 8U) * 8U;
      fixpipe_params.mSize = 1;
      fixpipe_params.srcStride = 16;
      fixpipe_params.dstStride =
          ((static_cast<uint32_t>(cur_n) + 15U) / 16U) * 16U;
      fixpipe_params.dualDstCtl = 0;
      fixpipe_params.subBlockId = false;
      fixpipe_params.unitFlag = 0;
      AscendC::Fixpipe<float, float, kRowMajorUbFixpipeConfig>(
          shared_scores_tile_tensor, l0_scores_tensor, fixpipe_params);
      AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
      AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_FIX>(score_ready_flag);
    }
  }

  AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
  AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
  AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
  AscendC::PipeBarrier<PIPE_ALL>();
}

__aicore__ inline void sparse_attention_fused_family_hd512_aiv(
    __gm__ bfloat16_t *keys, __gm__ bfloat16_t *values,
    __gm__ const int32_t *indices, __gm__ float *output, __gm__ float *lse,
    int64_t query_heads, int64_t query_tokens, int64_t selected_tokens,
    int64_t context_tokens, int64_t total_rows, int64_t indices_query_stride,
    int64_t indices_query_offset, int64_t indices_selected_stride,
    int64_t indices_selected_offset, int64_t output_query_stride,
    int64_t output_query_offset, float score_scale, int64_t query_start,
    bool causal, __gm__ uint8_t *tiling_gm) {
  AscendC::InitSocState();
  if (AscendC::GetSubBlockIdx() != 0) {
    return;
  }

  SparseAttentionScoreHd512Shape shape;
  copy_shape(&shape, tiling_gm);
  const int32_t head_dim = shape.k;
  const uint32_t block_idx =
      static_cast<uint32_t>(AscendC::GetBlockIdx() / AscendC::GetTaskRatio());
  const uint16_t gather_ready_flag =
      static_cast<uint16_t>(kGatherKeysReadyFlagBase + block_idx);
  const uint16_t score_ready_flag =
      static_cast<uint16_t>(kScoreTileReadyFlagBase + block_idx);
  if (block_idx >= static_cast<uint32_t>(shape.used_core_num)) {
    return;
  }

  const uint32_t n_loop =
      static_cast<uint32_t>((shape.n + kBaseN - 1) / kBaseN);
  const uint32_t k_loop =
      static_cast<uint32_t>((shape.k + kBaseK - 1) / kBaseK);

  AscendC::LocalTensor<bfloat16_t> l1_keys_tensor(
      AscendC::TPosition::TSCM, kGatherKeysL1Offset, kBaseK * kBaseN);
  AscendC::LocalTensor<float> shared_scores_tensor(
      AscendC::TPosition::LCM, kSharedScoresUbOffset, kSharedScoresUbEntries);
  AscendC::LocalTensor<bfloat16_t> ub_keys_tensor(
      AscendC::TPosition::LCM, kGatherKeysUbOffset, kGatherKeysUbEntries);

  auto copy_ub_to_l1 = MakeCopy(CopyUB2L1{}, CopyUB2L1TraitDefault{});
  __ubuf__ float *shared_scores =
      reinterpret_cast<__ubuf__ float *>(shared_scores_tensor.GetPhyAddr());
  __ubuf__ bfloat16_t *ub_keys_buf =
      reinterpret_cast<__ubuf__ bfloat16_t *>(ub_keys_tensor.GetPhyAddr());

  for (int64_t row_index = static_cast<int64_t>(block_idx);
       row_index < total_rows; row_index += shape.used_core_num) {
    const int64_t head_row = row_index / query_tokens;
    const int64_t query_row = row_index % query_tokens;
    const int64_t batch_index = head_row / query_heads;
    const int64_t head_index = head_row % query_heads;
    const int64_t key_offset = batch_index * context_tokens * head_dim;
    const int64_t indices_offset = (batch_index * indices_query_stride +
                                    indices_query_offset + query_row) *
                                       indices_selected_stride +
                                   indices_selected_offset;
    const int64_t output_base =
        ((batch_index * query_heads + head_index) * output_query_stride +
         output_query_offset + query_row) *
        head_dim;
    const int64_t lse_index =
        (batch_index * query_heads + head_index) * output_query_stride +
        output_query_offset + query_row;

    for (uint32_t n_index = 0; n_index < n_loop; ++n_index) {
      const uint16_t cur_n = static_cast<uint16_t>(
          n_index + 1 == n_loop
              ? shape.n - static_cast<int32_t>(n_index) * kBaseN
              : kBaseN);
      for (uint32_t k_index = 0; k_index < k_loop; ++k_index) {
        const uint16_t cur_k = static_cast<uint16_t>(
            k_index + 1 == k_loop
                ? shape.k - static_cast<int32_t>(k_index) * kBaseK
                : kBaseK);
        AscendC::CrossCoreWaitFlag<kCrossCoreSyncMode, PIPE_MTE3>(
            gather_ready_flag);
        auto ub_keys =
            MakeTensor(MakeMemPtr(ub_keys_buf),
                       MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(cur_k, cur_n));
        auto l1_keys =
            MakeTensor(MakeMemPtr(reinterpret_cast<__cbuf__ bfloat16_t *>(
                           l1_keys_tensor.GetPhyAddr())),
                       MakeFrameLayout<ZNLayoutPtn, bfloat16_t>(cur_k, cur_n));
        for (uint32_t selected_index = 0;
             selected_index < static_cast<uint32_t>(cur_n); ++selected_index) {
          const int32_t context_index =
              indices[indices_offset + n_index * kBaseN + selected_index];
          for (uint32_t dim_offset = 0;
               dim_offset < static_cast<uint32_t>(cur_k); ++dim_offset) {
            const uint32_t dim_index = k_index * kBaseK + dim_offset;
            const uint32_t dst_offset = zn_offset_hd512(
                dim_offset, selected_index, static_cast<uint32_t>(cur_n));
            if (context_index < 0 || context_index >= context_tokens) {
              ub_keys_buf[dst_offset] = 0;
            } else {
              ub_keys_buf[dst_offset] =
                  keys[key_offset +
                       static_cast<int64_t>(context_index) * head_dim +
                       dim_index];
            }
          }
        }
        Copy(copy_ub_to_l1, l1_keys, ub_keys);
        AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_MTE3>(
            gather_ready_flag);
      }
      AscendC::CrossCoreSetFlag<kCrossCoreSyncMode, PIPE_V>(score_ready_flag);
      AscendC::CrossCoreWaitFlag<kCrossCoreSyncMode, PIPE_V>(score_ready_flag);
    }

    AscendC::DataSyncBarrier<AscendC::MemDsbT::UB>();
    extern __ubuf__ uint32_t dynamicStartUB[];
    asc_vf_call<sparse_attention_fused_family_hd512_postprocess_vf>(
        dim3(kFusedPostprocessThreads, 1, 1), shared_scores, values, indices,
        output, lse, key_offset, indices_offset, output_base, lse_index,
        head_dim, static_cast<int32_t>(selected_tokens), score_scale,
        query_start + query_row, causal, dynamicStartUB);
  }
}

__global__ __aicore__ void sparse_attention_fused_family_hd512_kernel(
    __gm__ bfloat16_t* query,
    __gm__ bfloat16_t* keys,
    __gm__ bfloat16_t* values,
    __gm__ const int32_t* indices,
    __gm__ float* output,
    __gm__ float* lse,
    __kfc_workspace__ __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling_gm,
    int64_t total_rows,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t context_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t output_query_stride,
    int64_t output_query_offset,
    float score_scale,
    int64_t query_start,
    bool causal) {
  (void)workspace;
  KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIC_1_2);
  if ASCEND_IS_AIC {
    sparse_attention_fused_family_hd512_aic(
        query,
        tiling_gm,
        total_rows,
        query_tokens,
        selected_tokens,
        query_query_stride,
        query_query_offset);
  } else if ASCEND_IS_AIV {
    sparse_attention_fused_family_hd512_aiv(
        keys,
        values,
        indices,
        output,
        lse,
        query_heads,
        query_tokens,
        selected_tokens,
        context_tokens,
        total_rows,
        indices_query_stride,
        indices_query_offset,
        indices_selected_stride,
        indices_selected_offset,
        output_query_stride,
        output_query_offset,
        score_scale,
        query_start,
        causal,
        tiling_gm);
  }
}

} // namespace

extern "C" void launch_sparse_attention_score_gather_hd512_float(
    const bfloat16_t* query,
    const bfloat16_t* keys,
    const int32_t* indices,
    float* scores,
    uint8_t* workspace,
    uint8_t* tiling,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t context_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t score_stride,
    int64_t score_offset,
    aclrtStream stream) {
  const int64_t total_rows = batch_size * query_heads * query_tokens;
  SparseAttentionScoreHd512Shape shape = {
      static_cast<int32_t>(
          total_rows < kMaxUsedCoreNum ? total_rows : kMaxUsedCoreNum),
      1,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
      1,
      static_cast<int32_t>(selected_tokens),
      kHeadDim,
  };
  aclrtMemcpyAsync(
      tiling,
      sizeof(shape),
      &shape,
      sizeof(shape),
      ACL_MEMCPY_HOST_TO_DEVICE,
      stream);
  for (int64_t row_start = 0; row_start < total_rows; row_start += shape.used_core_num) {
    sparse_attention_score_gather_family_hd512_kernel<<<shape.used_core_num, 0, stream>>>(
        const_cast<bfloat16_t*>(query),
        const_cast<bfloat16_t*>(keys),
        indices,
        scores,
        workspace,
        tiling,
        row_start,
        total_rows,
        query_heads,
        query_tokens,
        context_tokens,
        query_query_stride,
        query_query_offset,
        indices_query_stride,
        indices_query_offset,
        indices_selected_stride,
        indices_selected_offset,
        score_stride,
        score_offset);
  }
}

extern "C" void launch_sparse_attention_hd512_fused_float(
    const bfloat16_t* query,
    const bfloat16_t* keys,
    const bfloat16_t* values,
    const int32_t* indices,
    float* output,
    float* lse,
    uint8_t* tiling,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t context_tokens,
    int64_t head_dim,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t output_query_stride,
    int64_t output_query_offset,
    float score_scale,
    int64_t query_start,
    bool causal,
    aclrtStream stream) {
  const int64_t total_rows = batch_size * query_heads * query_tokens;
  SparseAttentionScoreHd512Shape shape = {
      static_cast<int32_t>(
          total_rows < kFusedMaxUsedCoreNum ? total_rows : kFusedMaxUsedCoreNum),
      1,
      static_cast<int32_t>(selected_tokens),
      static_cast<int32_t>(head_dim),
      1,
      static_cast<int32_t>(selected_tokens),
      static_cast<int32_t>(head_dim),
  };
  aclrtMemcpyAsync(
      tiling,
      sizeof(shape),
      &shape,
      sizeof(shape),
      ACL_MEMCPY_HOST_TO_DEVICE,
      stream);
  auto workspace = reinterpret_cast<uint8_t*>(output);
  sparse_attention_fused_family_hd512_kernel<<<shape.used_core_num, 0, stream>>>(
      const_cast<bfloat16_t*>(query),
      const_cast<bfloat16_t*>(keys),
      const_cast<bfloat16_t*>(values),
      indices,
      output,
      lse,
      workspace,
      tiling,
      total_rows,
      query_heads,
      query_tokens,
      selected_tokens,
      context_tokens,
      query_query_stride,
      query_query_offset,
      indices_query_stride,
      indices_query_offset,
      indices_selected_stride,
      indices_selected_offset,
      output_query_stride,
      output_query_offset,
      score_scale,
      query_start,
      causal);
}
