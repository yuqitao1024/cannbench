#include <algorithm>
#include <ATen/Functions.h>
#include <ATen/core/TensorBody.h>
#include <c10/core/ScalarType.h>
#include <torch/library.h>

#include <cmath>
#include <string_view>
#include <tuple>

#include "acl/acl.h"
#include "torch_npu/csrc/core/npu/NPUStream.h"
#include "torch_npu/csrc/framework/OpCommand.h"

namespace aten_dsa_sparse_attention {
namespace {

constexpr int64_t kFamilyHd512QueryTile = 4;
constexpr int64_t kFamilyHd512SelectedTile = 128;
constexpr int64_t kFamilyHd128QueryTile = 8;
constexpr int64_t kFamilyHd128SelectedTile = 256;

extern "C" void launch_sparse_attention_hd512_postprocess_float(
    const float* scores,
    const float* selected_values,
    const int32_t* indices,
    float* output,
    float* lse,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t query_start,
    bool causal,
    aclrtStream stream);

extern "C" void launch_sparse_attention_hd128_postprocess_float(
    const float* scores,
    const float* selected_values,
    const int32_t* indices,
    float* output,
    float* lse,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t query_start,
    bool causal,
    aclrtStream stream);

void run_sparse_attention_family_hd512_tile(
    const at::Tensor& scores,
    const at::Tensor& selected_values,
    const at::Tensor& indices_tile,
    at::Tensor& output_tile,
    at::Tensor& lse_tile,
    int64_t batch_size,
    int64_t query_heads,
    int64_t current_query,
    int64_t selected_tokens,
    int64_t query_start,
    bool causal,
    aclrtStream acl_stream) {
  auto acl_call = [=, &output_tile, &lse_tile]() -> int {
    launch_sparse_attention_hd512_postprocess_float(
        scores.const_data_ptr<float>(),
        selected_values.const_data_ptr<float>(),
        indices_tile.const_data_ptr<int32_t>(),
        output_tile.mutable_data_ptr<float>(),
        lse_tile.mutable_data_ptr<float>(),
        batch_size,
        query_heads,
        current_query,
        selected_tokens,
        query_start,
        causal,
        acl_stream);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(
      "aten_dsa_sparse_attention::sparse_attention_forward_family_hd512",
      acl_call);
}

void run_sparse_attention_family_hd128_tile(
    const at::Tensor& scores,
    const at::Tensor& selected_values,
    const at::Tensor& indices_tile,
    at::Tensor& output_tile,
    at::Tensor& lse_tile,
    int64_t batch_size,
    int64_t query_heads,
    int64_t current_query,
    int64_t selected_tokens,
    int64_t query_start,
    bool causal,
    aclrtStream acl_stream) {
  auto acl_call = [=, &output_tile, &lse_tile]() -> int {
    launch_sparse_attention_hd128_postprocess_float(
        scores.const_data_ptr<float>(),
        selected_values.const_data_ptr<float>(),
        indices_tile.const_data_ptr<int32_t>(),
        output_tile.mutable_data_ptr<float>(),
        lse_tile.mutable_data_ptr<float>(),
        batch_size,
        query_heads,
        current_query,
        selected_tokens,
        query_start,
        causal,
        acl_stream);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(
      "aten_dsa_sparse_attention::sparse_attention_forward_decode_family_hd128",
      acl_call);
}

at::Tensor build_sparse_attention_score_tile(
    const at::Tensor& query_tile,
    const at::Tensor& selected_keys_chunk,
    int64_t current_query,
    float scale) {
  auto query_matmul = query_tile.unsqueeze(3);
  auto key_matmul = selected_keys_chunk.transpose(3, 4);
  return at::matmul(query_matmul, key_matmul).squeeze(3) * scale;
}

std::tuple<at::Tensor, at::Tensor> sparse_attention_forward_family_hd512_hybrid(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& values,
    const at::Tensor& indices,
    bool causal) {
  const auto batch_size = query.size(0);
  const auto query_heads = query.size(1);
  const auto query_tokens = query.size(2);
  const auto context_tokens = keys.size(2);
  const auto selected_tokens = indices.size(2);
  const auto head_dim = query.size(3);

  auto output = at::empty(
      {batch_size, query_heads, query_tokens, head_dim},
      query.options().dtype(c10::kFloat));
  auto lse = at::empty(
      {batch_size, query_heads, query_tokens},
      query.options().dtype(c10::kFloat));

  auto expanded_keys = keys.expand({batch_size, query_heads, context_tokens, head_dim});
  auto expanded_values = values.expand({batch_size, query_heads, context_tokens, head_dim});
  const auto scale = 1.0F / std::sqrt(static_cast<float>(head_dim));
  const auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);

  for (int64_t query_start = 0; query_start < query_tokens;
       query_start += kFamilyHd512QueryTile) {
    const auto current_query =
        std::min<int64_t>(kFamilyHd512QueryTile, query_tokens - query_start);
    auto query_tile = query.narrow(2, query_start, current_query);
    auto indices_tile = indices.narrow(1, query_start, current_query);
    auto output_tile = at::empty(
        {batch_size, query_heads, current_query, head_dim},
        query.options().dtype(c10::kFloat));
    auto lse_tile = at::empty(
        {batch_size, query_heads, current_query},
        query.options().dtype(c10::kFloat));
    auto scores = at::empty(
        {batch_size, query_heads, current_query, selected_tokens},
        query.options().dtype(c10::kFloat));
    auto selected_values = at::empty(
        {batch_size, query_heads, current_query, selected_tokens, head_dim},
        query.options().dtype(c10::kFloat));

    auto source_keys = expanded_keys.unsqueeze(2).expand(
        {batch_size, query_heads, current_query, context_tokens, head_dim});
    auto source_values = expanded_values.unsqueeze(2).expand(
        {batch_size, query_heads, current_query, context_tokens, head_dim});

    for (int64_t selected_start = 0; selected_start < selected_tokens;
         selected_start += kFamilyHd512SelectedTile) {
      const auto current_selected =
          std::min<int64_t>(kFamilyHd512SelectedTile, selected_tokens - selected_start);
      auto indices_chunk = indices_tile.narrow(2, selected_start, current_selected);
      auto gather_index = indices_chunk.unsqueeze(1).unsqueeze(-1).expand(
          {batch_size, query_heads, current_query, current_selected, head_dim});
      auto selected_keys_chunk = at::gather(source_keys, 3, gather_index);
      auto selected_values_chunk = at::gather(source_values, 3, gather_index);
      auto scores_chunk = build_sparse_attention_score_tile(
          query_tile,
          selected_keys_chunk,
          current_query,
          scale);

      scores.narrow(3, selected_start, current_selected).copy_(scores_chunk);
      selected_values.narrow(3, selected_start, current_selected).copy_(selected_values_chunk);
    }

    run_sparse_attention_family_hd512_tile(
        scores,
        selected_values,
        indices_tile,
        output_tile,
        lse_tile,
        batch_size,
        query_heads,
        current_query,
        selected_tokens,
        query_start,
        causal,
        acl_stream);
    output.narrow(2, query_start, current_query).copy_(output_tile);
    lse.narrow(2, query_start, current_query).copy_(lse_tile);
  }

  return {output, lse};
}

std::tuple<at::Tensor, at::Tensor> sparse_attention_forward_family_hd128_hybrid(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& values,
    const at::Tensor& indices,
    bool causal) {
  const auto batch_size = query.size(0);
  const auto query_heads = query.size(1);
  const auto query_tokens = query.size(2);
  const auto context_tokens = keys.size(2);
  const auto selected_tokens = indices.size(2);
  const auto head_dim = query.size(3);

  auto output = at::empty(
      {batch_size, query_heads, query_tokens, head_dim},
      query.options().dtype(c10::kFloat));
  auto lse = at::empty(
      {batch_size, query_heads, query_tokens},
      query.options().dtype(c10::kFloat));

  auto expanded_keys = keys.expand({batch_size, query_heads, context_tokens, head_dim});
  auto expanded_values = values.expand({batch_size, query_heads, context_tokens, head_dim});
  const auto scale = 1.0F / std::sqrt(static_cast<float>(head_dim));
  const auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);

  for (int64_t query_start = 0; query_start < query_tokens;
       query_start += kFamilyHd128QueryTile) {
    const auto current_query =
        std::min<int64_t>(kFamilyHd128QueryTile, query_tokens - query_start);
    auto query_tile = query.narrow(2, query_start, current_query);
    auto indices_tile = indices.narrow(1, query_start, current_query);
    auto output_tile = at::empty(
        {batch_size, query_heads, current_query, head_dim},
        query.options().dtype(c10::kFloat));
    auto lse_tile = at::empty(
        {batch_size, query_heads, current_query},
        query.options().dtype(c10::kFloat));
    auto scores = at::empty(
        {batch_size, query_heads, current_query, selected_tokens},
        query.options().dtype(c10::kFloat));
    auto selected_values = at::empty(
        {batch_size, query_heads, current_query, selected_tokens, head_dim},
        query.options().dtype(c10::kFloat));

    auto source_keys = expanded_keys.unsqueeze(2).expand(
        {batch_size, query_heads, current_query, context_tokens, head_dim});
    auto source_values = expanded_values.unsqueeze(2).expand(
        {batch_size, query_heads, current_query, context_tokens, head_dim});

    for (int64_t selected_start = 0; selected_start < selected_tokens;
         selected_start += kFamilyHd128SelectedTile) {
      const auto current_selected =
          std::min<int64_t>(kFamilyHd128SelectedTile, selected_tokens - selected_start);
      auto indices_chunk = indices_tile.narrow(2, selected_start, current_selected);
      auto gather_index = indices_chunk.unsqueeze(1).unsqueeze(-1).expand(
          {batch_size, query_heads, current_query, current_selected, head_dim});
      auto selected_keys_chunk = at::gather(source_keys, 3, gather_index);
      auto selected_values_chunk = at::gather(source_values, 3, gather_index);
      auto scores_chunk = build_sparse_attention_score_tile(
          query_tile,
          selected_keys_chunk,
          current_query,
          scale);

      scores.narrow(3, selected_start, current_selected).copy_(scores_chunk);
      selected_values.narrow(3, selected_start, current_selected).copy_(selected_values_chunk);
    }

    run_sparse_attention_family_hd128_tile(
        scores,
        selected_values,
        indices_tile,
        output_tile,
        lse_tile,
        batch_size,
        query_heads,
        current_query,
        selected_tokens,
        query_start,
        causal,
        acl_stream);
    output.narrow(2, query_start, current_query).copy_(output_tile);
    lse.narrow(2, query_start, current_query).copy_(lse_tile);
  }

  return {output, lse};
}

std::tuple<at::Tensor, at::Tensor> sparse_attention_forward_privateuse1(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& values,
    const at::Tensor& indices,
    std::string_view phase,
    std::string_view family,
    bool causal) {
  TORCH_CHECK(
      query.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU query tensor");
  TORCH_CHECK(
      keys.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU keys tensor");
  TORCH_CHECK(
      values.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU values tensor");
  TORCH_CHECK(
      indices.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU indices tensor");
  TORCH_CHECK(query.dim() == 4, "query must have shape [B, Hq, Q, D]");
  TORCH_CHECK(keys.dim() == 4, "keys must have shape [B, Hkv, C, D]");
  TORCH_CHECK(values.dim() == 4, "values must have shape [B, Hkv, C, D]");
  TORCH_CHECK(indices.dim() == 3, "indices must have shape [B, Q, S]");
  TORCH_CHECK(query.size(0) == keys.size(0), "batch sizes must match");
  TORCH_CHECK(query.size(0) == values.size(0), "batch sizes must match");
  TORCH_CHECK(query.size(0) == indices.size(0), "batch sizes must match");
  TORCH_CHECK(query.size(2) == indices.size(1), "query token counts must match");
  TORCH_CHECK(keys.size(2) == values.size(2), "context sizes must match");
  TORCH_CHECK(
      query.scalar_type() == at::ScalarType::Float ||
          query.scalar_type() == at::ScalarType::Half ||
          query.scalar_type() == at::ScalarType::BFloat16,
      "sparse_attention custom op supports float32/float16/bfloat16 query");
  TORCH_CHECK(
      keys.scalar_type() == query.scalar_type() &&
          values.scalar_type() == query.scalar_type(),
      "query, keys, and values must use the same dtype");
  TORCH_CHECK(
      indices.scalar_type() == at::ScalarType::Long ||
          indices.scalar_type() == at::ScalarType::Int,
      "indices must use int64 or int32");

  if (query.numel() == 0 || keys.numel() == 0 || values.numel() == 0 ||
      indices.numel() == 0) {
    return {
        at::empty(
            {query.size(0), query.size(1), query.size(2), query.size(3)},
            query.options()),
        at::empty(
            {query.size(0), query.size(1), query.size(2)},
            query.options().dtype(c10::kFloat)),
    };
  }

  auto query_float = query.scalar_type() == at::ScalarType::Float
      ? query.contiguous()
      : query.to(at::kFloat).contiguous();
  auto keys_float = keys.scalar_type() == at::ScalarType::Float
      ? keys.contiguous()
      : keys.to(at::kFloat).contiguous();
  auto values_float = values.scalar_type() == at::ScalarType::Float
      ? values.contiguous()
      : values.to(at::kFloat).contiguous();
  auto indices_int = indices.scalar_type() == at::ScalarType::Int
      ? indices.contiguous()
      : indices.to(at::kInt).contiguous();

  at::Tensor output_float;
  at::Tensor lse;
  const bool apply_causal_mask = causal && phase == "prefill";

  if (family == "family_hd512" && (phase == "prefill" || phase == "decode")) {
    TORCH_CHECK(query.size(3) == 512, "family_hd512 requires D == 512");
    TORCH_CHECK(keys.size(1) == 1, "family_hd512 requires kv_heads == 1");
    TORCH_CHECK(values.size(1) == 1, "family_hd512 requires kv_heads == 1");
    TORCH_CHECK(keys.size(3) == 512, "family_hd512 requires key D == 512");
    TORCH_CHECK(values.size(3) == 512, "family_hd512 requires value D == 512");
    TORCH_CHECK(
        indices.size(2) <= 1024,
        "family_hd512 custom op requires selected_tokens <= 1024");
    auto result = sparse_attention_forward_family_hd512_hybrid(
        query_float,
        keys_float,
        values_float,
        indices_int,
        apply_causal_mask);
    output_float = std::get<0>(result);
    lse = std::get<1>(result);
  } else if (
      family == "family_hd128" &&
      (phase == "prefill" || phase == "decode")) {
    TORCH_CHECK(query.size(1) == 128, "family_hd128 requires query_heads == 128");
    TORCH_CHECK(query.size(3) == 128, "family_hd128 requires D == 128");
    TORCH_CHECK(keys.size(1) == 1, "family_hd128 requires kv_heads == 1");
    TORCH_CHECK(values.size(1) == 1, "family_hd128 requires kv_heads == 1");
    TORCH_CHECK(keys.size(3) == 128, "family_hd128 requires key D == 128");
    TORCH_CHECK(values.size(3) == 128, "family_hd128 requires value D == 128");
    TORCH_CHECK(
        indices.size(2) <= 2048,
        "family_hd128 custom op requires selected_tokens <= 2048");
    if (phase == "decode") {
      TORCH_CHECK(query.size(2) == 1, "family_hd128 decode requires query_tokens == 1");
    }

    auto result = sparse_attention_forward_family_hd128_hybrid(
        query_float,
        keys_float,
        values_float,
        indices_int,
        apply_causal_mask);
    output_float = std::get<0>(result);
    lse = std::get<1>(result);
  } else {
    TORCH_CHECK(
        false,
        "sparse_attention custom op supports family_hd512 prefill/decode and family_hd128 prefill/decode only");
  }

  auto output = query.scalar_type() == at::ScalarType::Float
      ? output_float
      : output_float.to(query.scalar_type());
  return {output, lse};
}

TORCH_LIBRARY_FRAGMENT(aten_dsa_sparse_attention, m) {
  m.def(
      "sparse_attention_forward(Tensor query, Tensor keys, Tensor values, Tensor indices, str phase, str family, bool causal) -> (Tensor, Tensor)");
}

TORCH_LIBRARY_IMPL(aten_dsa_sparse_attention, PrivateUse1, m) {
  m.impl("sparse_attention_forward", &sparse_attention_forward_privateuse1);
}

} // namespace
} // namespace aten_dsa_sparse_attention
