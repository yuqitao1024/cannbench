#include <ATen/Functions.h>
#include <ATen/core/TensorBody.h>
#include <c10/core/ScalarType.h>
#include <torch/library.h>

#include <string_view>
#include <tuple>

#include "acl/acl.h"
#include "torch_npu/csrc/core/npu/NPUStream.h"
#include "torch_npu/csrc/framework/OpCommand.h"

namespace aten_dsa_sparse_attention {
namespace {

void launch_sparse_attention_prefill_family_hd512_float(
    const float* query,
    const float* keys,
    const float* values,
    const int32_t* indices,
    float* output,
    float* lse,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t context_tokens,
    int64_t selected_tokens,
    bool causal,
    aclrtStream stream);

std::tuple<at::Tensor, at::Tensor> sparse_attention_forward_prefill_family_hd512(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& values,
    const at::Tensor& indices,
    bool causal) {
  const auto batch_size = query.size(0);
  const auto query_heads = query.size(1);
  const auto query_tokens = query.size(2);
  const auto context_tokens = keys.size(2);
  const auto selected_tokens = indices.size(2);

  auto output = at::empty(
      {batch_size, query_heads, query_tokens, query.size(3)},
      query.options().dtype(c10::kFloat));
  auto lse = at::empty(
      {batch_size, query_heads, query_tokens},
      query.options().dtype(c10::kFloat));

  const auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);
  auto acl_call = [=]() -> int {
    launch_sparse_attention_prefill_family_hd512_float(
        query.const_data_ptr<float>(),
        keys.const_data_ptr<float>(),
        values.const_data_ptr<float>(),
        indices.const_data_ptr<int32_t>(),
        output.mutable_data_ptr<float>(),
        lse.mutable_data_ptr<float>(),
        batch_size,
        query_heads,
        query_tokens,
        context_tokens,
        selected_tokens,
        causal,
        acl_stream);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(
      "aten_dsa_sparse_attention::sparse_attention_forward_prefill_family_hd512",
      acl_call);
  return {output, lse};
}

std::tuple<at::Tensor, at::Tensor> sparse_attention_forward_privateuse1(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& values,
    const at::Tensor& indices,
    std::string_view phase,
    std::string_view family,
    bool causal) {
  TORCH_CHECK(
      query.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU query tensor");
  TORCH_CHECK(
      keys.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU keys tensor");
  TORCH_CHECK(
      values.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU values tensor");
  TORCH_CHECK(
      indices.device().type() == at::DeviceType::PrivateUse1,
      "expected PrivateUse1/NPU indices tensor");
  TORCH_CHECK(phase == "prefill", "sparse_attention custom op only supports prefill");
  TORCH_CHECK(
      family == "family_hd512",
      "sparse_attention custom op only supports family_hd512");
  TORCH_CHECK(query.dim() == 4, "query must have shape [B, Hq, Q, D]");
  TORCH_CHECK(keys.dim() == 4, "keys must have shape [B, Hkv, C, D]");
  TORCH_CHECK(values.dim() == 4, "values must have shape [B, Hkv, C, D]");
  TORCH_CHECK(indices.dim() == 3, "indices must have shape [B, Q, S]");
  TORCH_CHECK(query.size(3) == 512, "family_hd512 requires D == 512");
  TORCH_CHECK(keys.size(1) == 1, "family_hd512 requires kv_heads == 1");
  TORCH_CHECK(values.size(1) == 1, "family_hd512 requires kv_heads == 1");
  TORCH_CHECK(keys.size(3) == 512, "family_hd512 requires key D == 512");
  TORCH_CHECK(values.size(3) == 512, "family_hd512 requires value D == 512");
  TORCH_CHECK(query.size(0) == keys.size(0), "batch sizes must match");
  TORCH_CHECK(query.size(0) == values.size(0), "batch sizes must match");
  TORCH_CHECK(query.size(0) == indices.size(0), "batch sizes must match");
  TORCH_CHECK(query.size(2) == indices.size(1), "query token counts must match");
  TORCH_CHECK(keys.size(2) == values.size(2), "context sizes must match");
  TORCH_CHECK(
      indices.size(2) <= 1024,
      "family_hd512 custom op requires selected_tokens <= 1024");
  TORCH_CHECK(
      query.scalar_type() == at::ScalarType::Float ||
          query.scalar_type() == at::ScalarType::Half ||
          query.scalar_type() == at::ScalarType::BFloat16,
      "sparse_attention custom op supports float32/float16/bfloat16 query");
  TORCH_CHECK(
      keys.scalar_type() == query.scalar_type() &&
          values.scalar_type() == query.scalar_type(),
      "query, keys, and values must use the same dtype");
  TORCH_CHECK(
      indices.scalar_type() == at::ScalarType::Long ||
          indices.scalar_type() == at::ScalarType::Int,
      "indices must use int64 or int32");

  if (query.numel() == 0 || keys.numel() == 0 || values.numel() == 0 ||
      indices.numel() == 0) {
    return {
        at::empty(
            {query.size(0), query.size(1), query.size(2), query.size(3)},
            query.options()),
        at::empty(
            {query.size(0), query.size(1), query.size(2)},
            query.options().dtype(c10::kFloat)),
    };
  }

  auto query_float = query.scalar_type() == at::ScalarType::Float
      ? query.contiguous()
      : query.to(at::kFloat).contiguous();
  auto keys_float = keys.scalar_type() == at::ScalarType::Float
      ? keys.contiguous()
      : keys.to(at::kFloat).contiguous();
  auto values_float = values.scalar_type() == at::ScalarType::Float
      ? values.contiguous()
      : values.to(at::kFloat).contiguous();
  auto indices_int = indices.scalar_type() == at::ScalarType::Int
      ? indices.contiguous()
      : indices.to(at::kInt).contiguous();

  auto [output_float, lse] = sparse_attention_forward_prefill_family_hd512(
      query_float,
      keys_float,
      values_float,
      indices_int,
      causal);
  auto output = query.scalar_type() == at::ScalarType::Float
      ? output_float
      : output_float.to(query.scalar_type());
  return {output, lse};
}

TORCH_LIBRARY_FRAGMENT(aten_dsa_sparse_attention, m) {
  m.def(
      "sparse_attention_forward(Tensor query, Tensor keys, Tensor values, Tensor indices, str phase, str family, bool causal) -> (Tensor, Tensor)");
}

TORCH_LIBRARY_IMPL(aten_dsa_sparse_attention, PrivateUse1, m) {
  m.impl("sparse_attention_forward", &sparse_attention_forward_privateuse1);
}

} // namespace
} // namespace aten_dsa_sparse_attention
