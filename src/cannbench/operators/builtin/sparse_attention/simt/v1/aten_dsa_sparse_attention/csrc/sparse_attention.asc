void run_sparse_attention_family_hd512_fused_tile(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& values,
    const at::Tensor& indices,
    at::Tensor& output,
    at::Tensor& lse,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t context_tokens,
    int64_t query_query_stride,
    int64_t query_query_offset,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t output_query_stride,
    int64_t output_query_offset,
    float score_scale,
    int64_t query_start,
    bool causal,
    aclrtStream acl_stream) {
  auto output_tensor = output;
  auto lse_tensor = lse;
  auto tiling = at::empty({4096}, query.options().dtype(c10::kByte));
  auto acl_call = [=]() mutable -> int {
    launch_sparse_attention_hd512_fused_float(
        query.const_data_ptr<at::Half>(),
        keys.const_data_ptr<float>(),
        values.const_data_ptr<float>(),
        indices.const_data_ptr<int32_t>(),
        output_tensor.mutable_data_ptr<float>(),
        lse_tensor.mutable_data_ptr<float>(),
        tiling.mutable_data_ptr<uint8_t>(),
        batch_size,
        query_heads,
        query_tokens,
        selected_tokens,
        context_tokens,
        query_query_stride,
        query_query_offset,
        indices_query_stride,
        indices_query_offset,
        indices_selected_stride,
        indices_selected_offset,
        output_query_stride,
        output_query_offset,
        score_scale,
        query_start,
        causal,
        acl_stream);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(
      "aten_dsa_sparse_attention::sparse_attention_forward_family_hd512_fused",
      acl_call);
}

