void run_sparse_attention_family_hd512_tile(
    const at::Tensor& scores,
    const at::Tensor& selected_values,
    const at::Tensor& indices,
    at::Tensor& output,
    at::Tensor& lse,
    int64_t batch_size,
    int64_t query_heads,
    int64_t current_query,
    int64_t selected_tokens,
    int64_t indices_query_stride,
    int64_t indices_query_offset,
    int64_t indices_selected_stride,
    int64_t indices_selected_offset,
    int64_t output_query_stride,
    int64_t output_query_offset,
    float score_scale,
    int64_t query_start,
    bool causal,
    aclrtStream acl_stream) {
  auto output_tensor = output;
  auto lse_tensor = lse;
  auto acl_call = [=]() mutable -> int {
    launch_sparse_attention_hd512_postprocess_float(
        scores.const_data_ptr<float>(),
        selected_values.const_data_ptr<float>(),
        indices.const_data_ptr<int32_t>(),
        output_tensor.mutable_data_ptr<float>(),
        lse_tensor.mutable_data_ptr<float>(),
        batch_size,
        query_heads,
        current_query,
        selected_tokens,
        indices_query_stride,
        indices_query_offset,
        indices_selected_stride,
        indices_selected_offset,
        output_query_stride,
        output_query_offset,
        score_scale,
        query_start,
        causal,
        acl_stream);
    return 0;
  };
  at_npu::native::OpCommand::RunOpApiV2(
      "aten_dsa_sparse_attention::sparse_attention_forward_family_hd512",
      acl_call);
}

