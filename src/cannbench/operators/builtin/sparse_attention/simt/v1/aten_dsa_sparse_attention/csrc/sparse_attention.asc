std::tuple<at::Tensor, at::Tensor> sparse_attention_forward_family_hd512_hybrid(
    const at::Tensor& query,
    const at::Tensor& keys,
    const at::Tensor& values,
    const at::Tensor& indices,
    bool causal) {
  const auto batch_size = query.size(0);
  const auto query_heads = query.size(1);
  const auto query_tokens = query.size(2);
  const auto context_tokens = keys.size(2);
  const auto selected_tokens = indices.size(2);
  const auto head_dim = query.size(3);

  auto output = at::empty(
      {batch_size, query_heads, query_tokens, head_dim},
      query.options().dtype(c10::kFloat));
  auto lse = at::empty(
      {batch_size, query_heads, query_tokens},
      query.options().dtype(c10::kFloat));

  const auto scale = 1.0F / std::sqrt(static_cast<float>(head_dim));
  const auto acl_stream = c10_npu::getCurrentNPUStream().stream(true);

  for (int64_t query_start = 0; query_start < query_tokens;
       query_start += kFamilyHd512QueryTile) {
    const auto current_query =
        std::min<int64_t>(kFamilyHd512QueryTile, query_tokens - query_start);
    at::Tensor score_query;
    int64_t score_query_stride = query_tokens;
    int64_t score_query_offset = query_start;
    if (query.scalar_type() == at::ScalarType::Half) {
      score_query = query;
      run_sparse_attention_family_hd512_fused_tile(
          score_query,
          keys,
          values,
          indices,
          output,
          lse,
          batch_size,
          query_heads,
          current_query,
          selected_tokens,
          context_tokens,
          score_query_stride,
          score_query_offset,
          query_tokens,
          query_start,
          selected_tokens,
          0,
          query_tokens,
          query_start,
          scale,
          query_start,
          causal,
          acl_stream);
      continue;
    } else {
      auto query_tile = at::empty(
          {batch_size, query_heads, current_query, head_dim},
          query.options().dtype(c10::kHalf));
      run_sparse_attention_query_pack_hd512_tile(
          query,
          query_tile,
          batch_size,
          query_heads,
          current_query,
          query_tokens,
          query_start,
          acl_stream);
      score_query = query_tile;
      score_query_stride = current_query;
      score_query_offset = 0;
    }
    auto scores = at::empty(
        {batch_size, query_heads, current_query, selected_tokens},
        query.options().dtype(c10::kFloat));
    for (int64_t selected_start = 0; selected_start < selected_tokens;
         selected_start += kFamilyHd512SelectedTile) {
      const auto current_selected =
          std::min<int64_t>(kFamilyHd512SelectedTile, selected_tokens - selected_start);
      auto score_workspace = at::empty(
          {16 * 1024 * 1024},
          query.options().dtype(c10::kByte));
      auto score_tiling = at::empty(
          {4096},
          query.options().dtype(c10::kByte));
      run_sparse_attention_score_gather_family_hd512_tile(
          score_query,
          keys,
          indices,
          scores,
          score_workspace,
          score_tiling,
          batch_size,
          query_heads,
          current_query,
          current_selected,
          context_tokens,
          score_query_stride,
          score_query_offset,
          query_tokens,
          query_start,
          selected_tokens,
          selected_start,
          selected_tokens,
          selected_start,
          acl_stream);
    }

    run_sparse_attention_family_hd512_decode_direct_tile(
        scores,
        values,
        indices,
        output,
        lse,
        batch_size,
        query_heads,
        current_query,
        context_tokens,
        selected_tokens,
        query_tokens,
        query_start,
        selected_tokens,
        0,
        query_tokens,
        query_start,
        scale,
        query_start,
        causal,
        acl_stream);
  }

  return {output, lse};
}

